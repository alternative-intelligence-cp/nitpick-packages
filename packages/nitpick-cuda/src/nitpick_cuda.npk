pub func:cuda_malloc_managed = int64(int32:byte_size) {
    int64:r = nitpick_cuda_malloc_managed(byte_size);
    pass(r);
};

pub func:cuda_managed_set_f32 = NIL(int64:ptr, int32:index, flt32:val) {
    nitpick_cuda_managed_set_f32(ptr, index, val);
    pass(NIL);
};

pub func:cuda_managed_get_f32 = flt32(int64:ptr, int32:index) {
    flt32:r = nitpick_cuda_managed_get_f32(ptr, index);
    pass(r);
};

pub func:cuda_managed_set_i32 = NIL(int64:ptr, int32:index, int32:val) {
    nitpick_cuda_managed_set_i32(ptr, index, val);
    pass(NIL);
};

pub func:cuda_managed_get_i32 = int32(int64:ptr, int32:index) {
    int32:r = nitpick_cuda_managed_get_i32(ptr, index);
    pass(r);
};

pub func:cuda_prefetch_async = int32(int64:ptr, int32:byte_size, int32:dst_device, int64:cu_stream) {
    int32:r = nitpick_cuda_prefetch_async(ptr, byte_size, dst_device, cu_stream);
    pass(r);
};

pub func:cuda_cpu_device_id = int32() {
    int32:r = nitpick_cuda_cpu_device_id();
    pass(r);
};

