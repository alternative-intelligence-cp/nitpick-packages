// test_nitpick_input.npk — 12-test suite for nitpick-input (v0.12.2)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_input.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:test_create_names = int32() {
    int32:pc = 0i32;

    int64:inp = raw inp_create();
    if (inp > 0i64) { println("[PASS] T01 inp_create"); pc += 1i32; }
    if (inp <= 0i64) { println("[FAIL] T01"); }

    string:n2 = raw inp_btn_name(1i64);
    int32:t2 = 0i32;
    if (string_contains(n2, "UP")) { t2 = 1i32; }
    if (t2 == 1i32) { println("[PASS] T02 btn_name(1)=UP"); pc += 1i32; }
    if (t2 == 0i32) { println("[FAIL] T02"); }

    string:n3 = raw inp_btn_name(8i64);
    int32:t3 = 0i32;
    if (string_contains(n3, "RIGHT")) { t3 = 1i32; }
    if (t3 == 1i32) { println("[PASS] T03 btn_name(8)=RIGHT"); pc += 1i32; }
    if (t3 == 0i32) { println("[FAIL] T03"); }

    pass pc;
};

func:test_bitmask = int32() {
    int32:pc = 0i32;

    int64:inp = raw inp_create();

    // mask=5 means UP(1)+LEFT(4)
    int32:_s = raw inp_set_buttons(inp, 5i64);

    int64:has4 = raw inp_has_button(inp, 1i64);
    if (has4 == 1i64) { println("[PASS] T04 has UP in mask=5"); pc += 1i32; }
    if (has4 != 1i64) { println("[FAIL] T04"); }

    int64:has5 = raw inp_has_button(inp, 2i64);
    if (has5 == 0i64) { println("[PASS] T05 no DOWN in mask=5"); pc += 1i32; }
    if (has5 != 0i64) { println("[FAIL] T05"); }

    int64:has6 = raw inp_has_button(inp, 4i64);
    if (has6 == 1i64) { println("[PASS] T06 has LEFT in mask=5"); pc += 1i32; }
    if (has6 != 1i64) { println("[FAIL] T06"); }

    pass pc;
};

func:test_press_release = int32() {
    int32:pc = 0i32;

    int64:inp = raw inp_create();

    // Frame 1: no buttons → prev=0, cur=0
    int32:_u1 = raw inp_update(inp);
    // Frame 2: press UP → prev=0, cur=1
    int32:_s2 = raw inp_set_buttons(inp, 1i64);
    int64:p7 = raw inp_btnp(inp, 1i64);
    if (p7 == 1i64) { println("[PASS] T07 btnp UP (newly pressed)"); pc += 1i32; }
    if (p7 != 1i64) { println("[FAIL] T07"); }

    // Frame 3: update → prev=1, cur=1 (still held)
    int32:_u3 = raw inp_update(inp);
    int64:p8 = raw inp_btnp(inp, 1i64);
    if (p8 == 0i64) { println("[PASS] T08 btnp UP not new (held)"); pc += 1i32; }
    if (p8 != 0i64) { println("[FAIL] T08"); }

    // Frame 4: release UP → prev=1, cur=0
    int32:_s4 = raw inp_set_buttons(inp, 0i64);
    int64:r9 = raw inp_btnr(inp, 1i64);
    if (r9 == 1i64) { println("[PASS] T09 btnr UP (released)"); pc += 1i32; }
    if (r9 != 1i64) { println("[FAIL] T09"); }

    pass pc;
};

func:test_bindings = int32() {
    int32:pc = 0i32;

    int64:inp = raw inp_create();

    int32:_b1 = raw inp_bind_key(inp, "w", 1i64);
    string:btn10 = raw inp_key_to_btn(inp, "w");
    int32:t10 = 0i32;
    if (string_contains(btn10, "1")) { t10 = 1i32; }
    if (t10 == 1i32) { println("[PASS] T10 bind w→UP(1)"); pc += 1i32; }
    if (t10 == 0i32) { println("[FAIL] T10"); }

    int32:_b2 = raw inp_bind_key(inp, "space", 16i64);
    string:btn11 = raw inp_key_to_btn(inp, "space");
    int32:t11 = 0i32;
    if (string_contains(btn11, "16")) { t11 = 1i32; }
    if (t11 == 1i32) { println("[PASS] T11 bind space→A(16)"); pc += 1i32; }
    if (t11 == 0i32) { println("[FAIL] T11"); }

    string:btn12 = raw inp_key_to_btn(inp, "unknown_key");
    int32:t12 = 0i32;
    if (string_contains(btn12, "0")) { t12 = 1i32; }
    if (t12 == 1i32) { println("[PASS] T12 unbound key→0"); pc += 1i32; }
    if (t12 == 0i32) { println("[FAIL] T12"); }

    pass pc;
};

func:main = int32() {
    int32:pass_count = 0i32;
    int32:p1 = raw test_create_names();
    int32:p2 = raw test_bitmask();
    int32:p3 = raw test_press_release();
    int32:p4 = raw test_bindings();
    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
