# build.abc — nitpick-clamp package

[project]
name = "nitpick-clamp"
version = "0.1.0"
compiler = "/home/randy/Workspace/REPOS/nitpick/build/nitpickc"

[target.nitpick-clamp]
type = "library"
sources = ["src/nitpick_clamp.npk"]
deps = []
flags = []

[target.test-nitpick-clamp]
type = "binary"
sources = ["tests/test_nitpick_clamp.npk"]
deps = []
flags = ["-I", "src", "-L", "../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_io"]
