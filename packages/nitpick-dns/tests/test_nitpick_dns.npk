// test_nitpick_dns.npk
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_dns.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:_err) {
    drop _err;
    exit 1i32;
};

func:assert_eq_i64 = int64(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:assert_eq_str = int64(string:actual, string:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:main = int32() {
    string:ip1 = raw Dns.resolve("localhost");
    drop assert_eq_str(ip1, "127.0.0.1", "T01 resolve localhost\0");

    string:all2 = raw Dns.resolve_all("localhost");
    drop assert_eq_str(all2, "127.0.0.1", "T02 resolve_all localhost\0");

    int64:v3 = raw Dns.is_ipv4("192.168.1.1");
    drop assert_eq_i64(v3, 1i64, "T03 is_ipv4 valid\0");

    int64:v4 = raw Dns.is_ipv4("not.an.ip");
    drop assert_eq_i64(v4, 0i64, "T04 is_ipv4 invalid\0");

    int64:h5 = raw Dns.is_hostname("example.com");
    drop assert_eq_i64(h5, 1i64, "T05 is_hostname true\0");

    int64:h6 = raw Dns.is_hostname("10.0.0.1");
    drop assert_eq_i64(h6, 0i64, "T06 is_hostname false for IP\0");

    int64:cr7 = raw Dns.can_resolve("localhost");
    drop assert_eq_i64(cr7, 1i64, "T07 can_resolve localhost\0");

    int64:cr8 = raw Dns.can_resolve("this.host.does.not.exist.invalid");
    drop assert_eq_i64(cr8, 0i64, "T08 can_resolve invalid=0\0");

    string:ro9 = raw Dns.resolve_or("localhost", "0.0.0.0");
    drop assert_eq_str(ro9, "127.0.0.1", "T09 resolve_or valid\0");

    string:ro10 = raw Dns.resolve_or("this.host.does.not.exist.invalid", "0.0.0.0");
    drop assert_eq_str(ro10, "0.0.0.0", "T10 resolve_or fallback\0");

    string:rev11 = raw Dns.reverse("127.0.0.1");
    int64:t11 = 0i64;
    if (rev11 != "") { t11 = 1i64; }
    drop assert_eq_i64(t11, 1i64, "T11 reverse non-empty\0");

    int64:v12a = raw Dns.is_ipv4("0.0.0.0");
    int64:v12b = raw Dns.is_ipv4("255.255.255.255");
    int64:t12 = 0i64;
    if (v12a == 1i64) {
        if (v12b == 1i64) { t12 = 1i64; }
    }
    drop assert_eq_i64(t12, 1i64, "T12 is_ipv4 edge\0");

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
