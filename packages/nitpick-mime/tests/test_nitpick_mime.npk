// test_nitpick_mime.npk — 12-test suite for nitpick-mime (v0.11.2)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_mime.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    
    

    // T01: from_extension .html
    string:t1 = raw Mime.from_extension(".html");
    if (t1 == "text/html") { println("[PASS] T01 from_extension(.html)");  }
    if (t1 != "text/html") { println("[FAIL] T01"); }

    // T02: from_extension .png
    string:t2 = raw Mime.from_extension(".png");
    if (t2 == "image/png") { println("[PASS] T02 from_extension(.png)");  }
    if (t2 != "image/png") { println("[FAIL] T02"); }

    // T03: from_extension .mp3
    string:t3 = raw Mime.from_extension(".mp3");
    if (t3 == "audio/mpeg") { println("[PASS] T03 from_extension(.mp3)");  }
    if (t3 != "audio/mpeg") { println("[FAIL] T03"); }

    // T04: from_extension unknown
    string:t4 = raw Mime.from_extension(".xyz");
    if (t4 == "application/octet-stream") { println("[PASS] T04 unknown ext");  }
    if (t4 != "application/octet-stream") { println("[FAIL] T04"); }

    // T05: from_filename
    string:t5 = raw Mime.from_filename("photo.png");
    if (t5 == "image/png") { println("[PASS] T05 from_filename");  }
    if (t5 != "image/png") { println("[FAIL] T05"); }

    // T06: from_filename no extension
    string:t6 = raw Mime.from_filename("README");
    if (t6 == "application/octet-stream") { println("[PASS] T06 no extension");  }
    if (t6 != "application/octet-stream") { println("[FAIL] T06"); }

    // T07: to_extension reverse
    string:t7 = raw Mime.to_extension("application/json");
    if (t7 == ".json") { println("[PASS] T07 to_extension");  }
    if (t7 != ".json") { println("[FAIL] T07"); }

    // T08: to_extension unknown
    string:t8 = raw Mime.to_extension("application/unknown");
    if (t8 == "") { println("[PASS] T08 to_ext unknown");  }
    if (t8 != "") { println("[FAIL] T08"); }

    // T09: is_text text/css
    int32:t9 = raw Mime.is_text("text/css");
    if (t9 == 1i32) { println("[PASS] T09 is_text(css)");  }
    if (t9 != 1i32) { println("[FAIL] T09"); }

    // T10: is_text application/json
    int32:t10 = raw Mime.is_text("application/json");
    if (t10 == 1i32) { println("[PASS] T10 is_text(json)");  }
    if (t10 != 1i32) { println("[FAIL] T10"); }

    // T11: is_text image/png
    int32:t11 = raw Mime.is_text("image/png");
    if (t11 == 0i32) { println("[PASS] T11 not text");  }
    if (t11 != 0i32) { println("[FAIL] T11"); }

    // T12: count
    int32:t12 = raw Mime.count();
    if (t12 == 72i32) { println("[PASS] T12 count==72");  }
    if (t12 != 72i32) { println("[FAIL] T12"); }

    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
