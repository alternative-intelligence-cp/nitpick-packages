[project]
name = "nitpick-doom"
version = "0.1.0"

[target.nitpick-doom]
type = "binary"
sources = ["src/main.npk"]
deps = []
flags = [
    "-I", "../nitpick-raylib/src",
    "-I", "../nitpick-str/src",
    "-I", "../nitpick-rand/src",
    "-I", "../nitpick-math/src",
    "-I", "../nitpick-conv/src",
    "-L.", "-ldoom_shim", "-lnitpick_raylib_shim",
    "-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_io", "-lnitpick_libc_math",
    "-lraylib", "-lm", "-latomic"
]
