use "state.npk".*;
use "engine.npk".*;

func:assert_eq_i64 = int32(int64:a, int64:b) {
    if (a != b) {
        print("ASSERTION FAILED (i64)!\n\0");
        pass 1i32;
    }
    pass 0i32;
};

func:failsafe = int32(tbb32:err) {
    print("FATAL ERROR!\n\0");
    exit 1i32;
};

func:main = int32() {
    int32:errors = 0i32;
    print("Testing ADarkRoom Engine...\n\0");

    GameState:s = raw init_state();
    errors = errors + raw assert_eq_i64(s.wood, 0i64);
    errors = errors + raw assert_eq_i64(s.fire_level, 0i64);

    // Test fire degradation
    s.fire_level = 4i64;
    s.fire_timer = 0i64;
    
    // tick 15 times, should not degrade
    int64:i = 0i64;
    while (i < 15i64) {
        s = raw engine_tick(s);
        i = i + 1i64;
    }
    errors = errors + raw assert_eq_i64(s.fire_level, 4i64);
    
    // tick 1 more time, should degrade to 3
    s = raw engine_tick(s);
    errors = errors + raw assert_eq_i64(s.fire_level, 3i64);
    errors = errors + raw assert_eq_i64(s.room_temp, 3i64); // hot
    
    // tick 16 more times, degrade to 2
    i = 0i64;
    while (i < 16i64) { s = raw engine_tick(s); i = i + 1i64; }
    errors = errors + raw assert_eq_i64(s.fire_level, 2i64);
    errors = errors + raw assert_eq_i64(s.room_temp, 2i64); // warm

    // tick 16 more times, degrade to 1
    i = 0i64;
    while (i < 16i64) { s = raw engine_tick(s); i = i + 1i64; }
    errors = errors + raw assert_eq_i64(s.fire_level, 1i64);
    errors = errors + raw assert_eq_i64(s.room_temp, 1i64); // cold

    // tick 16 more times, degrade to 0
    i = 0i64;
    while (i < 16i64) { s = raw engine_tick(s); i = i + 1i64; }
    errors = errors + raw assert_eq_i64(s.fire_level, 0i64);
    errors = errors + raw assert_eq_i64(s.room_temp, 0i64); // freezing

    // tick 16 more times, should stay 0
    i = 0i64;
    while (i < 16i64) { s = raw engine_tick(s); i = i + 1i64; }
    errors = errors + raw assert_eq_i64(s.fire_level, 0i64);
    
    // Test logging
    GameLog:l = raw init_log();
    l = raw push_log(l, "Msg1\0");
    l = raw push_log(l, "Msg2\0");
    
    if (errors > 0i32) {
        print("Tests failed!\n\0");
        exit 1i32;
    }
    print("Tests passed successfully!\n\0");
    exit 0i32;
};
