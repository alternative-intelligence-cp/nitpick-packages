[project]
name = "nitpick-jwt"
version = "0.1.0"

[target.nitpick-jwt]
type = "library"
sources = ["src/nitpick_jwt.npk"]
deps = []
flags = ["-L.", "-lnitpick_jwt_shim"]

[target.test-nitpick-jwt]
type = "binary"
sources = ["tests/test_nitpick_jwt.npk"]
deps = []
flags = ["-I", "src", "-L.", "-lnitpick_jwt_shim", "-L../nitpick-crypto", "-lnitpick_crypto_shim", "-L../nitpick-base64", "-lnitpick_base64_shim", "-L../nitpick-json", "-lnitpick_json_shim", "-lssl", "-lcrypto"]
