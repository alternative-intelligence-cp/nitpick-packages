// test_nitpick_sort.npk — 12-test suite for nitpick-sort (v0.11.1)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_sort.npk".*;
extern "libc" { func:malloc = int64(int64:size); func:free = void(int64:ptr); }

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq_i64 = int64(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:main = int32() {
    // Build array: [5, 3, 8, 1, 9, 2, 7, 4, 6, 10]
    int64:arr = malloc(80i64);
    nitpick_libc_mem_write_i64(arr, 0i64,  5i64);
    nitpick_libc_mem_write_i64(arr, 8i64,  3i64);
    nitpick_libc_mem_write_i64(arr, 16i64, 8i64);
    nitpick_libc_mem_write_i64(arr, 24i64, 1i64);
    nitpick_libc_mem_write_i64(arr, 32i64, 9i64);
    nitpick_libc_mem_write_i64(arr, 40i64, 2i64);
    nitpick_libc_mem_write_i64(arr, 48i64, 7i64);
    nitpick_libc_mem_write_i64(arr, 56i64, 4i64);
    nitpick_libc_mem_write_i64(arr, 64i64, 6i64);
    nitpick_libc_mem_write_i64(arr, 72i64, 10i64);

    // T01: not sorted initially
    int32:s1 = raw Sort.is_sorted(arr, 10i64);
    drop assert_eq_i64(s1, 0i32, "T01 unsorted\0");

    // T02: quicksort
    drop Sort.quicksort(arr, 10i64);
    int32:s2 = raw Sort.is_sorted(arr, 10i64);
    drop assert_eq_i64(s2, 1i32, "T02 quicksort\0");

    // T03: first element after sort
    int64:v0 = nitpick_libc_mem_read_i64(arr, 0i64);
    drop assert_eq_i64(v0, 1i64, "T03 first=1\0");

    // T04: last element after sort
    int64:v9 = nitpick_libc_mem_read_i64(arr, 72i64);
    drop assert_eq_i64(v9, 10i64, "T04 last=10\0");

    // T05: min
    int64:mn = raw Sort.min(arr, 10i64);
    drop assert_eq_i64(mn, 1i64, "T05 min\0");

    // T06: max
    int64:mx = raw Sort.max(arr, 10i64);
    drop assert_eq_i64(mx, 10i64, "T06 max\0");

    // T07: sum
    int64:sm = raw Sort.sum(arr, 10i64);
    drop assert_eq_i64(sm, 55i64, "T07 sum=55\0");

    // T08: binary_search found
    int64:idx = raw Sort.binary_search(arr, 10i64, 7i64);
    drop assert_eq_i64(idx, 6i64, "T08 bsearch found\0");

    // T09: binary_search not found
    int64:idx2 = raw Sort.binary_search(arr, 10i64, 42i64);
    drop assert_eq_i64(idx2, 0i64 - 1i64, "T09 bsearch miss\0");

    // T10: reverse
    drop Sort.reverse(arr, 10i64);
    int64:first = nitpick_libc_mem_read_i64(arr, 0i64);
    int64:last = nitpick_libc_mem_read_i64(arr, 72i64);
    drop assert_eq_i64(first, 10i64, "T10 reverse first\0");

    // T11: reverse last
    drop assert_eq_i64(last, 1i64, "T11 reverse last\0");

    // T12: insertion_sort
    drop Sort.reverse(arr, 10i64);
    nitpick_libc_mem_write_i64(arr, 0i64, 99i64);
    drop Sort.insertion_sort(arr, 10i64);
    int32:s12 = raw Sort.is_sorted(arr, 10i64);
    drop assert_eq_i64(s12, 1i32, "T12 insertion_sort\0");

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
