// test_nitpick_sqlite.nitpick — Comprehensive SQLite tests
//
// 27 tests: open/close, CRUD, parameterized queries, transactions,
//           column accessors, error handling, SQL injection safety
//
// Workarounds for known compiler bugs:
//   - Variables consumed on use: last_db()/last_stmt() for fresh handles
//   - "close" in function names: renamed to "disconnect"
//   - String returns corrupt: column assertions done in C helpers


int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};


use "../src/nitpick_sqlite.npk".*;
extern "raw Sqlite.shim" {
    func:raw Sqlite.open       = int32(string:path);
    func:raw Sqlite.disconnect = int32(int32:db_id);
    func:raw Sqlite.exec       = int32(int32:db_id, string:sql);
    func:raw Sqlite.prepare    = int32(int32:db_id, string:sql);
    func:raw Sqlite.end_stmt   = int32(int32:stmt_id);
    func:raw Sqlite.reset      = int32(int32:stmt_id);
    func:raw Sqlite.bind_int    = int32(int32:stmt_id, int32:idx, int64:val);
}

extern "raw Sqlite.shim" {
    func:raw Sqlite.bind_double = int32(int32:stmt_id, int32:idx, float64:val);
    func:raw Sqlite.bind_text   = int32(int32:stmt_id, int32:idx, string:val);
    func:raw Sqlite.bind_null   = int32(int32:stmt_id, int32:idx);
    func:raw Sqlite.step           = int32(int32:stmt_id);
    func:raw Sqlite.column_count   = int32();
    func:raw Sqlite.column_is_null = int32(int32:col);
    func:raw Sqlite.begin    = int32(int32:db_id);
}

extern "raw Sqlite.shim" {
    func:raw Sqlite.commit   = int32(int32:db_id);
    func:raw Sqlite.rollback = int32(int32:db_id);
    func:raw Sqlite.last_insert_id = int64(int32:db_id);
    func:raw Sqlite.changes        = int32(int32:db_id);
    func:raw Sqlite.db   = int32();
    func:raw Sqlite.stmt = int32();
    func:nitpick_sqlite_assert_int_eq      = void(int32:actual, int32:expected, string:msg);
}

extern "raw Sqlite.shim" {
    func:nitpick_sqlite_assert_int64_eq    = void(int64:actual, int64:expected, string:msg);
    func:nitpick_sqlite_assert_true        = void(bool:val, string:msg);
    func:nitpick_sqlite_assert_col_text_eq = void(int32:col, string:expected, string:msg);
    func:nitpick_sqlite_assert_col_int_eq  = void(int32:col, int64:expected, string:msg);
    func:nitpick_sqlite_assert_col_is_null = void(int32:col, string:msg);
    func:nitpick_sqlite_assert_version_ok  = void(string:msg);
    func:nitpick_sqlite_test_summary       = void();
}

// ── Phase 1: version + open + basic CRUD (T01-T06) ─────────────────
func:test_phase1 = int32() {
    nitpick_sqlite_assert_version_ok("T01 sqlite3 version available");

    int32:db = raw Sqlite.db();
    nitpick_sqlite_assert_true(db >= 0i32, "T02 open :memory: database");

    int32:d1 = raw Sqlite.db();
    int32:r3 = raw Sqlite.exec(d1, "CREATE TABLE users(id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT NOT NULL, email TEXT, age INTEGER)");
    nitpick_sqlite_assert_int_eq(r3, 1i32, "T03 CREATE TABLE users");

    int32:d2 = raw Sqlite.db();
    int32:r4 = raw Sqlite.exec(d2, "INSERT INTO users(name, email, age) VALUES('Alice', 'alice@test.com', 30)");
    nitpick_sqlite_assert_int_eq(r4, 1i32, "T04 INSERT with exec");

    int32:d3 = raw Sqlite.db();
    int64:id1 = raw Sqlite.last_insert_id(d3);
    nitpick_sqlite_assert_int64_eq(id1, 1i64, "T05 last_insert_id == 1");

    int32:d4 = raw Sqlite.db();
    int32:ch = raw Sqlite.changes(d4);
    nitpick_sqlite_assert_int_eq(ch, 1i32, "T06 changes == 1 after insert");

    pass(0i32);
};

// ── Phase 2: parameterized insert (T07-T13) ────────────────────────
func:test_phase2 = int32() {
    int32:d1 = raw Sqlite.db();
    int32:ins = raw Sqlite.prepare(d1, "INSERT INTO users(name, email, age) VALUES(?1, ?2, ?3)");
    nitpick_sqlite_assert_true(ins >= 0i32, "T07 prepare INSERT stmt");

    int32:s1 = raw Sqlite.stmt();
    int32:b1 = raw Sqlite.bind_text(s1, 1i32, "Bob");
    nitpick_sqlite_assert_int_eq(b1, 1i32, "T08 bind_text name");

    int32:s2 = raw Sqlite.stmt();
    int32:b2 = raw Sqlite.bind_text(s2, 2i32, "bob@test.com");
    nitpick_sqlite_assert_int_eq(b2, 1i32, "T09 bind_text email");

    int32:s3 = raw Sqlite.stmt();
    int32:b3 = raw Sqlite.bind_int(s3, 3i32, 25i64);
    nitpick_sqlite_assert_int_eq(b3, 1i32, "T10 bind_int age");

    int32:s4 = raw Sqlite.stmt();
    int32:step1 = raw Sqlite.step(s4);
    nitpick_sqlite_assert_int_eq(step1, 0i32, "T11 step insert (0 = done)");

    int32:d2 = raw Sqlite.db();
    int64:id2 = raw Sqlite.last_insert_id(d2);
    nitpick_sqlite_assert_int64_eq(id2, 2i64, "T12 last_insert_id == 2");

    int32:s5 = raw Sqlite.stmt();
    int32:rr = raw Sqlite.reset(s5);
    nitpick_sqlite_assert_int_eq(rr, 1i32, "T13 reset statement");

    pass(0i32);
};

// ── Phase 2b: reuse stmt for Charlie + finalize ─────────────────────
func:test_phase2b = int32() {
    int32:s1 = raw Sqlite.stmt();
    drop(raw Sqlite.bind_text(s1, 1i32, "Charlie"));

    int32:s2 = raw Sqlite.stmt();
    drop(raw Sqlite.bind_text(s2, 2i32, "charlie@test.com"));

    int32:s3 = raw Sqlite.stmt();
    drop(raw Sqlite.bind_int(s3, 3i32, 35i64));

    int32:s4 = raw Sqlite.stmt();
    int32:step2 = raw Sqlite.step(s4);
    nitpick_sqlite_assert_int_eq(step2, 0i32, "T13b reuse stmt for Charlie");

    int32:s5 = raw Sqlite.stmt();
    drop(raw Sqlite.end_stmt(s5));

    pass(0i32);
};

// ── Phase 3a: SELECT first row (T14-T18) ────────────────────────────
func:test_phase3a = int32() {
    int32:d1 = raw Sqlite.db();
    int32:sel = raw Sqlite.prepare(d1, "SELECT id, name, email, age FROM users ORDER BY id");
    nitpick_sqlite_assert_true(sel >= 0i32, "T14 prepare SELECT");

    int32:s1 = raw Sqlite.stmt();
    int32:row1 = raw Sqlite.step(s1);
    nitpick_sqlite_assert_int_eq(row1, 1i32, "T15 step returns row");

    int32:cc = raw Sqlite.column_count();
    nitpick_sqlite_assert_int_eq(cc, 4i32, "T16 column_count == 4");

    nitpick_sqlite_assert_col_text_eq(1i32, "Alice", "T17 row 1 name == Alice");

    nitpick_sqlite_assert_col_int_eq(3i32, 30i64, "T18 row 1 age == 30");

    pass(0i32);
};

// ── Phase 3b: remaining rows (T19-T21) ──────────────────────────────
func:test_phase3b = int32() {
    int32:s1 = raw Sqlite.stmt();
    int32:row2 = raw Sqlite.step(s1);
    nitpick_sqlite_assert_int_eq(row2, 1i32, "T19 second row exists");
    nitpick_sqlite_assert_col_text_eq(1i32, "Bob", "T19b row 2 name == Bob");

    int32:s2 = raw Sqlite.stmt();
    int32:row3 = raw Sqlite.step(s2);
    nitpick_sqlite_assert_int_eq(row3, 1i32, "T20 third row exists");
    nitpick_sqlite_assert_col_text_eq(1i32, "Charlie", "T20b row 3 name == Charlie");

    int32:s3 = raw Sqlite.stmt();
    int32:row4 = raw Sqlite.step(s3);
    nitpick_sqlite_assert_int_eq(row4, 0i32, "T21 no more rows (done)");

    int32:s4 = raw Sqlite.stmt();
    drop(raw Sqlite.end_stmt(s4));

    pass(0i32);
};

// ── Phase 4a: transaction rollback (T22) ────────────────────────────
func:test_phase4a = int32() {
    int32:d1 = raw Sqlite.db();
    int32:tb = raw Sqlite.begin(d1);
    nitpick_sqlite_assert_int_eq(tb, 1i32, "T22 begin transaction");

    int32:d2 = raw Sqlite.db();
    drop(raw Sqlite.exec(d2, "INSERT INTO users(name, email, age) VALUES('DeleteMe', 'del@test.com', 99)"));

    int32:d3 = raw Sqlite.db();
    int32:tr = raw Sqlite.rollback(d3);
    nitpick_sqlite_assert_int_eq(tr, 1i32, "T22b rollback transaction");

    int32:d4 = raw Sqlite.db();
    drop(raw Sqlite.prepare(d4, "SELECT COUNT(*) FROM users WHERE name = 'DeleteMe'"));
    int32:s1 = raw Sqlite.stmt();
    drop(raw Sqlite.step(s1));
    nitpick_sqlite_assert_col_int_eq(0i32, 0i64, "T22c rollback removed insert");
    int32:s2 = raw Sqlite.stmt();
    drop(raw Sqlite.end_stmt(s2));

    pass(0i32);
};

// ── Phase 4b: transaction commit (T23) ──────────────────────────────
func:test_phase4b = int32() {
    int32:d1 = raw Sqlite.db();
    drop(raw Sqlite.begin(d1));

    int32:d2 = raw Sqlite.db();
    drop(raw Sqlite.exec(d2, "INSERT INTO users(name, email, age) VALUES('Dave', 'dave@test.com', 40)"));

    int32:d3 = raw Sqlite.db();
    int32:tc = raw Sqlite.commit(d3);
    nitpick_sqlite_assert_int_eq(tc, 1i32, "T23 commit transaction");

    int32:d4 = raw Sqlite.db();
    drop(raw Sqlite.prepare(d4, "SELECT COUNT(*) FROM users WHERE name = 'Dave'"));
    int32:s1 = raw Sqlite.stmt();
    drop(raw Sqlite.step(s1));
    nitpick_sqlite_assert_col_int_eq(0i32, 1i64, "T23b commit persisted insert");
    int32:s2 = raw Sqlite.stmt();
    drop(raw Sqlite.end_stmt(s2));

    pass(0i32);
};

// ── Phase 5a: SQL injection safety (T24) ────────────────────────────
func:test_phase5a = int32() {
    int32:d1 = raw Sqlite.db();
    drop(raw Sqlite.prepare(d1, "SELECT COUNT(*) FROM users WHERE name = ?1"));

    int32:s1 = raw Sqlite.stmt();
    drop(raw Sqlite.bind_text(s1, 1i32, "'; DROP TABLE users; --"));

    int32:s2 = raw Sqlite.stmt();
    drop(raw Sqlite.step(s2));
    nitpick_sqlite_assert_col_int_eq(0i32, 0i64, "T24 injection string finds 0 rows");
    int32:s3 = raw Sqlite.stmt();
    drop(raw Sqlite.end_stmt(s3));

    int32:d2 = raw Sqlite.db();
    drop(raw Sqlite.prepare(d2, "SELECT COUNT(*) FROM users"));
    int32:s4 = raw Sqlite.stmt();
    drop(raw Sqlite.step(s4));
    nitpick_sqlite_assert_col_int_eq(0i32, 4i64, "T24b table survived injection (4 rows)");
    int32:s5 = raw Sqlite.stmt();
    drop(raw Sqlite.end_stmt(s5));

    pass(0i32);
};

// ── Phase 5b: null binding (T25) ────────────────────────────────────
func:test_phase5b = int32() {
    int32:d1 = raw Sqlite.db();
    drop(raw Sqlite.prepare(d1, "INSERT INTO users(name, email, age) VALUES(?1, ?2, ?3)"));

    int32:s1 = raw Sqlite.stmt();
    drop(raw Sqlite.bind_text(s1, 1i32, "Eve"));

    int32:s2 = raw Sqlite.stmt();
    drop(raw Sqlite.bind_null(s2, 2i32));

    int32:s3 = raw Sqlite.stmt();
    drop(raw Sqlite.bind_int(s3, 3i32, 28i64));

    int32:s4 = raw Sqlite.stmt();
    drop(raw Sqlite.step(s4));
    int32:s5 = raw Sqlite.stmt();
    drop(raw Sqlite.end_stmt(s5));

    int32:d2 = raw Sqlite.db();
    drop(raw Sqlite.prepare(d2, "SELECT email FROM users WHERE name = 'Eve'"));
    int32:s6 = raw Sqlite.stmt();
    drop(raw Sqlite.step(s6));
    nitpick_sqlite_assert_col_is_null(0i32, "T25 NULL email is_null == 1");
    int32:s7 = raw Sqlite.stmt();
    drop(raw Sqlite.end_stmt(s7));

    pass(0i32);
};

// ── Phase 5c: error handling + close (T26-T27) ─────────────────────
func:test_phase5c = int32() {
    int32:d1 = raw Sqlite.db();
    int32:bad = raw Sqlite.exec(d1, "THIS IS NOT VALID SQL");
    nitpick_sqlite_assert_int_eq(bad, 0i32, "T26 bad SQL returns 0 (error)");

    int32:d2 = raw Sqlite.db();
    int32:cl = raw Sqlite.disconnect(d2);
    nitpick_sqlite_assert_int_eq(cl, 1i32, "T27 close database");

    pass(0i32);
};

// ── main ────────────────────────────────────────────────────────────
func:main = int32() {
    println("nitpick-sqlite test suite");
    println("======================");

    drop(raw Sqlite.open(":memory:"));

    drop(test_phase1());
    drop(test_phase2());
    drop(test_phase2b());
    drop(test_phase3a());
    drop(test_phase3b());
    drop(test_phase4a());
    drop(test_phase4b());
    drop(test_phase5a());
    drop(test_phase5b());
    drop(test_phase5c());

    
    nitpick_sqlite_test_summary();
    if (fail_cnt > 0i64) {
        exit 1i32;
    }

    exit 0;
};
