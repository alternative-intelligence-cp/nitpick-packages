use "nitpick_gtk4.npk";
use "nitpick_str.npk";

pub func:failsafe = int32(tbb32:err) {
    exit 1i32;
};

pub func:main = int32() {
    raw gtk_init("com.nitpick.gtk4test");
    raw gtk_run();
    raw gtk_set_title("Nitpick GTK4 Advanced Test");

    // Add Grid
    int32:grid = raw gtk4_add_grid();
    
    // Scrolled window
    int32:scroll = raw gtk4_add_scrolled_window();

    // Progress bar
    int32:pbar = raw gtk4_add_progress_bar();
    raw gtk4_progress_bar_set_fraction(pbar, 0.75f32);

    // Combo Box
    int32:combo = raw gtk4_add_combo_box_text();
    raw gtk4_combo_box_text_append(combo, "item1", "Item 1");
    raw gtk4_combo_box_text_append(combo, "item2", "Item 2");
    raw gtk4_combo_box_set_active(combo, 0i32);

    // Label
    int32:lbl = raw gtk_add_label("Advanced GTK4 Widgets");

    // Layout
    raw gtk4_grid_attach(grid, lbl, 0i32, 0i32, 2i32, 1i32);
    raw gtk4_grid_attach(grid, pbar, 0i32, 1i32, 1i32, 1i32);
    raw gtk4_grid_attach(grid, combo, 1i32, 1i32, 1i32, 1i32);
    
    // Attach grid to scroll
    raw gtk4_scrolled_window_set_child(scroll, grid);

    int32:frames = 0i32;

    while (raw gtk_is_running() != 0i32) {
        if (frames > 5i32) {
            break;
        }
        raw gtk_iterate(0i32);
        frames = frames + 1i32;
    }

    raw gtk_quit();
    return 0i32;
};
