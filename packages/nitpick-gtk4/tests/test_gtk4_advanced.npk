use "../src/nitpick_gtk4.npk";

extern "std" {
    func:print = int32(string:s);
}

pub func:failsafe = int32(tbb32:err) {
    exit 1i32;
};

pub func:main = int32() {
    _ = raw gtk4_init("org.nitpick.test.gtk4");
    
    _ = print("Before gtk4_run\n");
    // We must call run to register the app and create the window
    _ = raw gtk4_run();
    _ = print("After gtk4_run\n");

    // Box
    int32:main_box = raw gtk4_add_box(raw GTK_ORIENTATION_VERTICAL(), 5i32);
    
    // Switch
    int32:sw = raw gtk4_add_switch();
    _ = raw gtk4_switch_set_active(sw, 1i32);
    _ = print("Switch is active: ");
    if (raw gtk4_switch_get_active(sw) != 0i32) {
        _ = print("Yes\n");
    } else {
        _ = print("No\n");
    }

    // Scale
    int32:scale = raw gtk4_add_scale(raw GTK_ORIENTATION_HORIZONTAL(), 0.0f32, 100.0f32, 1.0f32);
    _ = raw gtk4_scale_set_value(scale, 42.5f32);
    
    // SpinButton
    int32:spin = raw gtk4_add_spin_button(0.0f32, 10.0f32, 0.5f32);
    _ = raw gtk4_spin_button_set_value(spin, 7.5f32);

    // ListBox
    int32:list = raw gtk4_add_list_box();
    int32:lb1 = raw gtk4_add_label("Item 1");
    int32:lb2 = raw gtk4_add_label("Item 2");
    _ = raw gtk4_list_box_append(list, lb1);
    _ = raw gtk4_list_box_append(list, lb2);

    // TextView
    int32:tv = raw gtk4_add_text_view();
    _ = raw gtk4_text_view_set_text(tv, "Hello multiline\ntext view!");
    
    // Add all to box
    _ = raw gtk4_box_append(main_box, sw);
    _ = raw gtk4_box_append(main_box, scale);
    _ = raw gtk4_box_append(main_box, spin);
    _ = raw gtk4_box_append(main_box, list);
    _ = raw gtk4_box_append(main_box, tv);

    _ = print("Advanced Widgets Added Successfully!\n");
    
    _ = raw gtk4_window_close();
    _ = raw gtk4_quit();
    exit 0;
};
