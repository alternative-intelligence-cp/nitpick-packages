// nitpick_ssh.npk — Native SSH-2 protocol implementation for Nitpick (v0.2.0)
//
// Pure Nitpick protocol logic + C shim for binary packet operations.
// Import with: use "nitpick_ssh.npk".*;
//
// Binary data uses opaque buffer handles (int64 pointers) with layout:
//   [cap:i64 @ 0][len:i64 @ 8][data @ 16...]
// This avoids null-byte truncation in Nitpick strings.

// ── C Shim: Buffer + Binary Packet Operations ──────────────────────────────

extern "nitpick_ssh_shim" {
    // Buffer management
    func:nitpick_ssh_buf_create       = int64(int64:cap);
    func:nitpick_ssh_buf_free         = void(int64:handle);
    func:nitpick_ssh_buf_len          = int64(int64:handle);
    func:nitpick_ssh_buf_clear        = void(int64:handle);
    func:nitpick_ssh_buf_write_byte   = int64(int64:handle, int32:val);
    func:nitpick_ssh_buf_read_byte    = int32(int64:handle, int64:pos);
    func:nitpick_ssh_buf_write_bytes  = int64(int64:handle, string:src, int32:count);
    func:nitpick_ssh_buf_write_from   = int64(int64:dst, int64:src);
    func:nitpick_ssh_buf_extract_str  = string(int64:handle, int64:offset, int64:count);
    func:nitpick_ssh_buf_equals_str   = int32(int64:handle, string:expected);

    // Wire format encoding (write to buffer, return possibly-reallocated handle)
    func:nitpick_ssh_encode_uint32      = int64(int64:handle, int64:val);
    func:nitpick_ssh_decode_uint32      = int64(int64:handle, int64:offset);
    func:nitpick_ssh_encode_string      = int64(int64:handle, string:data);
    func:nitpick_ssh_decode_string_len  = int64(int64:handle, int64:offset);
    func:nitpick_ssh_decode_string_data = string(int64:handle, int64:offset);
    func:nitpick_ssh_encode_byte        = int64(int64:handle, int32:val);
    func:nitpick_ssh_encode_bool        = int64(int64:handle, int32:val);
    func:nitpick_ssh_encode_name_list   = int64(int64:handle, string:csv);

    // Packet operations
    func:nitpick_ssh_packet_pad_length  = int32(int64:payload_len, int64:block_size);
    func:nitpick_ssh_packet_encode      = int64(int64:payload_handle);
    func:nitpick_ssh_packet_decode      = int64(int64:raw_handle);

    // mpint (RFC 4251 §5) — big integer wire format
    func:nitpick_ssh_encode_mpint       = int64(int64:dst, int64:src_buf);
    func:nitpick_ssh_decode_mpint       = int64(int64:handle, int64:offset);
    func:nitpick_ssh_mpint_size         = int64(int64:handle, int64:offset);

    // Binary buffer operations
    func:nitpick_ssh_buf_write_buf_as_string = int64(int64:dst, int64:src);
    func:nitpick_ssh_buf_compare        = int32(int64:a, int64:b);
    func:nitpick_ssh_buf_clone          = int64(int64:handle);
    func:nitpick_ssh_buf_extract_range  = int64(int64:handle, int64:offset, int64:count);

    // Type conversion (int64 <-> decimal string)
    func:nitpick_ssh_int64_to_str       = string(int64:val);
    func:nitpick_ssh_str_to_int64       = int64(string:s);
}

extern "libc" { func:string_length = int64(string:s); }

// ── C Shim: Cryptographic Primitives ────────────────────────────────────────

extern "nitpick_ssh_crypto_shim" {
    // CSPRNG
    func:ssh_crypto_random_fill     = int64(int64:handle, int32:count);
    func:ssh_crypto_random_uint32   = int64();

    // AES-CTR mode
    func:ssh_crypto_aes_ctr_create  = int64(int64:key_buf, int64:iv_buf);
    func:ssh_crypto_aes_ctr_process = int64(int64:state, int64:in_buf);
    func:ssh_crypto_aes_ctr_free    = void(int64:state);

    // SHA-256 / HMAC-SHA256 (raw 32-byte output buffers)
    func:ssh_crypto_sha256_raw      = int64(int64:in_buf);
    func:ssh_crypto_hmac_sha256_raw = int64(int64:key_buf, int64:data_buf);

    // Diffie-Hellman Group 14
    func:ssh_crypto_dh_generate     = int64(int32:group);
    func:ssh_crypto_dh_public_key   = int64(int64:dh_handle);
    func:ssh_crypto_dh_shared_secret = int64(int64:dh_handle, int64:peer_pub_buf);
    func:ssh_crypto_dh_free         = void(int64:dh_handle);

    // Public key / signature verification
    func:ssh_crypto_rsa_verify        = int64(int64:pubkey_buf, int64:sig_buf, int64:hash_buf);
    func:ssh_crypto_ed25519_verify    = int64(int64:pubkey_buf, int64:sig_buf, int64:msg_buf);
    func:ssh_crypto_key_type          = string(int64:pubkey_buf);
    func:ssh_crypto_extract_sig_blob  = int64(int64:sig_buf);
    func:ssh_crypto_base64_decode     = int64(string:input);

    // Phase 0.8.2 — Signing + Private Key Parsing
    func:ssh_crypto_rsa_sign          = int64(int64:privkey_handle, int64:data_buf);
    func:ssh_crypto_ed25519_sign      = int64(int64:privkey_handle, int64:data_buf);
    func:ssh_crypto_parse_pem_privkey = int64(string:pem_text);
    func:ssh_crypto_privkey_type      = string(int64:privkey_handle);
    func:ssh_crypto_privkey_free      = void(int64:privkey_handle);

    // Known hosts management
    func:ssh_crypto_known_hosts_load  = int64(string:path);
    func:ssh_crypto_known_hosts_check = int64(int64:kh_buf, string:host, string:key_type, int64:key_blob);
    func:ssh_crypto_known_hosts_add   = int64(string:path, string:host, string:key_type, string:key_b64);
}

// ── C Shim: Network I/O ─────────────────────────────────────────────────────

extern "nitpick_ssh_shim" {
    func:nitpick_ssh_net_connect      = int64(string:host, int64:port);
    func:nitpick_ssh_net_close        = void(int64:fd);
    func:nitpick_ssh_net_send_buf     = int64(int64:fd, int64:buf_handle);
    func:nitpick_ssh_net_send_str     = int64(int64:fd, string:str);
    func:nitpick_ssh_net_recv_exact   = int64(int64:fd, int64:count);
    func:nitpick_ssh_net_recv_line    = string(int64:fd);
    func:nitpick_ssh_net_set_timeout  = int64(int64:fd, int64:seconds);

    // Security hardening (Phase 1.0.0)
    func:nitpick_ssh_buf_compare_ct   = int32(int64:a, int64:b);
    func:nitpick_ssh_buf_secure_wipe  = void(int64:handle);
    func:nitpick_ssh_packet_size_valid = int32(int64:packet_len);
    func:nitpick_ssh_seq_next         = int64(int64:seq);
}

// ── Constants: SSH message types (RFC 4253 §12) ─────────────────────────────

func:SSH_MSG_DISCONNECT         = int32() { pass 1i32; };
func:SSH_MSG_IGNORE             = int32() { pass 2i32; };
func:SSH_MSG_UNIMPLEMENTED      = int32() { pass 3i32; };
func:SSH_MSG_DEBUG              = int32() { pass 4i32; };
func:SSH_MSG_SERVICE_REQUEST    = int32() { pass 5i32; };
func:SSH_MSG_SERVICE_ACCEPT     = int32() { pass 6i32; };
func:SSH_MSG_KEXINIT            = int32() { pass 20i32; };
func:SSH_MSG_NEWKEYS            = int32() { pass 21i32; };
func:SSH_MSG_KEXDH_INIT         = int32() { pass 30i32; };
func:SSH_MSG_KEXDH_REPLY        = int32() { pass 31i32; };

// SSH auth message types (RFC 4252)
func:SSH_MSG_USERAUTH_REQUEST   = int32() { pass 50i32; };
func:SSH_MSG_USERAUTH_FAILURE   = int32() { pass 51i32; };
func:SSH_MSG_USERAUTH_SUCCESS   = int32() { pass 52i32; };
func:SSH_MSG_USERAUTH_BANNER    = int32() { pass 53i32; };

// SSH channel message types (RFC 4254)
func:SSH_MSG_CHANNEL_OPEN            = int32() { pass 90i32; };
func:SSH_MSG_CHANNEL_OPEN_CONFIRM    = int32() { pass 91i32; };
func:SSH_MSG_CHANNEL_WINDOW_ADJUST   = int32() { pass 93i32; };
func:SSH_MSG_CHANNEL_DATA            = int32() { pass 94i32; };
func:SSH_MSG_CHANNEL_EOF             = int32() { pass 96i32; };
func:SSH_MSG_CHANNEL_CLOSE           = int32() { pass 97i32; };
func:SSH_MSG_CHANNEL_REQUEST         = int32() { pass 98i32; };
func:SSH_MSG_CHANNEL_SUCCESS         = int32() { pass 99i32; };
func:SSH_MSG_CHANNEL_FAILURE         = int32() { pass 100i32; };

