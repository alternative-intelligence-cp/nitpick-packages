// ── Session Management ──────────────────────────────────────────────────────

func:ssh_session_create = int64() {
    int64:h = ahash(256);
    ahset(h, "_state", "created");
    ahset(h, "_host", "");
    ahset(h, "_port", "22");
    ahset(h, "_version_remote", "");
    ahset(h, "_version_software", "");
    ahset(h, "_error", "");
    ahset(h, "_compression", "none");
    pass h;
};

func:ssh_session_error = string(int64:h) {
    string:v = ahget(h, "_error");
    pass v;
};

func:ssh_session_state = string(int64:h) {
    string:v = ahget(h, "_state");
    pass v;
};

func:ssh_session_set_state = NIL(int64:h, string:new_state) {
    ahset(h, "_state", new_state);
    pass(NIL);
};

func:ssh_session_set_error = NIL(int64:h, string:msg) {
    ahset(h, "_error", msg);
    ahset(h, "_state", "error");
    pass(NIL);
};

func:ssh_session_transition = int32(int64:h, string:expected_from, string:to_state) {
    string:current = ahget(h, "_state");
    int32:matched = 0i32;
    if (string_contains(current, expected_from)) { matched = 1i32; }
    if (matched == 0i32) { pass 0i32; }
    ahset(h, "_state", to_state);
    pass 1i32;
};

func:ssh_session_version_remote = string(int64:h) {
    string:v = ahget(h, "_version_remote");
    pass v;
};

func:ssh_session_version_software = string(int64:h) {
    string:v = ahget(h, "_version_software");
    pass v;
};

