// Encode payload buffer into a framed SSH packet buffer. Returns new buffer handle.
func:ssh_packet_encode = int64(int64:payload_handle) {
    pass nitpick_ssh_packet_encode(payload_handle);
};

// Decode raw packet buffer, extract payload. Returns payload buffer handle (0 on error).
func:ssh_packet_decode = int64(int64:raw_handle) {
    pass nitpick_ssh_packet_decode(raw_handle);
