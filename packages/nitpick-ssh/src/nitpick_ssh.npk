func:ssh_version_string = string() {
    pass "SSH-2.0-NitpickSSH_1.0";
};

// ── Buffer Management (pub wrappers) ────────────────────────────────────────

func:ssh_buf_create = int64(int64:cap) {
    pass nitpick_ssh_buf_create(cap);
};

func:ssh_buf_free = NIL(int64:handle) {
    nitpick_ssh_buf_free(handle);
    pass(NIL);
};

func:ssh_buf_len = int64(int64:handle) {
    pass nitpick_ssh_buf_len(handle);
};

func:ssh_buf_clear = NIL(int64:handle) {
    nitpick_ssh_buf_clear(handle);
    pass(NIL);
};

func:ssh_buf_write_byte = int64(int64:handle, int32:val) {
    pass nitpick_ssh_buf_write_byte(handle, val);
};

func:ssh_buf_read_byte = int32(int64:handle, int64:pos) {
    pass nitpick_ssh_buf_read_byte(handle, pos);
};

func:ssh_buf_write_str = int64(int64:handle, string:src) {
    int64:slen = string_length(src);
    pass nitpick_ssh_buf_write_bytes(handle, src, @cast_unchecked<int32>(slen));
};

func:ssh_buf_write_from = int64(int64:dst, int64:src) {
    pass nitpick_ssh_buf_write_from(dst, src);
};

func:ssh_buf_extract_str = string(int64:handle, int64:offset, int64:count) {
    pass nitpick_ssh_buf_extract_str(handle, offset, count);
};

func:ssh_buf_equals_str = int32(int64:handle, string:expected) {
    pass nitpick_ssh_buf_equals_str(handle, expected);
};

