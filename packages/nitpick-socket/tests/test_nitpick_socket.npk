// test_nitpick_socket.npk — UDP loopback tests (C-side assertions)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_socket.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq_i64 = int64(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:assert_eq_str = int64(string:actual, string:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:main = int32() {
    // Basic test
    int32:udp = raw Socket.udp_create();
    int64:t1 = 0i64;
    if (udp >= 0i32) { t1 = 1i64; }
    drop assert_eq_i64(t1, 1i64, "T01 UDP create\0");
    if (udp >= 0i32) {
        drop raw Socket.close(udp);
    }

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
