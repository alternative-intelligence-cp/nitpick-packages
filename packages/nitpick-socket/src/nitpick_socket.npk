// nitpick_socket.npk — TCP/UDP socket abstractions for Nitpick

extern "nitpick_socket_shim" {
    func:nitpick_socket_error           = string();
    func:nitpick_socket_tcp_connect     = int32(string:host, int32:port);
    func:nitpick_socket_tcp_listen      = int32(string:addr, int32:port, int32:backlog);
    func:nitpick_socket_tcp_accept      = int32(int32:listen_fd);
    func:nitpick_socket_udp_create      = int32();
    func:nitpick_socket_udp_bind        = int32(int32:fd, string:addr, int32:port);
    func:nitpick_socket_udp_sendto      = int32(int32:fd, string:data, int32:len, string:host, int32:port);
    func:nitpick_socket_udp_recvfrom    = string(int32:fd);
    func:nitpick_socket_send            = int32(int32:fd, string:data, int32:len);
    func:nitpick_socket_send_str        = int32(int32:fd, string:data);
    func:nitpick_socket_recv            = string(int32:fd, int32:max);
    func:nitpick_socket_last_result     = string();
    func:nitpick_socket_recv_length     = int64();
    func:nitpick_socket_set_nonblocking = int32(int32:fd);
    func:nitpick_socket_poll_read       = int32(int32:fd, int32:timeout_ms);
    func:nitpick_socket_close           = void(int32:fd);
    func:nitpick_socket_set_timeout     = int32(int32:fd, int32:seconds);
}

// ── Type wrapper ────────────────────────────────────────

pub Type:Socket = {
    func:error           = string()                                                     { pass(nitpick_socket_error()); };
    func:tcp_connect     = int32(string:host, int32:port)                               { pass(nitpick_socket_tcp_connect(host, port)); };
    func:tcp_listen      = int32(string:addr, int32:port, int32:backlog)                 { pass(nitpick_socket_tcp_listen(addr, port, backlog)); };
    func:tcp_accept      = int32(int32:listen_fd)                                       { pass(nitpick_socket_tcp_accept(listen_fd)); };
    func:udp_create      = int32()                                                      { pass(nitpick_socket_udp_create()); };
    func:udp_bind        = int32(int32:fd, string:addr, int32:port)                      { pass(nitpick_socket_udp_bind(fd, addr, port)); };
    func:udp_sendto      = int32(int32:fd, string:data, int32:len, string:host, int32:port) { pass(nitpick_socket_udp_sendto(fd, data, len, host, port)); };
    func:udp_recvfrom    = string(int32:fd)                                             { drop(nitpick_socket_udp_recvfrom(fd)); pass(nitpick_socket_last_result()); };
    func:send            = int32(int32:fd, string:data, int32:len)                       { pass(nitpick_socket_send(fd, data, len)); };
    func:send_str        = int32(int32:fd, string:data)                                  { pass(nitpick_socket_send_str(fd, data)); };
    func:recv            = string(int32:fd, int32:max)                                   { drop(nitpick_socket_recv(fd, max)); pass(nitpick_socket_last_result()); };
    func:recv_length     = int64()                                                      { pass(nitpick_socket_recv_length()); };
    func:set_nonblocking = int32(int32:fd)                                            { pass(nitpick_socket_set_nonblocking(fd)); };
    func:poll_read       = int32(int32:fd, int32:timeout_ms)                             { pass(nitpick_socket_poll_read(fd, timeout_ms)); };
    func:close           = NIL(int32:fd)                                                 { nitpick_socket_close(fd); pass(NIL); };
    func:set_timeout     = int32(int32:fd, int32:seconds)                                { pass(nitpick_socket_set_timeout(fd, seconds)); };
};
