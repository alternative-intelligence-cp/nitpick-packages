    func:src_manual = int64() { pass raw ep_src_manual(); };
    func:create = NIL(int64:ep, int64:meta, int64:snaps,
                         float64:width, float64:coupling, float64:crystal_threshold,
                         int64:capacity) { drop raw ep_create(ep, meta, snaps, width, coupling, crystal_threshold, capacity); pass NIL; };
    func:lean_alpha_a = NIL(int64:ep, int64:meta, int64:snaps,
                                float64:amount) { drop raw ep_lean_alpha_a(ep, meta, snaps, amount); pass NIL; };
    func:lean_alpha_b = NIL(int64:ep, int64:meta, int64:snaps,
                                float64:amount) { drop raw ep_lean_alpha_b(ep, meta, snaps, amount); pass NIL; };
    func:lean_alpha_unkn = NIL(int64:ep, int64:meta, int64:snaps,
                                   float64:amount) { drop raw ep_lean_alpha_unkn(ep, meta, snaps, amount); pass NIL; };
    func:lean_beta_a = NIL(int64:ep, int64:meta, int64:snaps,
                               float64:amount) { drop raw ep_lean_beta_a(ep, meta, snaps, amount); pass NIL; };
    func:lean_beta_b = NIL(int64:ep, int64:meta, int64:snaps,
                               float64:amount) { drop raw ep_lean_beta_b(ep, meta, snaps, amount); pass NIL; };
    func:lean_beta_unkn = NIL(int64:ep, int64:meta, int64:snaps,
                                  float64:amount) { drop raw ep_lean_beta_unkn(ep, meta, snaps, amount); pass NIL; };
    func:tilt_alpha = NIL(int64:ep, int64:meta, int64:snaps,
                              float64:amount, int64:toward) { drop raw ep_tilt_alpha(ep, meta, snaps, amount, toward); pass NIL; };
    func:tilt_beta = NIL(int64:ep, int64:meta, int64:snaps,
                             float64:amount, int64:toward) { drop raw ep_tilt_beta(ep, meta, snaps, amount, toward); pass NIL; };
    func:tilt_pair = NIL(int64:ep, int64:meta, int64:snaps,
                             float64:amount, int64:toward) { drop raw ep_tilt_pair(ep, meta, snaps, amount, toward); pass NIL; };
    func:observe_alpha = NIL(int64:ep, int64:meta, int64:snaps,
                                 float64:lean, float64:tilt, int64:direction) { drop raw ep_observe_alpha(ep, meta, snaps, lean, tilt, direction); pass NIL; };
    func:observe_beta = NIL(int64:ep, int64:meta, int64:snaps,
                                float64:lean, float64:tilt, int64:direction) { drop raw ep_observe_beta(ep, meta, snaps, lean, tilt, direction); pass NIL; };
    func:snapshot_now = NIL(int64:ep, int64:meta, int64:snaps) { drop raw ep_snapshot_now(ep, meta, snaps); pass NIL; };
