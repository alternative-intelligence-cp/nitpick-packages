[project]
name = "nitpick-matrix"
version = "0.11.1"

[target.nitpick-matrix]
type = "library"
sources = ["src/nitpick_matrix.npk"]
deps = []
flags = ["-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_math"]

[target.test-nitpick-matrix]
type = "binary"
sources = ["tests/test_nitpick_matrix.npk"]
deps = []
flags = ["-I", "src", "-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_math"]
