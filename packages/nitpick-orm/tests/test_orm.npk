// test_orm.npk
use "nitpick_orm.npk".*;
use "nitpick_str.npk".*;

extern "libc" {
    func:printf = int32(string:fmt);
}

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq = int32(string:actual, string:expected, string:test_name) {
    if (string_equals(actual, expected) == false) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n  Expected: \0"));
        drop(printf(expected));
        drop(printf("\n  Actual:   \0"));
        drop(printf(actual));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i32);
};

func:main = int32() {
    drop(printf("Initializing ORM Test...\n\0"));
    
    // --- SELECT ---
    QueryBuilder:q = raw ORM.select("users");
    q = raw ORM.cols(q, "id, name, email");
    q = raw ORM.where_eq(q, "status", "active");
    q = raw ORM.where_eq(q, "role", "admin");
    q = raw ORM.order_by(q, "created_at DESC");
    q = raw ORM.set_limit(q, 10i32);
    q = raw ORM.set_offset(q, 20i32);
    
    string:select_sql = raw ORM.to_sql(q, raw ORM.POSTGRES());
    string:select_mongo = raw ORM.to_mongo(q);
    
    drop assert_eq(select_sql, "SELECT id, name, email FROM users WHERE status = 'active' AND role = 'admin' ORDER BY created_at DESC LIMIT 10 OFFSET 20;", "SELECT SQL Postgres");
    drop assert_eq(select_mongo, "{\"status\": \"active\", \"role\": \"admin\"}", "SELECT Mongo JSON");
    
    // --- INSERT ---
    QueryBuilder:q2 = raw ORM.insert("users");
    q2 = raw ORM.set(q2, "name", "John Doe");
    q2 = raw ORM.set(q2, "email", "john@example.com");
    q2 = raw ORM.set_int(q2, "age", 30i64);
    
    string:insert_sql = raw ORM.to_sql(q2, raw ORM.POSTGRES());
    string:insert_mongo = raw ORM.to_mongo(q2);
    
    drop assert_eq(insert_sql, "INSERT INTO users (name, email, age) VALUES ('John Doe', 'john@example.com', 30);", "INSERT SQL");
    drop assert_eq(insert_mongo, "{\"name\": \"John Doe\", \"email\": \"john@example.com\", \"age\": 30}", "INSERT Mongo");
    
    // --- UPDATE ---
    QueryBuilder:q3 = raw ORM.update("users");
    q3 = raw ORM.set(q3, "status", "inactive");
    q3 = raw ORM.where_eq(q3, "id", "123");
    
    string:update_sql = raw ORM.to_sql(q3, raw ORM.POSTGRES());
    string:update_mongo = raw ORM.to_mongo(q3);
    
    drop assert_eq(update_sql, "UPDATE users SET status = 'inactive' WHERE id = '123';", "UPDATE SQL");
    drop assert_eq(update_mongo, "{\"$set\": {\"status\": \"inactive\"}}", "UPDATE Mongo");
    
    drop(printf("Done!\n\0"));
    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    
    exit 0i32;
};
