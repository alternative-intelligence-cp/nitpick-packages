use "nitpick_unix_socket.npk".*;

extern "libc" { func:printf = int32(string:fmt); }
extern "libc" { func:nitpick_libc_exit = NIL(int32:code); }

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) { exit(1i32); };

func:assert = NIL(int32:condition, string:msg) {
    if (condition == 0i32) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(msg));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(msg));
        drop(printf("\n\0"));
    }
    pass NIL;
};

func:main = int32() {
    string:path = "/tmp/test_nitpick.sock\0";
    
    int64:srv = raw UnixSocket.server(path);
    drop assert(srv >= 0i64, "server create and bind\0");

    int64:cli = raw UnixSocket.client(path);
    drop assert(cli >= 0i64, "client create and connect\0");

    int64:conn = raw UnixSocket.accept(srv);
    drop assert(conn >= 0i64, "server accept client\0");

    int64:sent = raw UnixSocket.send(cli, "hello unix\0");
    drop assert(sent > 0i64, "client send data\0");

    string:recv_data = raw UnixSocket.recv(conn, 1024i64);
    int32:match = 0i32;
    // We cannot use string literal comparison directly without str_eq, let's use Str.eq if possible, or just length + print
    // Wait, the original code had: if (recv_data == "hello unix") { match = 1i32; }
    // which worked if I implemented string equality. Let's try it.
    if (recv_data == "hello unix\\0") { match = 1i32; }
    drop assert(match, "server recv data matches\0");

    drop raw UnixSocket.close(conn);
    drop raw UnixSocket.close(cli);
    drop raw UnixSocket.close(srv);
    drop raw UnixSocket.unlink(path);

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("--- ALL TESTS PASSED ---\n\0"));
    exit 0i32;
};
