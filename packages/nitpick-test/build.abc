[project]
name = "nitpick-test"
version = "0.1.0"

[target.nitpick-test]
type = "library"
sources = ["src/nitpick_test.npk"]
deps = []
flags = []

[target.test-nitpick-test]
type = "binary"
sources = ["tests/test_nitpick_test.npk"]
deps = ["nitpick-test"]
flags = ["-I", "src", "-Lshim", "-lnitpick_test_shim", "-L../../../nitpick-libc/shim", "-lnitpick_libc_string", "-lnitpick_libc_mem", "-lnitpick_libc_io"]
