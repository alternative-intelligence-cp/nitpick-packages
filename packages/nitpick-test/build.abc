[project]
name = "nitpick-test"
version = "0.1.0"

[target.nitpick-test]
type = "library"
sources = ["src/nitpick_test.npk"]
deps = []
flags = []

[target.test-nitpick-test]
type = "binary"
sources = ["tests/test_nitpick_test.npk"]
deps = ["nitpick-test"]
flags = ["-I", "src"]
link_paths = ["shim", "../../../nitpick-libc/shim"]
link_libraries = ["nitpick_test_shim", "nitpick_libc_string", "nitpick_libc_mem", "nitpick_libc_io"]
