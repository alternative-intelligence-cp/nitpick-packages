    func:aria_rl_draw_rectangle       = void(int32:x, int32:y, int32:w, int32:h,
                                             int32:r, int32:g, int32:b, int32:a);
}

extern "nitpick_raylib_shim" {
    func:aria_rl_draw_rectangle_lines = void(int32:x, int32:y, int32:w, int32:h,
                                             int32:r, int32:g, int32:b, int32:a);
    // shapes: triangle
    func:aria_rl_draw_triangle       = void(flt32:x1, flt32:y1,
                                            flt32:x2, flt32:y2,
                                            flt32:x3, flt32:y3,
                                            int32:r, int32:g, int32:b, int32:a);
}

extern "nitpick_raylib_shim" {
    func:aria_rl_draw_triangle_lines = void(flt32:x1, flt32:y1,
                                            flt32:x2, flt32:y2,
                                            flt32:x3, flt32:y3,
                                            int32:r, int32:g, int32:b, int32:a);
    // 3D
    func:aria_rl_create_camera_3d = int32(flt32:pos_x, flt32:pos_y, flt32:pos_z,
                                          flt32:tar_x, flt32:tar_y, flt32:tar_z,
}

