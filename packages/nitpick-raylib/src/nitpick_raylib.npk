    func:aria_rl_destroy_camera_3d = void(int32:handle);
    func:aria_rl_update_camera_3d = void(int32:handle, int32:mode);
    func:aria_rl_begin_mode_3d_camera = void(int32:handle);
    func:aria_rl_get_camera_3d_pos_x = flt32(int32:handle);
