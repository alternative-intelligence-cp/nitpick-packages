// ── public API: 3D ────────────────────────────────────────────────────

pub func:rl_create_camera_3d = int32(flt32:pos_x, flt32:pos_y, flt32:pos_z,
                                     flt32:tar_x, flt32:tar_y, flt32:tar_z,
                                     flt32:up_x, flt32:up_y, flt32:up_z,
                                     flt32:fovy, int32:projection) {
    int32:r = aria_rl_create_camera_3d(pos_x, pos_y, pos_z, tar_x, tar_y, tar_z, up_x, up_y, up_z, fovy, projection);
    pass(r);
};

pub func:rl_destroy_camera_3d = NIL(int32:handle) {
    aria_rl_destroy_camera_3d(handle);
    pass(NIL);
};

pub func:rl_update_camera_3d = NIL(int32:handle, int32:mode) {
    aria_rl_update_camera_3d(handle, mode);
    pass(NIL);
};

pub func:rl_begin_mode_3d_camera = NIL(int32:handle) {
    aria_rl_begin_mode_3d_camera(handle);
    pass(NIL);
};

pub func:rl_get_camera_3d_pos_x = flt32(int32:handle) { flt32:r = aria_rl_get_camera_3d_pos_x(handle); pass(r); };
pub func:rl_get_camera_3d_pos_y = flt32(int32:handle) { flt32:r = aria_rl_get_camera_3d_pos_y(handle); pass(r); };
pub func:rl_get_camera_3d_pos_z = flt32(int32:handle) { flt32:r = aria_rl_get_camera_3d_pos_z(handle); pass(r); };
pub func:rl_get_camera_3d_target_x = flt32(int32:handle) { flt32:r = aria_rl_get_camera_3d_target_x(handle); pass(r); };
pub func:rl_get_camera_3d_target_y = flt32(int32:handle) { flt32:r = aria_rl_get_camera_3d_target_y(handle); pass(r); };
pub func:rl_get_camera_3d_target_z = flt32(int32:handle) { flt32:r = aria_rl_get_camera_3d_target_z(handle); pass(r); };

pub func:CAMERA_CUSTOM       = int32() { pass(0i32); };
pub func:CAMERA_FREE         = int32() { pass(1i32); };
pub func:CAMERA_ORBITAL      = int32() { pass(2i32); };
pub func:CAMERA_FIRST_PERSON = int32() { pass(3i32); };
pub func:CAMERA_THIRD_PERSON = int32() { pass(4i32); };

pub func:CAMERA_PERSPECTIVE  = int32() { pass(0i32); };
pub func:CAMERA_ORTHOGRAPHIC = int32() { pass(1i32); };

pub func:rl_begin_mode_3d = NIL(flt32:pos_x, flt32:pos_y, flt32:pos_z,
                                flt32:tar_x, flt32:tar_y, flt32:tar_z,
                                flt32:up_x, flt32:up_y, flt32:up_z,
                                flt32:fovy, int32:projection) {
    aria_rl_begin_mode_3d(pos_x, pos_y, pos_z, tar_x, tar_y, tar_z, up_x, up_y, up_z, fovy, projection);
