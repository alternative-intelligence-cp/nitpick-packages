extern "nitpick_raylib_shim" {
    // procedural beep (wave_type: 0=square 1=triangle 2=sawtooth 3=sine)
    func:aria_rl_gen_beep = int32(int32:freq, int32:dur_ms, int32:wave, flt32:vol);
    // advanced shapes
    func:aria_rl_draw_line_ex = void(flt32:x1, flt32:y1, flt32:x2, flt32:y2, flt32:thick,
                                     int32:r, int32:g, int32:b, int32:a);
    func:aria_rl_draw_rectangle_rounded = void(flt32:x, flt32:y, flt32:w, flt32:h,
                                               flt32:roundness, int32:segments,
}

