// nitpick_raylib.npk — Idiomatic Nitpick bindings for raylib
//
// Provides windowing, 2D drawing, text rendering, and input handling.
// Requires: libnitpick_raylib_shim.so + libraylib.so

// ── extern declarations (C shim) ────────────────────────────────────

extern "nitpick_raylib_shim" {
    // window
    func:aria_rl_init_window          = void(int32:w, int32:h, string:title);
    func:aria_rl_close_window         = void();
    func:aria_rl_window_should_close  = int32();
    func:aria_rl_is_window_ready      = int32();
    func:aria_rl_is_window_fullscreen = int32();
    func:aria_rl_toggle_fullscreen    = void();
}

extern "nitpick_raylib_shim" {
    func:aria_rl_set_window_size      = void(int32:w, int32:h);
    func:aria_rl_set_window_title     = void(string:title);
    func:aria_rl_set_window_position  = void(int32:x, int32:y);
    func:aria_rl_get_screen_width     = int32();
    func:aria_rl_get_screen_height    = int32();
    // drawing lifecycle
    func:aria_rl_begin_drawing    = void();
}

extern "nitpick_raylib_shim" {
    func:aria_rl_end_drawing      = void();
    func:aria_rl_clear_background = void(int32:r, int32:g, int32:b, int32:a);
    // timing
    func:aria_rl_set_target_fps = void(int32:fps);
    func:aria_rl_get_fps        = int32();
    func:aria_rl_get_frame_time = flt32();
    func:aria_rl_get_time       = flt64();
}

extern "nitpick_raylib_shim" {
    // shapes: pixel
    func:aria_rl_draw_pixel = void(int32:x, int32:y,
                                   int32:r, int32:g, int32:b, int32:a);
    // shapes: line
    func:aria_rl_draw_line = void(int32:x1, int32:y1, int32:x2, int32:y2,
                                  int32:r, int32:g, int32:b, int32:a);
