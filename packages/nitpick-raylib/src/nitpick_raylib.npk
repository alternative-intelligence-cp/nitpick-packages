    func:aria_rl_end_mode_2d = void();
}

extern "nitpick_raylib_shim" {
    func:aria_rl_get_screen_to_world_2d_x = flt32(flt32:pos_x, flt32:pos_y, flt32:offset_x, flt32:offset_y, flt32:target_x, flt32:target_y, flt32:rotation, flt32:zoom);
