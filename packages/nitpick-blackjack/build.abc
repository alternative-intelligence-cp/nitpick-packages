[project]
name = "nitpick-blackjack"
version = "0.1.0"

[target.nitpick-blackjack]
type = "binary"
sources = ["src/main.npk"]
flags = ["-I", "src", "-I", "../nitpick-raylib/src", "-I", "../nitpick-str/src", "-I", "../nitpick-rand/src", "-I", "../nitpick-mongo/src", "-I", "../nitpick-orm/src", "-I", "../nitpick-json/src", "-I", "../nitpick-conv/src", "-L.", "-lblackjack_shims", "-lraylib", "-lmongoc-1.0", "-lbson-1.0", "-latomic", "-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_io", "-lnitpick_libc_math", "-lm"]
