// test_logic.npk - Tests for blackjack core logic
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/cards.npk".*;
use "nitpick_str.npk".*;

func:failsafe = int32(tbb32:_err) { exit 1i32; };

func:main = int32() {
    int32:errors = 0i32;

    // T1: Card value checking
    int32:v1 = raw card_val(0i32); // Ace
    if (v1 == 1i32) { println("[PASS] Card val 0 == 1"); } else { println("[FAIL] Card val 0"); errors = errors + 1i32; }

    int32:v2 = raw card_val(9i32); // 10
    if (v2 == 10i32) { println("[PASS] Card val 9 == 10"); } else { println("[FAIL] Card val 9"); errors = errors + 1i32; }

    int32:v3 = raw card_val(12i32); // King
    if (v3 == 10i32) { println("[PASS] Card val 12 == 10"); } else { println("[FAIL] Card val 12"); errors = errors + 1i32; }

    // T2: Basic Hand Score
    Hand:h1 = raw init_hand();
    h1 = raw hand_add(h1, 0i32); // Ace of Hearts
    h1 = raw hand_add(h1, 12i32); // King of Hearts
    int32:score1 = raw calc_score(h1);
    if (score1 == 21i32) { println("[PASS] Score A+K == 21"); } else { println("[FAIL] Score A+K"); errors = errors + 1i32; }

    // T3: Multiple Aces Downgrade
    Hand:h2 = raw init_hand();
    h2 = raw hand_add(h2, 0i32); // Ace
    h2 = raw hand_add(h2, 13i32); // Ace of Diamonds
    h2 = raw hand_add(h2, 8i32); // 9 of Hearts
    int32:score2 = raw calc_score(h2);
    if (score2 == 21i32) { println("[PASS] Score A+A+9 == 21"); } else { println("[FAIL] Score A+A+9"); errors = errors + 1i32; }

    // T4: Busted Score
    Hand:h3 = raw init_hand();
    h3 = raw hand_add(h3, 10i32); // Jack
    h3 = raw hand_add(h3, 11i32); // Queen
    h3 = raw hand_add(h3, 12i32); // King
    int32:score3 = raw calc_score(h3);
    if (score3 == 30i32) { println("[PASS] Score J+Q+K == 30"); } else { println("[FAIL] Score J+Q+K"); errors = errors + 1i32; }

    println("---");
    if (errors > 0i32) {
        println("FAIL: Some tests failed");
        exit 1i32;
    }
    println("PASS: All tests passed");
    exit 0i32;
};
