// nitpick_http.npk — Idiomatic Nitpick HTTP client library
//
// Provides GET, POST, PUT, DELETE, PATCH, HEAD requests via libcurl.
// Requires: libnitpick_http_shim.so + libcurl

// ── extern declarations (C shim) ────────────────────────────────────

extern "nitpick_http_shim" {
    // init / cleanup
    func:nitpick_http_init    = int32();
    func:nitpick_http_cleanup = void();

    // request configuration
    func:nitpick_http_set_header           = void(string:header);
    func:nitpick_http_clear_headers        = void();
    func:nitpick_http_set_timeout          = void(int32:seconds);
    func:nitpick_http_set_follow_redirects = void(int32:follow);
    func:nitpick_http_set_user_agent       = void(string:ua);

    // HTTP methods
    func:nitpick_http_get    = int32(string:url);
    func:nitpick_http_post   = int32(string:url, string:body);
    func:nitpick_http_put    = int32(string:url, string:body);
    func:nitpick_http_delete = int32(string:url);
    func:nitpick_http_patch  = int32(string:url, string:body);
    func:nitpick_http_head   = int32(string:url);

    // response accessors
    func:nitpick_http_status           = int32();
    func:nitpick_http_response_body    = int64();
    func:nitpick_http_response_length  = int32();
    func:nitpick_http_response_headers = int64();
    func:nitpick_http_error            = int64();

    // Ollama streaming
    func:nitpick_http_enable_ollama_stream = void(int32:enable);
    func:nitpick_http_get_ollama_content = int64();
    func:nitpick_http_get_ollama_tool = int64();
    func:nitpick_http_get_ollama_arg = int64();
    func:nitpick_http_get_ollama_conf = int32();

    // URL encoding
    func:nitpick_http_url_encode = int64(string:str);
    func:nitpick_http_last_result = int64();
}

// ── public API: init / cleanup ──────────────────────────────────────

pub func:http_init = int32() {
    int32:r = nitpick_http_init();
    pass(r);
};

pub func:http_cleanup = NIL() {
    nitpick_http_cleanup();
    pass(NIL);
};

pub func:http_last_result = string() {
    pass string_from_cstr(nitpick_http_last_result());
};

pub func:http_enable_ollama_stream = NIL(int32:enable) {
    nitpick_http_enable_ollama_stream(enable);
    pass(NIL);
};

pub func:http_get_ollama_content = string() {
    pass string_from_cstr(nitpick_http_get_ollama_content());
};

pub func:http_get_ollama_tool = string() {
    pass string_from_cstr(nitpick_http_get_ollama_tool());
};

pub func:http_get_ollama_arg = string() {
    pass string_from_cstr(nitpick_http_get_ollama_arg());
};

pub func:http_get_ollama_conf = int32() {
    pass(nitpick_http_get_ollama_conf());
};

// ── public API: request configuration ───────────────────────────────

pub func:http_set_header = NIL(string:header) {
    nitpick_http_set_header(header);
    pass(NIL);
};

pub func:http_clear_headers = NIL() {
    nitpick_http_clear_headers();
    pass(NIL);
};

pub func:http_set_timeout = NIL(int32:seconds) {
    nitpick_http_set_timeout(seconds);
    pass(NIL);
};

pub func:http_follow_redirects = NIL(int32:follow) {
    nitpick_http_set_follow_redirects(follow);
    pass(NIL);
};

pub func:http_set_user_agent = NIL(string:ua) {
    nitpick_http_set_user_agent(ua);
    pass(NIL);
};

// ── public API: HTTP methods ────────────────────────────────────────

pub func:http_get = int32(string:url) {
    int32:r = nitpick_http_get(url);
    pass(r);
};

pub func:http_post = int32(string:url, string:body) {
    int32:r = nitpick_http_post(url, body);
    pass(r);
};

pub func:http_put = int32(string:url, string:body) {
    int32:r = nitpick_http_put(url, body);
    pass(r);
};

pub func:http_delete = int32(string:url) {
    int32:r = nitpick_http_delete(url);
    pass(r);
};

pub func:http_patch = int32(string:url, string:body) {
    int32:r = nitpick_http_patch(url, body);
    pass(r);
};

pub func:http_head = int32(string:url) {
    int32:r = nitpick_http_head(url);
    pass(r);
};

// ── public API: response ────────────────────────────────────────────

pub func:http_status = int32() {
    int32:r = nitpick_http_status();
    pass(r);
};

pub func:http_body = string() {
    pass string_from_cstr(nitpick_http_response_body());
};

pub func:http_body_length = int32() {
    int32:r = nitpick_http_response_length();
    pass(r);
};

pub func:http_response_headers = string() {
    pass string_from_cstr(nitpick_http_response_headers());
};

pub func:http_error = string() {
    pass string_from_cstr(nitpick_http_error());
};

// ── public API: utilities ───────────────────────────────────────────

pub func:http_url_encode = string(string:str) {
    drop(nitpick_http_url_encode(str));
    pass string_from_cstr(nitpick_http_last_result());
};
