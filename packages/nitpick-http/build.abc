[project]
name = "nitpick-http"
version = "0.12.0"

[target.nitpick-http]
type = "library"
sources = ["src/nitpick_http.npk"]
deps = []
flags = ["-L.", "-lnitpick_http_shim"]

[target.test-nitpick-http]
type = "binary"
sources = ["tests/test_nitpick_http.npk"]
deps = []
flags = ["-I", "src", "-L.", "-lnitpick_http_shim", "-lcurl"]
