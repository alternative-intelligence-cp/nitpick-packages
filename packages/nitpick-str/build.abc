[project]
name = "nitpick-str"
version = "0.1.0"

[target.nitpick-str]
type = "library"
sources = ["src/nitpick_str.npk"]
deps = []
flags = []

[target.test-nitpick-str]
type = "binary"
sources = ["tests/test_nitpick_str.npk"]
deps = ["nitpick-str"]
flags = ["-I", "src", "-L../../../nitpick-libc/shim", "-lnitpick_libc_string", "-lnitpick_libc_mem", "-lnitpick_libc_io"]
