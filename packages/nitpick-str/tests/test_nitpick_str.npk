// test_nitpick_str.npk
extern "libc" { func:printf = int32(string:fmt); }
extern "libc" { func:nitpick_libc_exit = NIL(int32:code); }
use "../src/nitpick_str.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq_str = int64(string:actual, string:expected, string:test_name) {
    if (string_equals(actual, expected) == false) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:assert_eq_i64 = int64(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:assert_eq_bool = int64(bool:actual, bool:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:main = int32() {
    // 01
    drop assert_eq_str(raw Str.char_at("hello", 0i64), "h", "01 char_at: 0 -> h\0");
    drop assert_eq_str(raw Str.char_at("hello", 4i64), "o", "02 char_at: 4 -> o\0");
    drop assert_eq_str(raw Str.char_at("hello", 10i64), "", "03 char_at: 10 -> empty\0");

    // 04
    drop assert_eq_str(raw Str.slice("hello world", 6i64), "world", "04 slice: 6 -> world\0");
    drop assert_eq_str(raw Str.slice("abc", 0i64), "abc", "05 slice: 0 -> whole\0");
    drop assert_eq_str(raw Str.slice("abc", 5i64), "", "06 slice: 5 -> empty\0");

    // 07
    drop assert_eq_str(raw Str.before("foo:bar:baz", ":"), "foo", "07 before: foo:bar:baz -> foo\0");
    drop assert_eq_str(raw Str.before("hello", ":"), "hello", "08 before: hello -> hello\0");
    drop assert_eq_str(raw Str.after("usr/local/bin", "/"), "local/bin", "09 after: usr/local/bin -> local/bin\0");
    drop assert_eq_str(raw Str.after("hello", "/"), "", "10 after: hello -> empty\0");

    // 11
    drop assert_eq_str(raw Str.before_last("usr/local/bin", "/"), "usr/local", "11 before_last: usr/local/bin -> usr/local\0");
    drop assert_eq_str(raw Str.after_last("usr/local/bin", "/"), "bin", "12 after_last: usr/local/bin -> bin\0");

    // 13
    drop assert_eq_str(raw Str.between("<hello>", "<", ">"), "hello", "13 between: <hello> -> hello\0");
    drop assert_eq_str(raw Str.between("<hello", "<", ">"), "", "14 between: <hello -> empty\0");

    // 15
    drop assert_eq_str(raw Str.replace("aabbaa", "aa", "X"), "Xbbaa", "15 replace: aabbaa -> Xbbaa\0");
    drop assert_eq_str(raw Str.replace("hello", "xyz", "Z"), "hello", "16 replace: hello -> hello\0");

    // 17
    drop assert_eq_str(raw Str.replace_all("aabbccaabbccaa", "aa", "X"), "XbbccXbbccX", "17 replace_all: aabbccaabbccaa -> XbbccXbbccX\0");
    drop assert_eq_str(raw Str.replace_all("no match here", "xyz", "Z"), "no match here", "18 replace_all: no match -> unchanged\0");

    // 19
    drop assert_eq_str(raw Str.remove_prefix("--verbose", "--"), "verbose", "19 remove_prefix: --verbose -> verbose\0");
    drop assert_eq_str(raw Str.remove_prefix("verbose", "--"), "verbose", "20 remove_prefix: verbose -> verbose\0");
    drop assert_eq_str(raw Str.remove_suffix("readme.txt", ".txt"), "readme", "21 remove_suffix: readme.txt -> readme\0");
    drop assert_eq_str(raw Str.remove_suffix("readme", ".txt"), "readme", "22 remove_suffix: readme -> readme\0");

    // 23
    drop assert_eq_i64(raw Str.count("banana", "a"), 3i64, "23 count: banana a -> 3\0");
    drop assert_eq_i64(raw Str.count("hello", "xyz"), 0i64, "24 count: hello xyz -> 0\0");
    drop assert_eq_i64(raw Str.count("abcabcabc", "abc"), 3i64, "25 count: abcabcabc abc -> 3\0");

    // 26
    drop assert_eq_i64(raw Str.line_count("line1\nline2\nline3"), 3i64, "26 line_count: 3 lines -> 3\0");
    drop assert_eq_i64(raw Str.line_count("hello"), 1i64, "27 line_count: 1 line -> 1\0");

    // 28
    drop assert_eq_bool(raw Str.is_blank("   "), true, "28 is_blank: spaces -> true\0");
    drop assert_eq_bool(raw Str.is_blank("hello"), false, "29 is_blank: hello -> false\0");

    // 30
    drop assert_eq_i64(raw Str.token_count("a:b:c", ":"), 3i64, "30 token_count: a:b:c -> 3\0");
    drop assert_eq_i64(raw Str.token_count("hello", ":"), 1i64, "31 token_count: hello -> 1\0");

    // 32
    drop assert_eq_str(raw Str.token("foo:bar:baz", ":", 0i64), "foo", "32 token: 0 -> foo\0");
    drop assert_eq_str(raw Str.token("foo:bar:baz", ":", 1i64), "bar", "33 token: 1 -> bar\0");
    drop assert_eq_str(raw Str.token("foo:bar:baz", ":", 2i64), "baz", "34 token: 2 -> baz\0");
    drop assert_eq_str(raw Str.token("foo:bar:baz", ":", 5i64), "", "35 token: 5 -> empty\0");

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
