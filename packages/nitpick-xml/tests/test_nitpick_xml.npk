// test_nitpick_xml.npk — XML parser tests (8 tests)

extern "libc" { func:printf = int32(string:fmt); }
int32:fail_cnt = 0i32;
use "nitpick_xml.npk".*;

func:failsafe = int32(tbb32:err) { drop(err); exit 1i32; };

func:main = int32() {
    int32:n = raw XML.parse("<root><name>Aria</name><version>0.2.6</version><item id=\"42\" type=\"test\">hello</item><item id=\"43\">world</item></root>");

    // T01: parse
    if (n > 0i32) { drop(printf("[PASS] T01 parse\n\0")); }
    if (n <= 0i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T01 parse\n\0")); }

    // T02: has tag
    int32:h1 = raw XML.has_tag("name");
    if (h1 == 1i32) { drop(printf("[PASS] T02 has_tag\n\0")); }
    if (h1 != 1i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T02 has_tag\n\0")); }

    // T03: get text
    string:t1 = raw XML.get_text("name");
    drop(printf("[PASS] T03 get_text\n\0"));

    // T04: get attribute
    string:a1 = raw XML.get_attr("item", "id");
    drop(printf("[PASS] T04 get_attr\n\0"));

    // T05: count tag
    int32:c1 = raw XML.count_tag("item");
    if (c1 == 2i32) { drop(printf("[PASS] T05 count_tag\n\0")); }
    if (c1 != 2i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T05 count_tag\n\0")); }

    // T06: missing tag
    int32:h2 = raw XML.has_tag("nonexistent");
    if (h2 == 0i32) { drop(printf("[PASS] T06 missing tag\n\0")); }
    if (h2 != 0i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T06 missing tag\n\0")); }

    // T07: node count
    int32:nc = raw XML.node_count();
    if (nc > 0i32) { drop(printf("[PASS] T07 node_count\n\0")); }
    if (nc <= 0i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T07 node_count\n\0")); }

    // T08: clear
    raw XML.clear();
    int32:nc2 = raw XML.node_count();
    if (nc2 == 0i32) { drop(printf("[PASS] T08 clear\n\0")); }
    if (nc2 != 0i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T08 clear\n\0")); }

    if (fail_cnt > 0i32) { drop(printf("FAIL\n\0")); } exit fail_cnt;
};
