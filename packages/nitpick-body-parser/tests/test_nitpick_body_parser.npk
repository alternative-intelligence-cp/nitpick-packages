// test_nitpick_body_parser.npk — 12-test suite for nitpick-body-parser (v0.12.1)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_body_parser.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:test_detect = int32() {
    int32:pc = 0i32;

    string:d1 = raw body_detect("application/x-www-form-urlencoded");
    if (d1 == "urlencoded") { println("[PASS] T01 detect urlencoded"); pc += 1i32; }
    if (d1 != "urlencoded") { println("[FAIL] T01"); }

    string:d2 = raw body_detect("application/json");
    if (d2 == "json") { println("[PASS] T02 detect json"); pc += 1i32; }
    if (d2 != "json") { println("[FAIL] T02"); }

    string:d3 = raw body_detect("multipart/form-data; boundary=abc");
    if (d3 == "multipart") { println("[PASS] T03 detect multipart"); pc += 1i32; }
    if (d3 != "multipart") { println("[FAIL] T03"); }

    string:d4 = raw body_detect("application/octet-stream");
    int32:t4 = 0i32;
    if (d4 == "unknown") { t4 = 1i32; }
    if (t4 == 1i32) { println("[PASS] T04 detect unknown"); pc += 1i32; }
    if (t4 == 0i32) { println("[FAIL] T04"); }

    pass pc;
};

func:test_parse_single = int32() {
    int32:pc = 0i32;

    int64:bh5 = raw body_parse("application/x-www-form-urlencoded", "name=alice");
    int64:_n5 = raw body_parse_urlencoded(bh5, "name=alice");
    string:f5 = raw body_field(bh5, "name");
    if (f5 == "alice") { println("[PASS] T05 parse single field"); pc += 1i32; }
    if (f5 != "alice") { println("[FAIL] T05"); }

    pass pc;
};

func:test_parse_multi = int32() {
    int32:pc = 0i32;

    int64:bh6 = raw body_parse("application/x-www-form-urlencoded", "a=1&b=2&c=3");
    int64:_n6 = raw body_parse_urlencoded(bh6, "a=1&b=2&c=3");
    int64:c6 = raw body_field_count(bh6);
    if (c6 == 3i64) { println("[PASS] T06 field count=3"); pc += 1i32; }
    if (c6 != 3i64) { println("[FAIL] T06"); }

    string:f7 = raw body_field(bh6, "b");
    if (f7 == "2") { println("[PASS] T07 field b=2"); pc += 1i32; }
    if (f7 != "2") { println("[FAIL] T07"); }

    string:k8 = raw body_field_key(bh6, 0i64);
    if (k8 == "a") { println("[PASS] T08 field_key[0]=a"); pc += 1i32; }
    if (k8 != "a") { println("[FAIL] T08"); }

    string:v9 = raw body_field_value(bh6, 1i64);
    if (v9 == "2") { println("[PASS] T09 field_value[1]=2"); pc += 1i32; }
    if (v9 != "2") { println("[FAIL] T09"); }

    pass pc;
};

func:test_access = int32() {
    int32:pc = 0i32;

    int64:bh = raw body_parse("application/x-www-form-urlencoded", "a=1&b=2&c=3");
    int64:_na = raw body_parse_urlencoded(bh, "a=1&b=2&c=3");

    int64:hf10 = raw body_has_field(bh, "c");
    if (hf10 == 1i64) { println("[PASS] T10 has_field c=true"); pc += 1i32; }
    if (hf10 != 1i64) { println("[FAIL] T10"); }

    string:r11 = raw body_raw(bh);
    if (r11 == "a=1&b=2&c=3") { println("[PASS] T11 raw body"); pc += 1i32; }
    if (r11 != "a=1&b=2&c=3") { println("[FAIL] T11"); }

    string:ct12 = raw body_content_type(bh);
    if (string_contains(ct12, "urlencoded")) { println("[PASS] T12 content_type"); pc += 1i32; }
    if (string_contains(ct12, "urlencoded") == false) { println("[FAIL] T12"); }

    pass pc;
};

func:main = int32() {
    int32:pass_count = 0i32;
    int32:p1 = raw test_detect();
    int32:p2 = raw test_parse_single();
    int32:p3 = raw test_parse_multi();
    int32:p4 = raw test_access();
    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
