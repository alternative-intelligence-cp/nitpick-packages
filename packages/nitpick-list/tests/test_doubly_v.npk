// test_doubly_v.npk — Tests for DListV (universal tagged doubly-linked list)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/singly_v.npk".*;
use "../src/doubly_v.npk".*;

int64:LIST_TAG_INT   = 0i64;
int64:LIST_TAG_F64   = 1i64;
int64:LIST_TAG_PTR   = 2i64;
int64:LIST_TAG_BYTES = 3i64;

int64:fail_cnt = 0i64;
func:failsafe = int32(tbb32:_e) { drop _e; exit 1i32; };

func:assert_eq = int64(int64:a, int64:e, string:n) {
    if (a != e) { fail_cnt += 1i64; drop printf("[FAIL] \0"); drop printf(n); drop printf("\n\0"); }
    else        { drop printf("[PASS] \0"); drop printf(n); drop printf("\n\0"); }
    pass 0i64;
};
func:assert_i32 = int64(int32:a, int32:e, string:n) { pass raw assert_eq(a => int64, e => int64, n); };

func:main = int32() {
    int64:dl = raw DListV.create();
    int64:ot = nitpick_libc_mem_malloc(8i64);
    int64:ov = nitpick_libc_mem_malloc(8i64);

    drop assert_eq (raw DListV.len(dl), 0i64, "T01 initial len\0");
    drop assert_i32(raw DListV.is_empty(dl), 1i32, "T02 is_empty\0");

    // push mixed types
    drop DListV.push_front(dl, LIST_TAG_INT, 10i64);
    drop DListV.push_front(dl, LIST_TAG_PTR, 200i64);
    drop DListV.push_back(dl,  LIST_TAG_F64, 300i64);
    drop assert_eq(raw DListV.len(dl), 3i64, "T03 len=3\0");
    drop assert_eq(raw DListV.peek_front_tag(dl), LIST_TAG_PTR, "T04 front tag=PTR\0");
    drop assert_eq(raw DListV.peek_front_val(dl), 200i64, "T05 front val=200\0");
    drop assert_eq(raw DListV.peek_back_tag(dl),  LIST_TAG_F64, "T06 back tag=F64\0");
    drop assert_eq(raw DListV.peek_back_val(dl),  300i64, "T07 back val=300\0");

    // pop_front
    int32:r1 = raw DListV.pop_front(dl, ot, ov);
    drop assert_i32(r1, 0i32, "T08 pop_front ok\0");
    drop assert_eq(nitpick_libc_mem_read_i64(ot, 0i64), LIST_TAG_PTR, "T09 popped tag=PTR\0");
    drop assert_eq(nitpick_libc_mem_read_i64(ov, 0i64), 200i64, "T10 popped val=200\0");

    // pop_back
    int32:r2 = raw DListV.pop_back(dl, ot, ov);
    drop assert_i32(r2, 0i32, "T11 pop_back ok\0");
    drop assert_eq(nitpick_libc_mem_read_i64(ot, 0i64), LIST_TAG_F64, "T12 back tag=F64\0");
    drop assert_eq(nitpick_libc_mem_read_i64(ov, 0i64), 300i64, "T13 back val=300\0");
    drop assert_eq(raw DListV.len(dl), 1i64, "T14 len=1\0");

    // contains
    drop assert_i32(raw DListV.contains_val(dl, LIST_TAG_INT, 10i64), 1i32, "T15 contains int 10\0");
    drop assert_i32(raw DListV.contains_val(dl, LIST_TAG_PTR, 10i64), 0i32, "T16 wrong tag\0");

    // remove_first
    drop DListV.push_back(dl, LIST_TAG_INT, 20i64);
    drop DListV.push_back(dl, LIST_TAG_INT, 30i64);
    drop assert_i32(raw DListV.remove_first(dl, LIST_TAG_INT, 10i64), 0i32, "T17 remove 10\0");
    drop assert_i32(raw DListV.contains_val(dl, LIST_TAG_INT, 10i64), 0i32, "T18 10 gone\0");

    // reverse: [20, 30] → [30, 20]
    drop DListV.reverse(dl);
    drop assert_eq(raw DListV.peek_front_val(dl), 30i64, "T19 reverse front=30\0");
    drop assert_eq(raw DListV.peek_back_val(dl),  20i64, "T20 reverse back=20\0");

    // clear
    drop DListV.clear(dl);
    drop assert_eq (raw DListV.len(dl), 0i64, "T21 clear len=0\0");
    drop assert_i32(raw DListV.is_empty(dl), 1i32, "T22 is_empty after clear\0");

    int32:mf1 = nitpick_libc_mem_free(ot);
    int32:mf2 = nitpick_libc_mem_free(ov);
    drop DListV.destroy(dl);
    drop printf("────────────────────\n\0");
    if (fail_cnt > 0i64) { drop printf("FAILURES detected\n\0"); exit 1i32; }
    drop printf("All doubly_v tests passed\n\0");
    exit 0i32;
};
