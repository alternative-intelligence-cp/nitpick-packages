// test_circular_v.npk — Tests for CListV (universal tagged circular list)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/singly_v.npk".*;
use "../src/circular_v.npk".*;

int64:LIST_TAG_INT   = 0i64;
int64:LIST_TAG_F64   = 1i64;
int64:LIST_TAG_PTR   = 2i64;
int64:LIST_TAG_BYTES = 3i64;

int64:fail_cnt = 0i64;
func:failsafe = int32(tbb32:_e) { drop _e; exit 1i32; };

func:assert_eq = int64(int64:a, int64:e, string:n) {
    if (a != e) { fail_cnt += 1i64; drop printf("[FAIL] \0"); drop printf(n); drop printf("\n\0"); }
    else        { drop printf("[PASS] \0"); drop printf(n); drop printf("\n\0"); }
    pass 0i64;
};
func:assert_i32 = int64(int32:a, int32:e, string:n) { pass raw assert_eq(a => int64, e => int64, n); };

func:main = int32() {
    int64:cl = raw CListV.create();
    int64:ot = nitpick_libc_mem_malloc(8i64);
    int64:ov = nitpick_libc_mem_malloc(8i64);

    drop assert_eq (raw CListV.len(cl), 0i64, "T01 initial len=0\0");
    drop assert_i32(raw CListV.is_empty(cl), 1i32, "T02 is_empty\0");

    // push three elements of different tags
    drop CListV.push(cl, LIST_TAG_INT, 10i64);
    drop CListV.push(cl, LIST_TAG_PTR, 20i64);
    drop CListV.push(cl, LIST_TAG_F64, 30i64);
    drop assert_eq(raw CListV.len(cl), 3i64, "T03 len=3\0");

    // head = first push (10), tail = last push (30)
    drop assert_eq(raw CListV.peek_tag(cl), LIST_TAG_INT, "T04 peek head tag=INT\0");
    drop assert_eq(raw CListV.peek_val(cl), 10i64, "T05 peek head val=10\0");
    drop assert_eq(raw CListV.peek_tail_tag(cl), LIST_TAG_F64, "T06 peek tail tag=F64\0");
    drop assert_eq(raw CListV.peek_tail_val(cl), 30i64, "T07 peek tail val=30\0");

    // contains
    drop assert_i32(raw CListV.contains_val(cl, LIST_TAG_PTR, 20i64),  1i32, "T08 contains ptr 20\0");
    drop assert_i32(raw CListV.contains_val(cl, LIST_TAG_INT, 20i64),  0i32, "T09 wrong tag\0");
    drop assert_i32(raw CListV.contains_val(cl, LIST_TAG_INT, 999i64), 0i32, "T10 not found\0");

    // rotate — tail advances: new head = old head.next (PTR:20), new tail = INT:10
    drop CListV.rotate(cl);
    drop assert_eq(raw CListV.peek_val(cl),      20i64, "T11 rotate head=20\0");
    drop assert_eq(raw CListV.peek_tail_val(cl), 10i64, "T12 rotate tail=10\0");

    // pop removes head (PTR:20)
    int32:pop_ok = raw CListV.pop(cl, ot, ov);
    drop assert_i32(pop_ok, 0i32, "T13 pop ok\0");
    drop assert_eq(nitpick_libc_mem_read_i64(ot, 0i64), LIST_TAG_PTR, "T14 popped tag=PTR\0");
    drop assert_eq(nitpick_libc_mem_read_i64(ov, 0i64), 20i64, "T15 popped val=20\0");
    drop assert_eq(raw CListV.len(cl), 2i64, "T16 len=2\0");

    // clear
    drop CListV.clear(cl);
    drop assert_eq (raw CListV.len(cl), 0i64, "T17 clear len=0\0");
    drop assert_i32(raw CListV.is_empty(cl), 1i32, "T18 is_empty after clear\0");

    // push after clear
    drop CListV.push(cl, LIST_TAG_BYTES, 55i64);
    drop assert_eq(raw CListV.peek_tag(cl), LIST_TAG_BYTES, "T19 push after clear tag=BYTES\0");
    drop assert_eq(raw CListV.peek_val(cl), 55i64, "T20 push after clear val=55\0");
    drop assert_eq(raw CListV.len(cl), 1i64, "T21 len=1\0");

    int32:mf1 = nitpick_libc_mem_free(ot);
    int32:mf2 = nitpick_libc_mem_free(ov);
    drop CListV.destroy(cl);
    drop printf("────────────────────\n\0");
    if (fail_cnt > 0i64) { drop printf("FAILURES detected\n\0"); exit 1i32; }
    drop printf("All circular_v tests passed\n\0");
    exit 0i32;
};
