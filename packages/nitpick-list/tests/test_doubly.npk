// test_doubly.npk — Tests for doubly-linked list (fast int64 variant)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/doubly.npk".*;

int64:fail_cnt = 0i64;
func:failsafe = int32(tbb32:_e) { drop _e; exit 1i32; };

func:assert_eq = int64(int64:a, int64:e, string:n) {
    if (a != e) { fail_cnt += 1i64; drop printf("[FAIL] \0"); drop printf(n); drop printf("\n\0"); }
    else        { drop printf("[PASS] \0"); drop printf(n); drop printf("\n\0"); }
    pass 0i64;
};
func:assert_i32 = int64(int32:a, int32:e, string:n) { pass raw assert_eq(a => int64, e => int64, n); };

func:main = int32() {
    int64:dl = raw DList.create();

    drop assert_eq (raw DList.len(dl), 0i64,  "T01 initial len=0\0");
    drop assert_i32(raw DList.is_empty(dl), 1i32, "T02 is_empty\0");
    drop assert_eq (raw DList.pop_front(dl), -1i64, "T03 pop_front empty\0");
    drop assert_eq (raw DList.pop_back(dl),  -1i64, "T04 pop_back empty\0");

    // push_front builds [30, 20, 10]
    drop DList.push_front(dl, 10i64);
    drop DList.push_front(dl, 20i64);
    drop DList.push_front(dl, 30i64);
    drop assert_eq (raw DList.len(dl), 3i64, "T05 len=3\0");
    drop assert_eq (raw DList.peek_front(dl), 30i64, "T06 peek_front=30\0");
    drop assert_eq (raw DList.peek_back(dl),  10i64, "T07 peek_back=10\0");

    // pop from both ends
    drop assert_eq(raw DList.pop_front(dl), 30i64, "T08 pop_front=30\0");
    drop assert_eq(raw DList.pop_back(dl),  10i64, "T09 pop_back=10\0");
    drop assert_eq(raw DList.len(dl), 1i64, "T10 len=1 after two pops\0");
    drop assert_eq(raw DList.peek_front(dl), 20i64, "T11 only elem=20\0");

    // push_back
    drop DList.push_back(dl, 50i64);
    drop DList.push_back(dl, 60i64);
    drop assert_eq(raw DList.peek_back(dl), 60i64, "T12 peek_back=60\0");
    drop assert_eq(raw DList.len(dl), 3i64, "T13 len=3\0");

    // contains / remove_first
    drop assert_i32(raw DList.contains(dl, 50i64),  1i32, "T14 contains 50\0");
    drop assert_i32(raw DList.contains(dl, 999i64), 0i32, "T15 not contains 999\0");
    drop assert_i32(raw DList.remove_first(dl, 50i64), 0i32, "T16 remove 50 ok\0");
    drop assert_i32(raw DList.contains(dl, 50i64), 0i32, "T17 50 gone\0");
    drop assert_eq (raw DList.len(dl), 2i64, "T18 len=2\0");

    // reverse: [20, 60] → [60, 20]
    drop DList.reverse(dl);
    drop assert_eq(raw DList.peek_front(dl), 60i64, "T19 reverse front=60\0");
    drop assert_eq(raw DList.peek_back(dl),  20i64, "T20 reverse back=20\0");

    // clear and verify
    drop DList.clear(dl);
    drop assert_eq (raw DList.len(dl), 0i64, "T21 clear len=0\0");
    drop assert_i32(raw DList.is_empty(dl), 1i32, "T22 is_empty after clear\0");

    // single element round-trip
    drop DList.push_back(dl, 77i64);
    drop assert_eq(raw DList.pop_back(dl), 77i64, "T23 single pop_back=77\0");
    drop assert_i32(raw DList.is_empty(dl), 1i32, "T24 empty after single pop\0");

    drop DList.destroy(dl);
    drop printf("────────────────────\n\0");
    if (fail_cnt > 0i64) { drop printf("FAILURES detected\n\0"); exit 1i32; }
    drop printf("All doubly tests passed\n\0");
    exit 0i32;
};
