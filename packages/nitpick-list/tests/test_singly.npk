// test_singly.npk — Tests for singly-linked list (fast int64 variant)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/singly.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:_e) { drop _e; exit 1i32; };

func:assert_eq = int64(int64:actual, int64:expected, string:name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop printf("[FAIL] \0"); drop printf(name); drop printf("\n\0");
    } else {
        drop printf("[PASS] \0"); drop printf(name); drop printf("\n\0");
    }
    pass 0i64;
};

func:assert_i32 = int64(int32:actual, int32:expected, string:name) {
    pass raw assert_eq(actual => int64, expected => int64, name);
};

func:main = int32() {
    int64:sl = raw SList.create();

    // T01 — initial state
    drop assert_eq(raw SList.len(sl), 0i64,  "T01 initial len=0\0");
    drop assert_i32(raw SList.is_empty(sl), 1i32, "T02 is_empty on new\0");

    // T03 — pop on empty returns -1
    drop assert_eq(raw SList.pop_front(sl), -1i64, "T03 pop_front empty=-1\0");

    // T04-T06 — push_front
    drop SList.push_front(sl, 10i64);
    drop SList.push_front(sl, 20i64);
    drop SList.push_front(sl, 30i64);
    drop assert_eq(raw SList.len(sl), 3i64,  "T04 len after 3 push_front\0");
    drop assert_eq(raw SList.peek_front(sl), 30i64, "T05 peek_front=30\0");
    drop assert_eq(raw SList.peek_back(sl),  10i64, "T06 peek_back=10\0");

    // T07 — pop_front
    drop assert_eq(raw SList.pop_front(sl), 30i64, "T07 pop_front=30\0");
    drop assert_eq(raw SList.len(sl), 2i64, "T08 len after pop\0");

    // T09-T10 — push_back maintains tail
    drop SList.push_back(sl, 99i64);
    drop assert_eq(raw SList.peek_back(sl), 99i64, "T09 peek_back after push_back\0");
    drop assert_eq(raw SList.len(sl), 3i64, "T10 len=3\0");

    // T11-T12 — contains
    drop assert_i32(raw SList.contains(sl, 20i64), 1i32, "T11 contains 20\0");
    drop assert_i32(raw SList.contains(sl, 999i64), 0i32, "T12 not contains 999\0");

    // T13 — remove_first
    drop assert_i32(raw SList.remove_first(sl, 20i64), 0i32, "T13 remove_first 20 ok\0");
    drop assert_i32(raw SList.contains(sl, 20i64), 0i32, "T14 20 gone after remove\0");
    drop assert_eq(raw SList.len(sl), 2i64, "T15 len=2 after remove\0");

    // T16 — reverse
    // sl now: [10, 99] (after removing 20)
    drop SList.reverse(sl);
    drop assert_eq(raw SList.peek_front(sl), 99i64, "T16 reverse: front=99\0");
    drop assert_eq(raw SList.peek_back(sl),  10i64, "T17 reverse: back=10\0");

    // T18 — clear
    drop SList.clear(sl);
    drop assert_eq(raw SList.len(sl), 0i64, "T18 clear: len=0\0");
    drop assert_i32(raw SList.is_empty(sl), 1i32, "T19 is_empty after clear\0");

    // T20 — single element edge case
    drop SList.push_back(sl, 42i64);
    drop assert_eq(raw SList.peek_front(sl), 42i64, "T20 single: peek_front=42\0");
    drop assert_eq(raw SList.peek_back(sl),  42i64, "T21 single: peek_back=42\0");
    drop assert_eq(raw SList.pop_front(sl),  42i64, "T22 single: pop_front=42\0");
    drop assert_eq(raw SList.len(sl),         0i64, "T23 single: len=0 after pop\0");

    drop SList.destroy(sl);
    drop printf("────────────────────\n\0");
    if (fail_cnt > 0i64) {
        drop printf("FAILURES detected\n\0");
        exit 1i32;
    }
    drop printf("All singly tests passed\n\0");
    exit 0i32;
};
