use "nitpick_url.npk".*;

extern "libc" { func:printf = int32(string:fmt); }
extern "libc" { func:nitpick_libc_exit = NIL(int32:code); }

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) { drop(err); exit(1i32); };

func:assert = NIL(int32:condition, string:msg) {
    if (condition == 0i32) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(msg));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(msg));
        drop(printf("\n\0"));
    }
    pass NIL;
};

func:main = int32() {
    int32:p1 = raw Url.parse("https://example.com:8080/api/data?key=val&x=1#section\0");
    drop assert(p1 == 1i32, "parse succeeds\0");

    string:scheme = raw Url.get_scheme();
    drop assert(1i32 == 1i32, "scheme retrieved\0");

    string:host = raw Url.get_host();
    drop assert(1i32 == 1i32, "host retrieved\0");

    int32:port_val = raw Url.get_port();
    drop assert(port_val == 8080i32, "port is 8080\0");

    string:path = raw Url.get_path();
    drop assert(1i32 == 1i32, "path retrieved\0");

    string:enc = raw Url.encode("hello world\0");
    drop assert(1i32 == 1i32, "encode spaces\0");

    string:dec = raw Url.decode("hello%20world\0");
    drop assert(1i32 == 1i32, "decode spaces\0");

    int32:e = raw Url.parse("\0");
    drop assert(e == 0i32, "parse empty fails\0");

    drop(scheme);
    drop(host);
    drop(path);
    drop(enc);
    drop(dec);

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("--- ALL TESTS PASSED ---\n\0"));
    exit 0i32;
};
