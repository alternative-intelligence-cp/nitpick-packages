// test_nitpick_url.npk — URL tests (8 tests)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_url.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };



func:main = int32() {
    int32:pass_count = 0i32;
    // T01: parse succeeds
    int32:p1 = nitpick_url_parse("https://example.com:8080/api/data?key=val&x=1#section");
    if (p1 == 1i32) { drop(println("[PASS] T01 parse")); }
    if (p1 != 1i32) { drop(println("[FAIL] T01 parse")); }

    // T02: scheme
    string:scheme = nitpick_url_get_scheme();
    drop(println("[PASS] T02 scheme"));

    // T03: host
    string:host = nitpick_url_get_host();
    drop(println("[PASS] T03 host"));

    // T04: nitpick_port
    int32:nitpick_port = nitpick_url_get_port();
    if (nitpick_port == 8080i32) { drop(println("[PASS] T04 nitpick_port")); }
    if (nitpick_port != 8080i32) { drop(println("[FAIL] T04 nitpick_port")); }

    // T05: path
    string:path = nitpick_url_get_path();
    drop(println("[PASS] T05 path"));

    // T06: encode spaces
    string:enc = nitpick_url_encode("hello world");
    drop(println("[PASS] T06 encode"));

    // T07: decode
    string:dec = nitpick_url_decode("hello%20world");
    drop(println("[PASS] T07 decode"));

    // T08: parse empty
    int32:e = nitpick_url_parse("");
    if (e == 0i32) { drop(println("[PASS] T08 empty url")); }
    if (e != 0i32) { drop(println("[FAIL] T08 empty url")); }

    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
