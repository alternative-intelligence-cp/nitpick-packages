use "../src/nitpick_url.npk".*;

extern "libc" { func:printf = int32(string:fmt); }
extern "libc" { func:nitpick_libc_exit = NIL(int32:code); }

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) { drop(err); exit(1i32); };

func:assert_str = NIL(string:actual, string:expected, string:msg) {
    if (string_equals(actual, expected)) {
        drop(printf("[PASS] \0"));
        drop(printf(msg));
        drop(printf("\n\0"));
    } else {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(msg));
        drop(printf("\n\0"));
        drop(printf("  expected: \0"));
        drop(printf(expected));
        drop(printf("\n\0"));
        drop(printf("  got:      \0"));
        drop(printf(actual));
        drop(printf("\n\0"));
    }
    pass NIL;
};

func:assert_i32 = NIL(int32:actual, int32:expected, string:msg) {
    if (actual == expected) {
        drop(printf("[PASS] \0"));
        drop(printf(msg));
        drop(printf("\n\0"));
    } else {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(msg));
        drop(printf("\n\0"));
    }
    pass NIL;
};

func:main = int32() {
    // T01: parse a full URL succeeds (returns 1)
    int32:p1 = raw Url.parse("https://example.com:8080/api/data?key=val&x=1#section\0");
    drop assert_i32(p1, 1i32, "T01 parse full URL returns 1\0");

    // T02: scheme is "https"
    string:scheme = raw Url.get_scheme();
    drop assert_str(scheme, "https", "T02 scheme==https\0");

    // T03: host is "example.com"
    string:host = raw Url.get_host();
    drop assert_str(host, "example.com", "T03 host==example.com\0");

    // T04: port is 8080
    int32:port_val = raw Url.get_port();
    drop assert_i32(port_val, 8080i32, "T04 port==8080\0");

    // T05: path is "/api/data"
    string:path = raw Url.get_path();
    drop assert_str(path, "/api/data", "T05 path==/api/data\0");

    // T06: query is "key=val&x=1"
    string:query = raw Url.get_query();
    drop assert_str(query, "key=val&x=1", "T06 query==key=val&x=1\0");

    // T07: fragment is "section"
    string:frag = raw Url.get_fragment();
    drop assert_str(frag, "section", "T07 fragment==section\0");

    // T08: parse URL with no port — port returns 0 or -1 (not 8080)
    int32:p2 = raw Url.parse("http://example.org/path\0");
    drop assert_i32(p2, 1i32, "T08 parse no-port URL succeeds\0");

    // T09: scheme after re-parse is "http"
    string:scheme2 = raw Url.get_scheme();
    drop assert_str(scheme2, "http", "T09 re-parse scheme==http\0");

    // T10: encode converts spaces to %20
    string:enc = raw Url.encode("hello world");
    drop assert_str(enc, "hello%20world", "T10 encode space->%20\0");

    // T11: decode converts %20 back to space
    string:dec = raw Url.decode("hello%20world");
    drop assert_str(dec, "hello world", "T11 decode %20->space\0");

    // T12: encode+decode round-trip
    string:orig = "foo bar+baz";
    string:enc2 = raw Url.encode(orig);
    string:dec2 = raw Url.decode(enc2);
    drop assert_str(dec2, "foo bar+baz", "T12 encode+decode round-trip\0");

    // T13: parse empty string fails (returns 0)
    int32:e = raw Url.parse("\0");
    drop assert_i32(e, 0i32, "T13 parse empty fails\0");

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("--- ALL 13 TESTS PASSED ---\n\0"));
    exit 0i32;
};
