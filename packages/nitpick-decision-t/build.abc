[project]
name = "nitpick-decision-t"
version = "0.1.0"

[target.nitpick-decision-t]
type = "library"
sources = ["src/nitpick_decision_t.npk"]
deps = []
flags = ["-L../../../nitpick-libc/shim", "-lnitpick_libc_mem"]

[target.test-nitpick-decision-t]
type = "binary"
sources = ["tests/test_nitpick_decision_t.npk"]
deps = []
flags = ["-I", "src", "-I", "../nitpick-str/src", "-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_io"]
