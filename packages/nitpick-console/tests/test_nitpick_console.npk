// test_nitpick_console.npk — 12-test suite for nitpick-console (v0.11.2)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_console.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    
    
    int64:bus = raw Console.init();

    // T01: zone RAM (addr 100 => zone 0)
    int32:z1 = raw Console.zone(100i32);
    if (z1 == 0i32) { println("[PASS] T01 zone RAM");  }
    if (z1 != 0i32) { println("[FAIL] T01"); }

    // T02: zone VRAM (addr 20000 => zone 5)
    int32:z2 = raw Console.zone(20000i32);
    if (z2 == 5i32) { println("[PASS] T02 zone VRAM");  }
    if (z2 != 5i32) { println("[FAIL] T02"); }

    // T03: zone ROM (addr 40000 => zone 6)
    int32:z3 = raw Console.zone(40000i32);
    if (z3 == 6i32) { println("[PASS] T03 zone ROM");  }
    if (z3 != 6i32) { println("[FAIL] T03"); }

    // T04: write/read byte
    int32:w4 = raw Console.write(bus, 500i32, 0xABi32);
    int32:r4 = raw Console.read(bus, 500i32);
    if (r4 == 0xABi32) { println("[PASS] T04 write/read");  }
    if (r4 != 0xABi32) { println("[FAIL] T04"); }

    // T05: write16/read16
    int32:w5 = raw Console.write16(bus, 600i32, 0x1234i32);
    int32:r5 = raw Console.read16(bus, 600i32);
    if (r5 == 0x1234i32) { println("[PASS] T05 write16/read16");  }
    if (r5 != 0x1234i32) { println("[FAIL] T05"); }

    // T06: fill region
    int32:f6 = raw Console.fill(bus, 1000i32, 10i32, 0xFFi32);
    int32:r6 = raw Console.read(bus, 1005i32);
    if (r6 == 0xFFi32) { println("[PASS] T06 fill");  }
    if (r6 != 0xFFi32) { println("[FAIL] T06"); }

    // T07: reset clears data
    int32:rs7 = raw Console.reset(bus);
    int32:r7 = raw Console.read(bus, 500i32);
    if (r7 == 0i32) { println("[PASS] T07 reset");  }
    if (r7 != 0i32) { println("[FAIL] T07"); }

    // T08: is_valid for valid address
    int32:v8 = raw Console.is_valid(100i32);
    if (v8 == 1i32) { println("[PASS] T08 is_valid");  }
    if (v8 != 1i32) { println("[FAIL] T08"); }

    // T09: is_valid for invalid address (65536)
    int32:v9 = raw Console.is_valid(65536i32);
    if (v9 == 0i32) { println("[PASS] T09 invalid addr");  }
    if (v9 != 0i32) { println("[FAIL] T09"); }

    // T10: ms_to_frame
    int32:f10 = raw Console.ms_to_frame(33i32);
    if (f10 == 2i32) { println("[PASS] T10 ms_to_frame");  }
    if (f10 != 2i32) { println("[FAIL] T10"); }

    // T11: is_vblank at frame boundary (16ms = vblank region)
    int32:vb11 = raw Console.is_vblank(16i32);
    if (vb11 == 1i32) { println("[PASS] T11 is_vblank");  }
    if (vb11 != 1i32) { println("[FAIL] T11"); }

    // T12: in_zone check (addr 500 in zone 0 RAM)
    int32:iz12 = raw Console.in_zone(500i32, 0i32);
    if (iz12 == 1i32) { println("[PASS] T12 in_zone");  }
    if (iz12 != 1i32) { println("[FAIL] T12"); }

    int32:rd = raw Console.destroy(bus);
    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
