// test_nitpick_bitset.npk — 12-test suite for nitpick-bitset (v0.11.3)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_bitset.npk".*;

func:failsafe = int32(tbb32:_err) { exit 1i32; };

func:main = int32() {
    
    
    int64:bs = raw Bitset.create(32i64);

    // T01: initial count is 0
    int32:c1 = raw Bitset.count(bs);
    if (c1 == 0i32) { println("[PASS] T01 init count=0");  }
    if (c1 != 0i32) { println("[FAIL] T01"); }

    // T02: set and test
    int32:_s2 = raw Bitset.set(bs, 5i64);
    int32:g2 = raw Bitset.test(bs, 5i64);
    if (g2 == 1i32) { println("[PASS] T02 set/test");  }
    if (g2 != 1i32) { println("[FAIL] T02"); }

    // T03: unset bit reads 0
    int32:g3 = raw Bitset.test(bs, 10i64);
    if (g3 == 0i32) { println("[PASS] T03 unset=0");  }
    if (g3 != 0i32) { println("[FAIL] T03"); }

    // T04: clear
    int32:_s4 = raw Bitset.set(bs, 10i64);
    int32:_c4 = raw Bitset.clear(bs, 10i64);
    int32:g4 = raw Bitset.test(bs, 10i64);
    if (g4 == 0i32) { println("[PASS] T04 clear");  }
    if (g4 != 0i32) { println("[FAIL] T04"); }

    // T05: toggle (0→1)
    int32:_t5 = raw Bitset.toggle(bs, 20i64);
    int32:g5 = raw Bitset.test(bs, 20i64);
    if (g5 == 1i32) { println("[PASS] T05 toggle 0→1");  }
    if (g5 != 1i32) { println("[FAIL] T05"); }

    // T06: toggle (1→0)
    int32:_t6 = raw Bitset.toggle(bs, 20i64);
    int32:g6 = raw Bitset.test(bs, 20i64);
    if (g6 == 0i32) { println("[PASS] T06 toggle 1→0");  }
    if (g6 != 0i32) { println("[FAIL] T06"); }

    // T07: count after operations (bit 5 still set)
    int32:c7 = raw Bitset.count(bs);
    if (c7 == 1i32) { println("[PASS] T07 count=1");  }
    if (c7 != 1i32) { println("[FAIL] T07"); }

    // T08: size
    int64:sz8 = raw Bitset.size(bs);
    if (sz8 == 32i64) { println("[PASS] T08 size=32");  }
    if (sz8 != 32i64) { println("[FAIL] T08"); }

    // T09: union
    int64:bs2 = raw Bitset.create(32i64);
    int32:_s9 = raw Bitset.set(bs2, 0i64);
    int32:_u9 = raw Bitset.union(bs, bs2);
    int32:g9 = raw Bitset.test(bs, 0i64);
    if (g9 == 1i32) { println("[PASS] T09 union");  }
    if (g9 != 1i32) { println("[FAIL] T09"); }

    // T10: intersect
    int64:bs3 = raw Bitset.create(32i64);
    int32:_s10a = raw Bitset.set(bs3, 5i64);
    int32:_i10 = raw Bitset.intersect(bs, bs3);
    int32:g10a = raw Bitset.test(bs, 5i64);
    int32:g10b = raw Bitset.test(bs, 0i64);
    if (g10a == 1i32) { if (g10b == 0i32) { println("[PASS] T10 intersect");  } }

    // T11: complement
    int64:bs4 = raw Bitset.create(8i64);
    int32:_s11 = raw Bitset.set(bs4, 2i64);
    int32:_cp11 = raw Bitset.complement(bs4);
    int32:g11a = raw Bitset.test(bs4, 2i64);
    int32:g11b = raw Bitset.test(bs4, 0i64);
    if (g11a == 0i32) { if (g11b == 1i32) { println("[PASS] T11 complement");  } }

    // T12: equals
    int64:bsA = raw Bitset.create(8i64);
    int64:bsB = raw Bitset.create(8i64);
    int32:_sA = raw Bitset.set(bsA, 3i64);
    int32:_sB = raw Bitset.set(bsB, 3i64);
    int32:eq12 = raw Bitset.equals(bsA, bsB);
    if (eq12 == 1i32) { println("[PASS] T12 equals");  }
    if (eq12 != 1i32) { println("[FAIL] T12"); }

    int32:_d1 = raw Bitset.destroy(bs);
    int32:_d2 = raw Bitset.destroy(bs2);
    int32:_d3 = raw Bitset.destroy(bs3);
    int32:_d4 = raw Bitset.destroy(bs4);
    int32:_dA = raw Bitset.destroy(bsA);
    int32:_dB = raw Bitset.destroy(bsB);
    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
