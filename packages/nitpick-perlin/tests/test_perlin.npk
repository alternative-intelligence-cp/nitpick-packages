// test_perlin.npk

extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_perlin.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    drop(println("Testing nitpick-perlin...\n"));

    drop(noise_set_seed(42i32));

    flt64:val1 = raw perlin_2d(0.5f64, 0.5f64);
    flt64:val2 = raw perlin_3d(0.5f64, 0.5f64, 0.5f64);
    flt64:val3 = raw simplex_2d(0.5f64, 0.5f64);

    drop(println("Perlin / Simplex generated!\n"));

    // Ensure they return different values at different coordinates
    flt64:val4 = raw perlin_2d(1.5f64, 0.5f64);
    if (val4 == val1) {
        drop(println("ERROR: Perlin 2D returned identical values for different coords!\n"));
        exit 1;
    }

    drop(println("SUCCESS: All tests passed.\n"));
    exit 0;
};
