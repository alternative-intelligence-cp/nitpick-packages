// test_nitpick_smtp.npk — 12-test suite for nitpick-smtp (v0.12.2)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_smtp.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq_i64 = int64(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:assert_eq_str = int64(string:actual, string:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:test_create_greet = int32() {
    int64:h = raw SMTP.init();
    
    int64:t1 = 0i64;
    if (h > 0i64) { t1 = 1i64; }
    drop assert_eq_i64(t1, 1i64, "T01 smtp_create\0");

    string:c2 = raw SMTP.ehlo(h, "mail.example.com");
    int64:t2 = 0i64;
    if (string_contains(c2, "EHLO mail.example.com")) { t2 = 1i64; }
    drop assert_eq_i64(t2, 1i64, "T02 cmd_ehlo\0");

    string:c3 = raw SMTP.mail_from(h, "alice@example.com");
    int64:t3 = 0i64;
    if (string_contains(c3, "MAIL FROM:<alice@example.com>")) { t3 = 1i64; }
    drop assert_eq_i64(t3, 1i64, "T03 cmd_mail_from\0");

    pass 0i32;
};

func:test_envelope = int32() {
    int64:h = raw SMTP.init();

    string:c4 = raw SMTP.rcpt_to(h, "bob@example.com");
    int64:t4 = 0i64;
    if (string_contains(c4, "RCPT TO:<bob@example.com>")) { t4 = 1i64; }
    drop assert_eq_i64(t4, 1i64, "T04 cmd_rcpt_to\0");

    string:c5 = raw SMTP.data(h);
    int64:t5 = 0i64;
    if (string_contains(c5, "DATA")) { t5 = 1i64; }
    drop assert_eq_i64(t5, 1i64, "T05 cmd_data\0");

    string:c6 = raw SMTP.bye(h);
    int64:t6 = 0i64;
    if (string_contains(c6, "QUIT")) { t6 = 1i64; }
    drop assert_eq_i64(t6, 1i64, "T06 cmd_quit\0");

    pass 0i32;
};

func:test_misc_cmds = int32() {
    int64:h = raw SMTP.init();

    string:c7 = raw SMTP.reset(h);
    int64:t7 = 0i64;
    if (string_contains(c7, "RSET")) { t7 = 1i64; }
    drop assert_eq_i64(t7, 1i64, "T07 cmd_rset\0");

    string:c8 = raw SMTP.noop(h);
    int64:t8 = 0i64;
    if (string_contains(c8, "NOOP")) { t8 = 1i64; }
    drop assert_eq_i64(t8, 1i64, "T08 cmd_noop\0");

    string:msg9 = raw SMTP.compose(h, "alice@example.com", "bob@example.com", "Hello", "Hi Bob!");
    int64:t9 = 0i64;
    if (string_contains(msg9, "Subject: Hello")) { t9 = 1i64; }
    drop assert_eq_i64(t9, 1i64, "T09 build_message subject\0");

    pass 0i32;
};

func:test_parse_reply = int32() {
    int64:h = raw SMTP.init();

    drop raw SMTP.parse(h, "250 OK");
    string:code10 = raw SMTP.code(h);
    int64:t10 = 0i64;
    if (string_contains(code10, "250")) { t10 = 1i64; }
    drop assert_eq_i64(t10, 1i64, "T10 reply_code=250\0");

    string:msg11 = raw SMTP.msg(h);
    int64:t11 = 0i64;
    if (string_contains(msg11, "OK")) { t11 = 1i64; }
    drop assert_eq_i64(t11, 1i64, "T11 reply_msg=OK\0");

    drop raw SMTP.parse(h, "550 Mailbox not found");
    string:code12 = raw SMTP.code(h);
    int64:t12 = 0i64;
    if (string_contains(code12, "550")) { t12 = 1i64; }
    drop assert_eq_i64(t12, 1i64, "T12 reply_code=550\0");

    pass 0i32;
};

func:main = int32() {
    drop raw test_create_greet();
    drop raw test_envelope();
    drop raw test_misc_cmds();
    drop raw test_parse_reply();

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    
    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
