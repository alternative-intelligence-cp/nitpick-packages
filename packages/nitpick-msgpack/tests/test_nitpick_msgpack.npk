// test_nitpick_msgpack.npk — 12-test suite for nitpick-msgpack (v0.11.2)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_msgpack.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    
    
    int64:buf = raw MsgPack.create(256i64);

    // T01: initial length is 0
    int64:len1 = raw MsgPack.length(buf);
    if (len1 == 0i64) { println("[PASS] T01 init len=0");  }
    if (len1 != 0i64) { println("[FAIL] T01"); }

    // T02: encode nil (tag 0xc0 = 192)
    int32:r2 = raw MsgPack.encode_nil(buf);
    int32:tag2 = raw MsgPack.read_tag(buf, 0i64);
    if (tag2 == 192i32) { println("[PASS] T02 nil=0xc0");  }
    if (tag2 != 192i32) { println("[FAIL] T02"); }

    // T03: is_nil at position 0
    int32:n3 = raw MsgPack.is_nil(buf, 0i64);
    if (n3 == 1i32) { println("[PASS] T03 is_nil");  }
    if (n3 != 1i32) { println("[FAIL] T03"); }

    // T04: encode true (tag 0xc3 = 195)
    int32:r4 = raw MsgPack.encode_bool(buf, 1i32);
    int32:tag4 = raw MsgPack.read_tag(buf, 1i64);
    if (tag4 == 195i32) { println("[PASS] T04 true=0xc3");  }
    if (tag4 != 195i32) { println("[FAIL] T04"); }

    // T05: decode_bool at position 1
    int32:d5 = raw MsgPack.decode_bool(buf, 1i64);
    if (d5 == 1i32) { println("[PASS] T05 decode_bool=1");  }
    if (d5 != 1i32) { println("[FAIL] T05"); }

    // T06: encode false (tag 0xc2 = 194)
    int32:r6 = raw MsgPack.encode_bool(buf, 0i32);
    int32:tag6 = raw MsgPack.read_tag(buf, 2i64);
    if (tag6 == 194i32) { println("[PASS] T06 false=0xc2");  }
    if (tag6 != 194i32) { println("[FAIL] T06"); }

    // T07: encode/decode positive fixint (42)
    int32:r7 = raw MsgPack.encode_int(buf, 42i32);
    int32:d7 = raw MsgPack.decode_int(buf, 3i64);
    if (d7 == 42i32) { println("[PASS] T07 fixint=42");  }
    if (d7 != 42i32) { println("[FAIL] T07"); }

    // T08: encode/decode negative fixint (-5)
    int32:r8 = raw MsgPack.encode_nint(buf, -5i32);
    int32:d8 = raw MsgPack.decode_nint(buf, 4i64);
    if (d8 == -5i32) { println("[PASS] T08 nfixint=-5");  }
    if (d8 != -5i32) { println("[FAIL] T08"); }

    // T09: length after 5 encodes (nil+true+false+42+(-5) = 5 bytes)
    int64:len9 = raw MsgPack.length(buf);
    if (len9 == 5i64) { println("[PASS] T09 len=5");  }
    if (len9 != 5i64) { println("[FAIL] T09"); }

    // T10: capacity
    int64:cap10 = raw MsgPack.capacity(buf);
    if (cap10 == 256i64) { println("[PASS] T10 cap=256");  }
    if (cap10 != 256i64) { println("[FAIL] T10"); }

    // T11: encode/decode i32 (1000)
    int32:r11 = raw MsgPack.encode_i32(buf, 1000i32);
    int32:d11 = raw MsgPack.decode_i32(buf, 5i64);
    if (d11 == 1000i32) { println("[PASS] T11 i32=1000");  }
    if (d11 != 1000i32) { println("[FAIL] T11"); }

    // T12: encode_str + decode_str_len
    int32:r12 = raw MsgPack.encode_str(buf, "hi");
    // str at offset 10 (5 bytes + 5 bytes for i32 encoding)
    int64:spos = raw MsgPack.length(buf);
    // str_len of "hi" should be 2
    int32:slen = raw MsgPack.decode_str_len(buf, 10i64);
    if (slen == 2i32) { println("[PASS] T12 str_len=2");  }
    if (slen != 2i32) { println("[FAIL] T12"); }

    int32:rd = raw MsgPack.destroy(buf);
    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
