// test_nitpick_math.npk — LIB-1 test suite (23 tests, all 18 libm functions)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_math.npk".*;
//
// Build: aria_make and run .npk_make/build/test-nitpick-math
// (build.abc compiles both nitpick_math.npk and this file together, -lm)
//
// Testing strategy: call extern libm functions directly with literal
// constant arguments.  LLVM constant-folds all known math intrinsics
// (sin, cos, sqrt, pow, exp, log, etc.) at compile time, producing
// correct pass/fail strings as constants.  This verifies the function
// signatures, extern linkage, and LLVM IR correctness for all 18
// functions.
//
// Bugs #16-#19: ALL RESOLVED. Full float64 param/return and extern coverage enabled.

func:failsafe = int32(tbb32:err) { exit 1; };

// Extern declarations (also declared in nitpick_math.npk; duplicates are fine).
// Note: fabs, acos, fmod now covered — Bugs #18/#19 resolved.



















func:main = int32() {
    int32:pass_count = 0i32;
    float64:eps = 0.000001;
    float64:E   = 2.718281828459045;

    int64:passed = 0i64;
    int64:failed = 0i64;

    drop(println("nitpick-math -- LIB-1"));
    drop(println("==================="));

    // ── trig ─────────────────────────────────────────────────────────────────

    // test 01: sin(0) = 0
    float64:r01 = sin(0.0);
    float64:d01a = r01 - 0.0; float64:d01b = 0.0 - r01;
    int64:c01 = 1i64;
    if (eps < d01a) { c01 = 0i64; }
    if (eps < d01b) { c01 = 0i64; }
    if (c01 == 1i64) { passed = passed + 1i64; drop(println("[PASS] sin(0) = 0")); }
    if (c01 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] sin(0) = 0")); }

    // test 02: cos(0) = 1
    float64:r02 = cos(0.0);
    float64:d02a = r02 - 1.0; float64:d02b = 1.0 - r02;
    int64:c02 = 1i64;
    if (eps < d02a) { c02 = 0i64; }
    if (eps < d02b) { c02 = 0i64; }
    if (c02 == 1i64) { passed = passed + 1i64; drop(println("[PASS] cos(0) = 1")); }
    if (c02 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] cos(0) = 1")); }

    // test 03: tan(0) = 0
    float64:r03 = tan(0.0);
    float64:d03a = r03 - 0.0; float64:d03b = 0.0 - r03;
    int64:c03 = 1i64;
    if (eps < d03a) { c03 = 0i64; }
    if (eps < d03b) { c03 = 0i64; }
    if (c03 == 1i64) { passed = passed + 1i64; drop(println("[PASS] tan(0) = 0")); }
    if (c03 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] tan(0) = 0")); }

    // test 04: asin(0) = 0
    float64:r04 = asin(0.0);
    float64:d04a = r04 - 0.0; float64:d04b = 0.0 - r04;
    int64:c04 = 1i64;
    if (eps < d04a) { c04 = 0i64; }
    if (eps < d04b) { c04 = 0i64; }
    if (c04 == 1i64) { passed = passed + 1i64; drop(println("[PASS] asin(0) = 0")); }
    if (c04 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] asin(0) = 0")); }

    // test 05: cos(PI) = -1  (note: acos/fabs/fmod skipped — Bug #19)
    float64:neg1 = 0.0 - 1.0;
    float64:r05 = cos(3.141592653589793);
    float64:d05a = r05 - neg1; float64:d05b = neg1 - r05;
    int64:c05 = 1i64;
    if (eps < d05a) { c05 = 0i64; }
    if (eps < d05b) { c05 = 0i64; }
    if (c05 == 1i64) { passed = passed + 1i64; drop(println("[PASS] cos(PI) = -1")); }
    if (c05 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] cos(PI) = -1")); }

    // test 06: atan(0) = 0
    float64:r06 = atan(0.0);
    float64:d06a = r06 - 0.0; float64:d06b = 0.0 - r06;
    int64:c06 = 1i64;
    if (eps < d06a) { c06 = 0i64; }
    if (eps < d06b) { c06 = 0i64; }
    if (c06 == 1i64) { passed = passed + 1i64; drop(println("[PASS] atan(0) = 0")); }
    if (c06 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] atan(0) = 0")); }

    // test 07: atan2(0, 1) = 0
    float64:r07 = atan2(0.0, 1.0);
    float64:d07a = r07 - 0.0; float64:d07b = 0.0 - r07;
    int64:c07 = 1i64;
    if (eps < d07a) { c07 = 0i64; }
    if (eps < d07b) { c07 = 0i64; }
    if (c07 == 1i64) { passed = passed + 1i64; drop(println("[PASS] atan2(0,1) = 0")); }
    if (c07 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] atan2(0,1) = 0")); }

    // ── sqrt / pow ───────────────────────────────────────────────────────────

    // test 08: sqrt(4) = 2
    float64:r08 = sqrt(4.0);
    float64:d08a = r08 - 2.0; float64:d08b = 2.0 - r08;
    int64:c08 = 1i64;
    if (eps < d08a) { c08 = 0i64; }
    if (eps < d08b) { c08 = 0i64; }
    if (c08 == 1i64) { passed = passed + 1i64; drop(println("[PASS] sqrt(4) = 2")); }
    if (c08 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] sqrt(4) = 2")); }

    // test 09: sqrt(9) = 3
    float64:r09 = sqrt(9.0);
    float64:d09a = r09 - 3.0; float64:d09b = 3.0 - r09;
    int64:c09 = 1i64;
    if (eps < d09a) { c09 = 0i64; }
    if (eps < d09b) { c09 = 0i64; }
    if (c09 == 1i64) { passed = passed + 1i64; drop(println("[PASS] sqrt(9) = 3")); }
    if (c09 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] sqrt(9) = 3")); }

    // test 10: pow(2, 10) = 1024
    float64:r10 = pow(2.0, 10.0);
    float64:d10a = r10 - 1024.0; float64:d10b = 1024.0 - r10;
    int64:c10 = 1i64;
    if (eps < d10a) { c10 = 0i64; }
    if (eps < d10b) { c10 = 0i64; }
    if (c10 == 1i64) { passed = passed + 1i64; drop(println("[PASS] pow(2,10) = 1024")); }
    if (c10 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] pow(2,10) = 1024")); }

    // test 11: pow(3, 0) = 1
    float64:r11 = pow(3.0, 0.0);
    float64:d11a = r11 - 1.0; float64:d11b = 1.0 - r11;
    int64:c11 = 1i64;
    if (eps < d11a) { c11 = 0i64; }
    if (eps < d11b) { c11 = 0i64; }
    if (c11 == 1i64) { passed = passed + 1i64; drop(println("[PASS] pow(3,0) = 1")); }
    if (c11 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] pow(3,0) = 1")); }

    // ── exp / log ────────────────────────────────────────────────────────────

    // test 12: exp(0) = 1
    float64:r12 = exp(0.0);
    float64:d12a = r12 - 1.0; float64:d12b = 1.0 - r12;
    int64:c12 = 1i64;
    if (eps < d12a) { c12 = 0i64; }
    if (eps < d12b) { c12 = 0i64; }
    if (c12 == 1i64) { passed = passed + 1i64; drop(println("[PASS] exp(0) = 1")); }
    if (c12 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] exp(0) = 1")); }

    // test 13: log(e) = 1
    float64:r13 = log(E);
    float64:d13a = r13 - 1.0; float64:d13b = 1.0 - r13;
    int64:c13 = 1i64;
    if (eps < d13a) { c13 = 0i64; }
    if (eps < d13b) { c13 = 0i64; }
    if (c13 == 1i64) { passed = passed + 1i64; drop(println("[PASS] log(e) = 1")); }
    if (c13 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] log(e) = 1")); }

    // test 14: log2(8) = 3
    float64:r14 = log2(8.0);
    float64:d14a = r14 - 3.0; float64:d14b = 3.0 - r14;
    int64:c14 = 1i64;
    if (eps < d14a) { c14 = 0i64; }
    if (eps < d14b) { c14 = 0i64; }
    if (c14 == 1i64) { passed = passed + 1i64; drop(println("[PASS] log2(8) = 3")); }
    if (c14 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] log2(8) = 3")); }

    // test 15: log10(100) = 2
    float64:r15 = log10(100.0);
    float64:d15a = r15 - 2.0; float64:d15b = 2.0 - r15;
    int64:c15 = 1i64;
    if (eps < d15a) { c15 = 0i64; }
    if (eps < d15b) { c15 = 0i64; }
    if (c15 == 1i64) { passed = passed + 1i64; drop(println("[PASS] log10(100) = 2")); }
    if (c15 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] log10(100) = 2")); }

    // ── abs / floor / ceil / round / fmod ────────────────────────────────────

    // test 16: sin(PI/2) = 1
    float64:r16 = sin(1.5707963267948966);
    float64:d16a = r16 - 1.0; float64:d16b = 1.0 - r16;
    int64:c16 = 1i64;
    if (eps < d16a) { c16 = 0i64; }
    if (eps < d16b) { c16 = 0i64; }
    if (c16 == 1i64) { passed = passed + 1i64; drop(println("[PASS] sin(PI/2) = 1")); }
    if (c16 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] sin(PI/2) = 1")); }

    // test 17: floor(2.9) = 2
    float64:r17 = floor(2.9);
    float64:d17a = r17 - 2.0; float64:d17b = 2.0 - r17;
    int64:c17 = 1i64;
    if (eps < d17a) { c17 = 0i64; }
    if (eps < d17b) { c17 = 0i64; }
    if (c17 == 1i64) { passed = passed + 1i64; drop(println("[PASS] floor(2.9) = 2")); }
    if (c17 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] floor(2.9) = 2")); }

    // test 18: ceil(2.1) = 3
    float64:r18 = ceil(2.1);
    float64:d18a = r18 - 3.0; float64:d18b = 3.0 - r18;
    int64:c18 = 1i64;
    if (eps < d18a) { c18 = 0i64; }
    if (eps < d18b) { c18 = 0i64; }
    if (c18 == 1i64) { passed = passed + 1i64; drop(println("[PASS] ceil(2.1) = 3")); }
    if (c18 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] ceil(2.1) = 3")); }

    // test 19: round(2.5) = 3
    float64:r19 = round(2.5);
    float64:d19a = r19 - 3.0; float64:d19b = 3.0 - r19;
    int64:c19 = 1i64;
    if (eps < d19a) { c19 = 0i64; }
    if (eps < d19b) { c19 = 0i64; }
    if (c19 == 1i64) { passed = passed + 1i64; drop(println("[PASS] round(2.5) = 3")); }
    if (c19 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] round(2.5) = 3")); }

    // test 20: exp(1) = e
    float64:r20 = exp(1.0);
    float64:d20a = r20 - E; float64:d20b = E - r20;
    int64:c20 = 1i64;
    if (eps < d20a) { c20 = 0i64; }
    if (eps < d20b) { c20 = 0i64; }
    if (c20 == 1i64) { passed = passed + 1i64; drop(println("[PASS] exp(1) = e")); }
    if (c20 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] exp(1) = e")); }

    // ── fabs / acos / fmod (previously skipped, now enabled) ─────────────────

    // test 21: fabs(-3.14) = 3.14
    float64:r21 = fabs(0.0 - 3.14);
    float64:d21a = r21 - 3.14; float64:d21b = 3.14 - r21;
    int64:c21 = 1i64;
    if (eps < d21a) { c21 = 0i64; }
    if (eps < d21b) { c21 = 0i64; }
    if (c21 == 1i64) { passed = passed + 1i64; drop(println("[PASS] fabs(-3.14) = 3.14")); }
    if (c21 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] fabs(-3.14) = 3.14")); }

    // test 22: acos(1.0) = 0
    float64:r22 = acos(1.0);
    float64:d22a = r22 - 0.0; float64:d22b = 0.0 - r22;
    int64:c22 = 1i64;
    if (eps < d22a) { c22 = 0i64; }
    if (eps < d22b) { c22 = 0i64; }
    if (c22 == 1i64) { passed = passed + 1i64; drop(println("[PASS] acos(1) = 0")); }
    if (c22 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] acos(1) = 0")); }

    // test 23: fmod(7.5, 2.5) = 0
    float64:r23 = fmod(7.5, 2.5);
    float64:d23a = r23 - 0.0; float64:d23b = 0.0 - r23;
    int64:c23 = 1i64;
    if (eps < d23a) { c23 = 0i64; }
    if (eps < d23b) { c23 = 0i64; }
    if (c23 == 1i64) { passed = passed + 1i64; drop(println("[PASS] fmod(7.5, 2.5) = 0")); }
    if (c23 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] fmod(7.5, 2.5) = 0")); }

    // ── summary ──────────────────────────────────────────────────────────────

    drop(println("---"));
    if (failed == 0i64) {
        drop(println("PASS: all 23 nitpick-math tests passed"));
        exit(0i32);
    }
    drop(println("FAIL: some nitpick-math tests failed"));
    exit(1i32);
};
