[project]
name = "nitpick-json"
version = "0.2.0"

[target.nitpick-json]
type = "library"
sources = ["src/nitpick_json.npk"]
deps = []
flags = ["-L.", "-lnitpick_json_shim"]

[target.test-nitpick-json]
type = "binary"
sources = ["tests/test_nitpick_json.npk"]
deps = []
flags = ["-I", "src", "-L.", "-lnitpick_json_shim"]
