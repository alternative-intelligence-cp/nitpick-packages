// test_nitpick_json.npk — LIB-22  test suite
//
// 20 deterministic tests covering all token types and edge cases.
//
// Token type reference:
//   0=EOF  1={  2=}  3=[  4=]  5=:  6=,  7=STRING  8=NUMBER  9=TRUE  10=FALSE  11=NULL

extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_json.npk".*;
use "stdlib/print_utils.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    string:doc = "{\"user\": {\"name\": \"Alice\", \"age\": 30, \"active\": true}, \"tags\": [\"admin\", \"user\"]}";
    int32:res = raw json_parse(doc);
    if (res == 1i32) {
        drop(println("PASS: DOM parser success"));
    } else {
        drop(println("FAIL: DOM parser failed"));
        exit 1;
    }

    string:name = raw json_get_string("user.name");
    if (string_equals(name, "Alice")) {
        drop(println("PASS: json_get_string"));
    } else {
        drop(println("FAIL: json_get_string"));
        exit 1;
    }

    int64:age = raw json_get_int("user.age");
    if (age == 30i64) {
        drop(println("PASS: json_get_int"));
    } else {
        drop(println("FAIL: json_get_int"));
        exit 1;
    }

    int32:active = raw json_get_bool("user.active");
    if (active == 1i32) {
        drop(println("PASS: json_get_bool"));
    } else {
        drop(println("FAIL: json_get_bool"));
        exit 1;
    }

    int32:tag_count = raw json_array_count("tags");
    if (tag_count == 2i32) {
        drop(println("PASS: json_array_count"));
    } else {
        drop(println("FAIL: json_array_count"));
        exit 1;
    }

    string:tag0 = raw json_get_string("tags.0");
    if (string_equals(tag0, "admin")) {
        drop(println("PASS: json_get_string array index"));
    } else {
        drop(println("FAIL: json_get_string array index"));
        exit 1;
    }

    drop(println("PASS: all tests passed"));
    exit 0;
};
