extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "nitpick_uuid.npk".*;
extern "libc" { func:printf = int32(string:fmt); }

int32:fail_cnt = 0i32;
func:failsafe = int32(tbb32:err) { drop(err); exit 1i32; };

func:main = int32() {
    int32:pass_count = 0i32;
    // Declare all uint128 constants upfront via VarDecl (safe path through ir_generator).
    // This avoids passing u128 literals inline to pub func calls or using them in
    // direct comparisons, both of which crash due to LBIM type mismatch.
    uint128:n0      = 0u128;
    uint128:n1      = 1u128;
    uint128:n2      = 2u128;
    uint128:n3      = 3u128;
    uint128:n5      = 5u128;
    uint128:n7      = 7u128;
    uint128:n8      = 8u128;
    uint128:n10     = 10u128;
    uint128:n21     = 21u128;
    uint128:n42a    = 42u128;
    uint128:n42b    = 42u128;
    uint128:n99     = 99u128;
    uint128:n100    = 100u128;
    uint128:n2e64p2 = 18446744073709551618u128;

    // T01: uuid_nil() == 0
    uint128:r01 = raw Uuid.nil();
    uint64:f01 = raw Uuid.eq(r01, n0);
    if (f01 == 1u64) { drop(printf("[PASS] T01 uuid_nil()==0\n\0")); }
    if (f01 == 0u64) { drop(printf("[FAIL] T01 uuid_nil()==0\n\0")); }

    // T02: uuid_one() == 1
    uint128:r02 = raw Uuid.one();
    uint64:f02 = raw Uuid.eq(r02, n1);
    if (f02 == 1u64) { drop(printf("[PASS] T02 uuid_one()==1\n\0")); }
    if (f02 == 0u64) { drop(printf("[FAIL] T02 uuid_one()==1\n\0")); }

    // T03: uuid_step(0) == 1
    uint128:r03 = raw Uuid.step(n0);
    uint64:f03 = raw Uuid.eq(r03, n1);
    if (f03 == 1u64) { drop(printf("[PASS] T03 uuid_step(0)==1\n\0")); }
    if (f03 == 0u64) { drop(printf("[FAIL] T03 uuid_step(0)==1\n\0")); }

    // T04: uuid_step(99) == 100
    uint128:r04 = raw Uuid.step(n99);
    uint64:f04 = raw Uuid.eq(r04, n100);
    if (f04 == 1u64) { drop(printf("[PASS] T04 uuid_step(99)==100\n\0")); }
    if (f04 == 0u64) { drop(printf("[FAIL] T04 uuid_step(99)==100\n\0")); }

    // T05: uuid_double(5) == 10
    uint128:r05 = raw Uuid.double(n5);
    uint64:f05 = raw Uuid.eq(r05, n10);
    if (f05 == 1u64) { drop(printf("[PASS] T05 uuid_double(5)==10\n\0")); }
    if (f05 == 0u64) { drop(printf("[FAIL] T05 uuid_double(5)==10\n\0")); }

    // T06: uuid_sum(3, 5) == 8
    uint128:r06 = raw Uuid.sum(n3, n5);
    uint64:f06 = raw Uuid.eq(r06, n8);
    if (f06 == 1u64) { drop(printf("[PASS] T06 uuid_sum(3,5)==8\n\0")); }
    if (f06 == 0u64) { drop(printf("[FAIL] T06 uuid_sum(3,5)==8\n\0")); }

    // T07: uuid_pack(1, 2) == 2^64 + 2
    uint128:r07 = raw Uuid.pack(n1, n2);
    uint64:f07 = raw Uuid.eq(r07, n2e64p2);
    if (f07 == 1u64) { drop(printf("[PASS] T07 uuid_pack(1,2)==2^64+2\n\0")); }
    if (f07 == 0u64) { drop(printf("[FAIL] T07 uuid_pack(1,2)==2^64+2\n\0")); }

    // T08: uuid_unpack_hi(2^64+2) == 1
    uint128:r08 = raw Uuid.unpack_hi(n2e64p2);
    uint64:f08 = raw Uuid.eq(r08, n1);
    if (f08 == 1u64) { drop(printf("[PASS] T08 uuid_unpack_hi==1\n\0")); }
    if (f08 == 0u64) { drop(printf("[FAIL] T08 uuid_unpack_hi==1\n\0")); }

    // T09: uuid_unpack_lo(2^64+2) == 2
    uint128:r09 = raw Uuid.unpack_lo(n2e64p2);
    uint64:f09 = raw Uuid.eq(r09, n2);
    if (f09 == 1u64) { drop(printf("[PASS] T09 uuid_unpack_lo==2\n\0")); }
    if (f09 == 0u64) { drop(printf("[FAIL] T09 uuid_unpack_lo==2\n\0")); }

    // T10: uuid_gt(5, 3) == 1 (5 > 3)
    uint64:r10 = raw Uuid.gt(n5, n3);
    uint64:f10 = 0u64; if (r10 == 1u64) { f10 = 1u64; }
    if (f10 == 1u64) { drop(printf("[PASS] T10 uuid_gt(5,3)==1\n\0")); }
    if (f10 == 0u64) { drop(printf("[FAIL] T10 uuid_gt(5,3)==1\n\0")); }

    // T11: uuid_lt(3, 5) == 1 (3 < 5)
    uint64:r11 = raw Uuid.lt(n3, n5);
    uint64:f11 = 0u64; if (r11 == 1u64) { f11 = 1u64; }
    if (f11 == 1u64) { drop(printf("[PASS] T11 uuid_lt(3,5)==1\n\0")); }
    if (f11 == 0u64) { drop(printf("[FAIL] T11 uuid_lt(3,5)==1\n\0")); }

    // T12: uuid_eq(42, 42) == 1
    uint64:r12 = raw Uuid.eq(n42a, n42b);
    uint64:f12 = 0u64; if (r12 == 1u64) { f12 = 1u64; }
    if (f12 == 1u64) { drop(printf("[PASS] T12 uuid_eq(42,42)==1\n\0")); }
    if (f12 == 0u64) { drop(printf("[FAIL] T12 uuid_eq(42,42)==1\n\0")); }

    // T13: uuid_gt(3, 5) == 0 (3 NOT > 5)
    uint64:r13 = raw Uuid.gt(n3, n5);
    uint64:f13 = 0u64; if (r13 == 0u64) { f13 = 1u64; }
    if (f13 == 1u64) { drop(printf("[PASS] T13 uuid_gt(3,5)==0\n\0")); }
    if (f13 == 0u64) { drop(printf("[FAIL] T13 uuid_gt(3,5)==0\n\0")); }

    // T14: uuid_eq(3, 5) == 0 (3 != 5)
    uint64:r14 = raw Uuid.eq(n3, n5);
    uint64:f14 = 0u64; if (r14 == 0u64) { f14 = 1u64; }
    if (f14 == 1u64) { drop(printf("[PASS] T14 uuid_eq(3,5)==0\n\0")); }
    if (f14 == 0u64) { drop(printf("[FAIL] T14 uuid_eq(3,5)==0\n\0")); }

    // T15: uuid_product(3, 7) == 21
    uint128:r15 = raw Uuid.product(n3, n7);
    uint64:f15 = raw Uuid.eq(r15, n21);
    if (f15 == 1u64) { drop(printf("[PASS] T15 uuid_product(3,7)==21\n\0")); }
    if (f15 == 0u64) { drop(printf("[FAIL] T15 uuid_product(3,7)==21\n\0")); }

    
    drop(printf("---\n\0"));
    
        drop(printf("PASS: all tests passed\n\0"));
    if (fail_cnt > 0i32) {
        drop(printf("FAIL: tests failed\n\0"));
    }
    exit fail_cnt;
};
