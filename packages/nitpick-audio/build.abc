[project]
name = "nitpick-audio"
version = "0.2.0"

[target.nitpick-audio]
type = "library"
sources = ["src/nitpick_audio.npk"]
deps = []
flags = ["-lSDL2", "-lasound", "-L", "shim", "-lnitpick_audio_shim"]

[target.test-nitpick-audio]
type = "binary"
sources = ["tests/test_nitpick_audio.npk"]
deps = []
flags = ["-lSDL2", "-lasound", "-L", "shim", "-lnitpick_audio_shim", "-I", "src"]
