use "../src/nitpick_llama.npk".*;
use "../src/ops.npk".*;
func:main = int32() {
    drop(llama_init_example());
    int64:n = 5i64;
    flt32->:x = alloc(5 * 4i64) => flt32->;
    flt32->:y = alloc(5 * 4i64) => flt32->;
    x[0i64] = -0.8233930203769775f32;
    y[0i64] = -0.6146049975378995f32;
    x[1i64] = 0.7569073648487872f32;
    y[1i64] = -0.19557955609415578f32;
    x[2i64] = 0.8109341578799898f32;
    y[2i64] = 0.8902189565236274f32;
    x[3i64] = -0.23637847869418493f32;
    y[3i64] = -0.6098629357996384f32;
    x[4i64] = -0.5962011327698598f32;
    y[4i64] = -0.4696446305616233f32;
    flt32->:sum_ptr = alloc(4i64) => flt32->;
    sum_ptr[0i64] = 0.0f32;
    drop(ggml_vec_dot_f32(n, sum_ptr, x, y));
    flt32:sum = sum_ptr[0i64];
    flt32:expected = 1.5040959523936939f32;
    flt32:diff = sum - expected;
    if (diff < 0.0f32) { diff = 0.0f32 - diff; }
    if (diff > 0.01f32) { exit(1i32); }
