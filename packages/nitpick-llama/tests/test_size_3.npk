use "../src/nitpick_llama.npk".*;
use "../src/ops.npk".*;
func:main = int32() {
    drop(llama_init_example());
    int64:n = 3i64;
    flt32->:x = alloc(3 * 4i64) => flt32->;
    flt32->:y = alloc(3 * 4i64) => flt32->;
    x[0i64] = -0.3937591243729375f32;
    y[0i64] = -0.7583611388379541f32;
    x[1i64] = 0.8285027583748694f32;
    y[1i64] = -0.4230083729424572f32;
    x[2i64] = -0.5905084509557839f32;
    y[2i64] = -0.3536710446318414f32;
    flt32->:sum_ptr = alloc(4i64) => flt32->;
    sum_ptr[0i64] = 0.0f32;
    drop(ggml_vec_dot_f32(n, sum_ptr, x, y));
    flt32:sum = sum_ptr[0i64];
    flt32:expected = 0.15699375490226775f32;
    flt32:diff = sum - expected;
    if (diff < 0.0f32) { diff = 0.0f32 - diff; }
