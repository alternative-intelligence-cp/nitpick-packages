use "../src/nitpick_llama.npk".*;
use "../src/ops.npk".*;
func:main = int32() {
    drop(llama_init_example());
    int64:n = 16i64;
    flt32->:x = alloc(n * 4i64) => flt32->;
    x[0i64] = 2.0f32;
    x[1i64] = 2.0f32;
    x[2i64] = 2.0f32;
    x[3i64] = 2.0f32;
    x[4i64] = 2.0f32;
    x[5i64] = 2.0f32;
    x[6i64] = 2.0f32;
    x[7i64] = 2.0f32;
    x[8i64] = 2.0f32;
    x[9i64] = 2.0f32;
    x[10i64] = 2.0f32;
    x[11i64] = 2.0f32;
    x[12i64] = 2.0f32;
    x[13i64] = 2.0f32;
    x[14i64] = 2.0f32;
    x[15i64] = 2.0f32;
    flt32->:sum_ptr = alloc(4i64) => flt32->;
    sum_ptr[0i64] = 0.0f32;
    // Alias x and y
    drop(ggml_vec_dot_f32(n, sum_ptr, x, x));
    flt32:sum = sum_ptr[0i64];
    if (sum != 64.0f32) { exit(1i32); }
    exit(0i32);
};
func:failsafe = int32(tbb32:_err) { exit(1i32); };