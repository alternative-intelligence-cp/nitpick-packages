
use "../../src/nitpick_llama.npk".*;
use "proposed_ops_fixed.npk".*;

func:main = int32() {{
    drop(llama_init_example());
    int64:n = 16i64;
    flt32->:x = alloc(n * 4i64) => flt32->;
    flt32->:y = alloc(n * 4i64) => flt32->;

    x[0i64] = 0.9654099185968601f32;
    y[0i64] = -0.45358929017902927f32;
    x[1i64] = 0.4046929240192627f32;
    y[1i64] = -0.37466712048528295f32;
    x[2i64] = -0.40697800717460697f32;
    y[2i64] = -0.28415183955029444f32;
    x[3i64] = 0.07089759881098567f32;
    y[3i64] = 0.7815566338875737f32;
    x[4i64] = 0.3169019281274088f32;
    y[4i64] = -0.285959601015209f32;
    x[5i64] = -0.16215687640849885f32;
    y[5i64] = -0.42595791312332043f32;
    x[6i64] = -0.5859717657635999f32;
    y[6i64] = -0.1955763012635916f32;
    x[7i64] = 0.4224063018668536f32;
    y[7i64] = -0.7487113407058477f32;
    x[8i64] = 0.23101032488716555f32;
    y[8i64] = 0.17837855078749687f32;
    x[9i64] = 0.8706053793782766f32;
    y[9i64] = 0.35617382343385295f32;
    x[10i64] = 0.7086944299147424f32;
    y[10i64] = 0.7158538974862403f32;
    x[11i64] = 0.9594780865138337f32;
    y[11i64] = 0.41897417541592086f32;
    x[12i64] = 0.15908104295545678f32;
    y[12i64] = -0.8469611839502544f32;
    x[13i64] = 0.8062838899330067f32;
    y[13i64] = 0.37761609372527927f32;
    x[14i64] = 0.9898437652773726f32;
    y[14i64] = 0.7731231818144648f32;
    x[15i64] = -0.4561832481340722f32;
    y[15i64] = -0.46957669933787227f32;

    flt32->:sum_ptr = alloc(4i64) => flt32->;
    sum_ptr[0i64] = 0.0f32;
    drop(ggml_vec_dot_f32(n, sum_ptr, x, y));
    flt32:sum = sum_ptr[0i64];

    // Check against oracle value
    flt32:expected = 1.7681487968669067f32;
    flt32:diff = sum - expected;
    if (diff < 0.0f32) {{ diff = 0.0f32 - diff; }}
    if (diff > 0.01f32) {{
        exit(1i32);
    }}
    exit(0i32);
}};

func:failsafe = int32(tbb32:_err) {{
    exit(1i32);
}};
