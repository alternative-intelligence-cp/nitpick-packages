// test_nitpick_cli.npk — 12-test suite for nitpick-cli (v0.11.2)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_cli.npk".*;

func:failsafe = int32(tbb32:_err) { exit 1; };

func:main = int32() {
    
    

    // T01: red wraps text (length > input)
    string:r1 = raw Cli.red("hi");
    int64:l1 = string_length(r1);
    if (l1 > 2i64) { println("[PASS] T01 red");  }
    if (l1 <= 2i64) { println("[FAIL] T01"); }

    // T02: green wraps text
    string:r2 = raw Cli.green("hi");
    int64:l2 = string_length(r2);
    if (l2 > 2i64) { println("[PASS] T02 green");  }
    if (l2 <= 2i64) { println("[FAIL] T02"); }

    // T03: bold wraps text
    string:r3 = raw Cli.bold("hi");
    int64:l3 = string_length(r3);
    if (l3 > 2i64) { println("[PASS] T03 bold");  }
    if (l3 <= 2i64) { println("[FAIL] T03"); }

    // T04: italic wraps text
    string:r4 = raw Cli.italic("hi");
    int64:l4 = string_length(r4);
    if (l4 > 2i64) { println("[PASS] T04 italic");  }
    if (l4 <= 2i64) { println("[FAIL] T04"); }

    // T05: strip(red("hi")) == "hi"
    string:r5 = raw Cli.red("hi");
    string:s5 = raw Cli.strip(r5);
    if (s5 == "hi") { println("[PASS] T05 strip red");  }
    if (s5 != "hi") { println("[FAIL] T05"); }

    // T06: strip(bold("test")) == "test"
    string:r6 = raw Cli.bold("test");
    string:s6 = raw Cli.strip(r6);
    if (s6 == "test") { println("[PASS] T06 strip bold");  }
    if (s6 != "test") { println("[FAIL] T06"); }

    // T07: progress bar non-empty
    string:r7 = raw Cli.progress(50i32, 100i32, 20i32);
    int64:l7 = string_length(r7);
    if (l7 > 0i64) { println("[PASS] T07 progress");  }
    if (l7 <= 0i64) { println("[FAIL] T07"); }

    // T08: hr non-empty
    string:r8 = raw Cli.hr(40i32, "-");
    int64:l8 = string_length(r8);
    if (l8 > 0i64) { println("[PASS] T08 hr");  }
    if (l8 <= 0i64) { println("[FAIL] T08"); }

    // T09: banner non-empty
    string:r9 = raw Cli.banner("test", 40i32);
    int64:l9 = string_length(r9);
    if (l9 > 0i64) { println("[PASS] T09 banner");  }
    if (l9 <= 0i64) { println("[FAIL] T09"); }

    // T10: bright_red wraps text
    string:r10 = raw Cli.bright_red("hi");
    int64:l10 = string_length(r10);
    if (l10 > 2i64) { println("[PASS] T10 bright_red");  }
    if (l10 <= 2i64) { println("[FAIL] T10"); }

    // T11: underline wraps text
    string:r11 = raw Cli.underline("hi");
    int64:l11 = string_length(r11);
    if (l11 > 2i64) { println("[PASS] T11 underline");  }
    if (l11 <= 2i64) { println("[FAIL] T11"); }

    // T12: count is 20
    int32:c = raw Cli.count();
    if (c == 20i32) { println("[PASS] T12 count=20");  }
    if (c != 20i32) { println("[FAIL] T12"); }

    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
