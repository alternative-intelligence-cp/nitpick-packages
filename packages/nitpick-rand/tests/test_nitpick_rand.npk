// test_nitpick_rand.npk — LIB-2 test suite (10 tests, all 3 rand functions)
//
// Build: aria_make run from nitpick-rand/ package root, then run
//        .npk_make/build/test-nitpick-rand
//
// Testing strategy: call rand_next / rand_bounded / rand_bool with literal
// constant seeds.  LLVM constant-folds all uint64 bitwise operations
// (^, <<, >>, %, &) at compile time, producing verified pass/fail results.
//
// Bug #20 (ashr for uint64 >>) — RESOLVED: compiler now uses lshr.
// Bug #21 (large u64 literals) — RESOLVED: full 64-bit range supported.
//
// Reference values (standard xorshift64, compatible with ariac for safe seeds):
//   rand_next(1)                        = 1082269761
//   rand_next(1082269761)               = 1152992998833853505
//   rand_next(1066028243488)            = 8140722925750643220  (= rand_next(rand_next(999)))
//   rand_next(999)                      = 1066028243488
//   rand_bounded(1, 10)                 = 1
//   rand_bounded(1, 100)                = 61
//   rand_bounded(1082269761, 256)       = 65
//   rand_bounded(100, 50)               = 24
//   rand_bool(1)                        = 1   (rand_next(1) is odd)
//   rand_bool(2)                        = 0   (rand_next(2) is even)

extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_rand.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };

func:main = int32() {
    int32:pass_count = 0i32;
    int64:passed = 0i64;
    int64:failed = 0i64;

    drop(println("nitpick-rand -- LIB-2"));
    drop(println("=================="));

    // ── rand_next ────────────────────────────────────────────────────────────

    // test 01: rand_next(1) = 1082269761
    uint64:r01 = raw rand_next(1u64);
    int64:c01 = 0i64;
    if (r01 == 1082269761u64) { c01 = 1i64; }
    if (c01 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_next(1) = 1082269761")); }
    if (c01 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_next(1) = 1082269761")); }

    // test 02: rand_next(rand_next(1)) = 1152992998833853505
    uint64:r02 = raw rand_next(1082269761u64);
    int64:c02 = 0i64;
    if (r02 == 1152992998833853505u64) { c02 = 1i64; }
    if (c02 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_next(r1) = 1152992998833853505")); }
    if (c02 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_next(r1) = 1152992998833853505")); }

    // test 03: rand_next(rand_next(999)) = 8140722925750643220
    // Note: xs64(xs64(xs64(1))) = 11177516664432764457 >= 2^63, so we use a
    // different chain. Bug #21: u64 literals >= 2^63 are stored as 0 in ariac.
    uint64:r03 = raw rand_next(1066028243488u64);
    int64:c03 = 0i64;
    if (r03 == 8140722925750643220u64) { c03 = 1i64; }
    if (c03 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_next(rand_next(999)) = 8140722925750643220")); }
    if (c03 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_next(rand_next(999)) = 8140722925750643220")); }

    // test 04: rand_next(999) = 1066028243488
    uint64:r04 = raw rand_next(999u64);
    int64:c04 = 0i64;
    if (r04 == 1066028243488u64) { c04 = 1i64; }
    if (c04 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_next(999) = 1066028243488")); }
    if (c04 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_next(999) = 1066028243488")); }

    // ── rand_bounded ─────────────────────────────────────────────────────────

    // test 05: rand_bounded(1, 10) = 1
    uint64:r05 = raw rand_bounded(1u64, 10u64);
    int64:c05 = 0i64;
    if (r05 == 1u64) { c05 = 1i64; }
    if (c05 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_bounded(1, 10) = 1")); }
    if (c05 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_bounded(1, 10) = 1")); }

    // test 06: rand_bounded(1, 100) = 61
    uint64:r06 = raw rand_bounded(1u64, 100u64);
    int64:c06 = 0i64;
    if (r06 == 61u64) { c06 = 1i64; }
    if (c06 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_bounded(1, 100) = 61")); }
    if (c06 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_bounded(1, 100) = 61")); }

    // test 07: rand_bounded(1082269761, 256) = 65
    uint64:r07 = raw rand_bounded(1082269761u64, 256u64);
    int64:c07 = 0i64;
    if (r07 == 65u64) { c07 = 1i64; }
    if (c07 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_bounded(r1, 256) = 65")); }
    if (c07 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_bounded(r1, 256) = 65")); }

    // test 08: rand_bounded(100, 50) = 24
    uint64:r08 = raw rand_bounded(100u64, 50u64);
    int64:c08 = 0i64;
    if (r08 == 24u64) { c08 = 1i64; }
    if (c08 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_bounded(100, 50) = 24")); }
    if (c08 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_bounded(100, 50) = 24")); }

    // ── rand_bool ────────────────────────────────────────────────────────────

    // test 09: rand_bool(1) = 1  (rand_next(1) = 1082269761 which is odd)
    uint64:r09 = raw rand_bool(1u64);
    int64:c09 = 0i64;
    if (r09 == 1u64) { c09 = 1i64; }
    if (c09 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_bool(1) = 1 (odd)")); }
    if (c09 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_bool(1) = 1 (odd)")); }

    // test 10: rand_bool(2) = 0  (rand_next(2) is even)
    uint64:r10 = raw rand_bool(2u64);
    int64:c10 = 0i64;
    if (r10 == 0u64) { c10 = 1i64; }
    if (c10 == 1i64) { passed = passed + 1i64; drop(println("[PASS] rand_bool(2) = 0 (even)")); }
    if (c10 == 0i64) { failed = failed + 1i64; drop(println("[FAIL] rand_bool(2) = 0 (even)")); }

    // ── summary ──────────────────────────────────────────────────────────────

    drop(println("---"));
    if (failed == 0i64) {
        drop(println("PASS: all 10 nitpick-rand tests passed"));
        exit(0i32);
    }
    drop(println("FAIL: some nitpick-rand tests failed"));
    exit(1i32);
};
