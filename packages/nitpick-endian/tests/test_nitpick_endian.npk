// test_nitpick_endian.npk
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_endian.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:_err) {
    drop _err;
    exit 1i32;
};

func:assert_eq_u64 = int64(uint64:actual, uint64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:main = int32() {
    uint64:r01 = raw Endian.rev16(258u64);
    drop assert_eq_u64(r01, 513u64, "T01 rev16(0x0102)==0x0201\0");

    uint64:r02 = raw Endian.rev16(0u64);
    drop assert_eq_u64(r02, 0u64, "T02 rev16(0)==0\0");

    uint64:r03 = raw Endian.rev32(16909060u64);
    drop assert_eq_u64(r03, 67305985u64, "T03 rev32(0x01020304)==0x04030201\0");

    uint64:r04 = raw Endian.rev32(0u64);
    drop assert_eq_u64(r04, 0u64, "T04 rev32(0)==0\0");

    uint64:r05 = raw Endian.rev64(72623859790382856u64);
    drop assert_eq_u64(r05, 578437695752307201u64, "T05 rev64 reverses all 8 bytes\0");

    uint64:r06 = raw Endian.rol32(1u64, 1u64);
    drop assert_eq_u64(r06, 2u64, "T06 rol32(1,1)==2\0");

    uint64:r07 = raw Endian.ror32(2u64, 1u64);
    drop assert_eq_u64(r07, 1u64, "T07 ror32(2,1)==1\0");

    uint64:r08 = raw Endian.rol32(2147483648u64, 1u64);
    drop assert_eq_u64(r08, 1u64, "T08 rol32(0x80000000,1)==1\0");

    uint64:r09 = raw Endian.rol64(1u64, 1u64);
    drop assert_eq_u64(r09, 2u64, "T09 rol64(1,1)==2\0");

    uint64:r10 = raw Endian.ror64(2u64, 1u64);
    drop assert_eq_u64(r10, 1u64, "T10 ror64(2,1)==1\0");

    uint64:r11 = raw Endian.ror64(9223372036854775808u64, 1u64);
    drop assert_eq_u64(r11, 4611686018427387904u64, "T11 ror64(highbit,1)==0x4000...\0");

    uint64:r12 = raw Endian.le64(72623859790382856u64);
    drop assert_eq_u64(r12, 72623859790382856u64, "T12 le64 is identity\0");

    uint64:r13 = raw Endian.be64(72623859790382856u64);
    drop assert_eq_u64(r13, 578437695752307201u64, "T13 be64 reverses bytes\0");

    uint64:r14 = raw Endian.be32(16909060u64);
    drop assert_eq_u64(r14, 67305985u64, "T14 be32 reverses bytes\0");

    uint64:r15 = raw Endian.be16(258u64);
    drop assert_eq_u64(r15, 513u64, "T15 be16 reverses bytes\0");

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
