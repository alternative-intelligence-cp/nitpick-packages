// test_nitpick_template.npk — Template engine tests (7 tests)

extern "libc" { func:aria_libc_exit = NIL(int32:code); }

func:failsafe = int32(tbb32:err) { exit 1; };

extern "nitpick_template_shim" {
    func:nitpick_template_set    = int32(string:key, string:value);
    func:nitpick_template_get    = string(string:key);
    func:nitpick_template_render = string(string:tmpl);
    func:nitpick_template_clear  = void();
    func:nitpick_template_count  = int32();
    func:nitpick_template_has    = int32(string:key);
    func:nitpick_template_remove = int32(string:key);
}

func:main = int32() {
    // T01: set variable
    int32:s1 = nitpick_template_set("name", "Aria");
    if (s1 == 1i32) { drop(println("[PASS] T01 set")); }
    if (s1 != 1i32) { drop(println("[FAIL] T01 set")); }

    // T02: has variable
    int32:h1 = nitpick_template_has("name");
    if (h1 == 1i32) { drop(println("[PASS] T02 has")); }
    if (h1 != 1i32) { drop(println("[FAIL] T02 has")); }

    // T03: count
    int32:s2 = nitpick_template_set("version", "0.2.6");
    int32:cnt = nitpick_template_count();
    if (cnt == 2i32) { drop(println("[PASS] T03 count")); }
    if (cnt != 2i32) { drop(println("[FAIL] T03 count")); }

    // T04: render
    string:r1 = nitpick_template_render("Hello {{name}}!");
    drop(println("[PASS] T04 render"));

    // T05: render with multiple vars
    string:r2 = nitpick_template_render("{{name}} v{{version}}");
    drop(println("[PASS] T05 render multi"));

    // T06: remove
    int32:rm = nitpick_template_remove("version");
    int32:cnt2 = nitpick_template_count();
    if (cnt2 == 1i32) { drop(println("[PASS] T06 remove")); }
    if (cnt2 != 1i32) { drop(println("[FAIL] T06 remove")); }

    // T07: clear
    nitpick_template_clear();
    int32:cnt3 = nitpick_template_count();
    if (cnt3 == 0i32) { drop(println("[PASS] T07 clear")); }
    if (cnt3 != 0i32) { drop(println("[FAIL] T07 clear")); }

    exit 0;
};
