// nitpick_regex.npk — Regular expression library for Nitpick
//
// POSIX extended regex: compile, match, search, groups, replace.
// Requires: libnitpick_regex_shim.so

extern "nitpick_regex_shim" {
    func:nitpick_regex_compile       = int32(string:pattern);
    func:nitpick_regex_compile_icase = int32(string:pattern);
    func:nitpick_regex_cleanup      = void();
    func:nitpick_regex_error         = string();

    func:nitpick_regex_match      = int32(string:text);
    func:nitpick_regex_match_full = int32(string:text);
    func:nitpick_regex_search     = int32(string:text);

    func:nitpick_regex_group_count = int32();
    func:nitpick_regex_group       = string(int32:idx);
    func:nitpick_regex_group_start = int32(int32:idx);
    func:nitpick_regex_group_end   = int32(int32:idx);

    func:nitpick_regex_replace = string(string:text, string:replacement);
    func:nitpick_regex_last_result = string();
}

pub func:regex_compile = int32(string:pattern) { int32:r = nitpick_regex_compile(pattern); pass(r); };
pub func:regex_compile_icase = int32(string:pattern) { int32:r = nitpick_regex_compile_icase(pattern); pass(r); };
pub func:regex_cleanup = NIL() { nitpick_regex_cleanup(); pass(NIL); };
pub func:regex_error = string() { string:r = nitpick_regex_error(); pass(r); };

pub func:regex_match = int32(string:text) { int32:r = nitpick_regex_match(text); pass(r); };
pub func:regex_match_full = int32(string:text) { int32:r = nitpick_regex_match_full(text); pass(r); };
pub func:regex_search = int32(string:text) { int32:r = nitpick_regex_search(text); pass(r); };

pub func:regex_group_count = int32() { int32:r = nitpick_regex_group_count(); pass(r); };
pub func:regex_group = string(int32:idx) { drop(nitpick_regex_group(idx)); string:r = nitpick_regex_last_result(); pass(r); };
pub func:regex_group_start = int32(int32:idx) { int32:r = nitpick_regex_group_start(idx); pass(r); };
pub func:regex_group_end = int32(int32:idx) { int32:r = nitpick_regex_group_end(idx); pass(r); };

pub func:regex_replace = string(string:text, string:replacement) { drop(nitpick_regex_replace(text, replacement)); string:r = nitpick_regex_last_result(); pass(r); };
