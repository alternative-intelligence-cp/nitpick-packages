[target.nhnterm]
type = "executable"
src = ["src/main.npk"]
include_dirs = [
    "src",
    "../nitpick-tui/src",
    "../nitpick-display/src",
    "../nitpick-input/src",
    "../nitpick-http/src",
    "../nitpick-str/src",
    "../nitpick-fs/src"
]
libs = [
    "../nitpick-display/shim/libnitpick_display_shim.a",
    "../nitpick-input/shim/libnitpick_input.a",
    "../nitpick-http/libnitpick_http_shim.a",
    "../../../nitpick-libc/shim/libnitpick_libc_string.a",
    "../../../nitpick-libc/shim/libnitpick_libc_mem.a",
    "../../../nitpick-libc/shim/libnitpick_libc_io.a",
    "-lcurl"
]
