func:test_shim_functions = int32() {
    int32:pc = 0i32;

    string:accept = raw WebSocket.compute_accept("dGhlIHNhbXBsZSBub25jZQ==");
    int32:t13 = 0i32;
    if (accept == "s3pPLMBiTxaQ9kYGzzhZRbK+xOo=") { t13 = 1i32; }
    if (t13 == 1i32) { println("[PASS] T13 ws_compute_accept correct"); pc += 1i32; }
    if (t13 == 0i32) { println("[FAIL] T13"); }

    string:f_bld = raw WebSocket.build_frame(1i64, "hello", 5i32, 0i32);
    int64:f_len = raw WebSocket.build_frame_len();
    int32:t14 = 0i32;
    if (f_len == 7i64) { t14 = 1i32; } // 2 header + 5 payload
    if (t14 == 1i32) { println("[PASS] T14 ws_build_frame len 7"); pc += 1i32; }
    if (t14 == 0i32) { println("[FAIL] T14"); }

    int64:op = raw WebSocket.parse_opcode(f_bld);
    int32:t15 = 0i32;
    if (op == 1i64) { t15 = 1i32; }
    if (t15 == 1i32) { println("[PASS] T15 parse_opcode = 1"); pc += 1i32; }
    if (t15 == 0i32) { println("[FAIL] T15"); }

    int64:p_len = raw WebSocket.parse_payload_len(f_bld);
    int32:t16 = 0i32;
    if (p_len == 5i64) { t16 = 1i32; }
    if (t16 == 1i32) { println("[PASS] T16 parse_payload_len = 5"); pc += 1i32; }
    if (t16 == 0i32) { println("[FAIL] T16"); }

    string:unmask = raw WebSocket.unmask_payload(f_bld);
    int32:t17 = 0i32;
    if (string_contains(unmask, "hello")) { t17 = 1i32; }
    if (t17 == 1i32) { println("[PASS] T17 unmask_payload = hello"); pc += 1i32; }
    if (t17 == 0i32) { println("[FAIL] T17"); }

    pass pc;
};

