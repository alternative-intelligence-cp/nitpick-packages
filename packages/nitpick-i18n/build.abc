[project]
name = "nitpick-i18n"
version = "0.1.0"

[target.nitpick-i18n]
type = "library"
sources = ["src/nitpick_i18n.npk"]
deps = []
flags = ["-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_string"]

[target.test-nitpick-i18n]
type = "binary"
sources = ["tests/test_nitpick_i18n.npk"]
deps = ["nitpick-i18n"]
flags = ["-I", "src", "-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_string"]
