pub func:failsafe = int32(tbb32:err) { drop err; exit 1i32; };
extern "libc" {
    func:printf = int32(string:fmt, string:v);
}

pub func:main = int32() {
    string:s = "hello world";
    int64:p = @cast_unchecked<int64>(s);
    string:s2 = @cast_unchecked<string>(p);
    drop printf("s2=%s\n\0", s2);
    exit 0i32;
};
