// test_nitpick_semver.npk — SemVer tests (8 tests)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_semver.npk".*;

func:failsafe = int32(tbb32:err) { exit 1; };



func:main = int32() {
    int32:pass_count = 0i32;
    // T01: parse
    int32:r1 = nitpick_semver_parse("1.2.3");
    if (r1 == 1i32) { drop(println("[PASS] T01 parse")); }
    if (r1 != 1i32) { drop(println("[FAIL] T01 parse")); }

    // T02: major
    int32:nitpick_maj = nitpick_semver_get_major();
    if (nitpick_maj == 1i32) { drop(println("[PASS] T02 major")); }
    if (nitpick_maj != 1i32) { drop(println("[FAIL] T02 major")); }

    // T03: minor
    int32:nitpick_min = nitpick_semver_get_minor();
    if (nitpick_min == 2i32) { drop(println("[PASS] T03 minor")); }
    if (nitpick_min != 2i32) { drop(println("[FAIL] T03 minor")); }

    // T04: patch
    int32:nitpick_pat = nitpick_semver_get_patch();
    if (nitpick_pat == 3i32) { drop(println("[PASS] T04 patch")); }
    if (nitpick_pat != 3i32) { drop(println("[FAIL] T04 patch")); }

    // T05: compare equal
    int32:c1 = nitpick_semver_compare("1.0.0", "1.0.0");
    if (c1 == 0i32) { drop(println("[PASS] T05 compare equal")); }
    if (c1 != 0i32) { drop(println("[FAIL] T05 compare equal")); }

    // T06: compare less
    int32:c2 = nitpick_semver_compare("1.0.0", "2.0.0");
    if (c2 == -1i32) { drop(println("[PASS] T06 compare less")); }
    if (c2 != -1i32) { drop(println("[FAIL] T06 compare less")); }

    // T07: compare greater
    int32:c3 = nitpick_semver_compare("2.1.0", "1.9.0");
    if (c3 == 1i32) { drop(println("[PASS] T07 compare greater")); }
    if (c3 != 1i32) { drop(println("[FAIL] T07 compare greater")); }

    // T08: satisfies
    int32:s1 = nitpick_semver_satisfies("1.2.3", ">=1.0.0");
    if (s1 == 1i32) { drop(println("[PASS] T08 satisfies")); }
    if (s1 != 1i32) { drop(println("[FAIL] T08 satisfies")); }

    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
