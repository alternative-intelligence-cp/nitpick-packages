[project]
name = "nitpick-fs"
version = "0.1.0"

[target.nitpick-fs]
type = "library"
sources = ["src/nitpick_fs.npk"]
deps = []
flags = ["-L.", "-lnitpick_fs_shim"]

[target.test-nitpick-fs]
type = "binary"
sources = ["tests/test_nitpick_fs.npk"]
deps = []
flags = ["-I", "src", "-L.", "-lnitpick_fs_shim"]
