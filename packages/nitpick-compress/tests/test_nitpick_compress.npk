// test_nitpick_compress.npk — 12-test suite for nitpick-compress (v0.11.2)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_compress.npk".*;

func:failsafe = int32(tbb32:_err) { exit 1; };

func:main = int32() {
    
    

    // T01: version non-empty
    string:ver = raw Compress.version();
    int64:vlen = string_length(ver);
    if (vlen > 0i64) { println("[PASS] T01 version");  }
    if (vlen <= 0i64) { println("[FAIL] T01"); }

    // T02: deflate returns compressed length > 0
    int32:d2 = raw Compress.deflate("hello world", 11i32);
    if (d2 > 0i32) { println("[PASS] T02 deflate>0");  }
    if (d2 <= 0i32) { println("[FAIL] T02"); }

    // T03: get_length after deflate > 0
    int32:gl3 = raw Compress.get_length();
    if (gl3 > 0i32) { println("[PASS] T03 get_length");  }
    if (gl3 <= 0i32) { println("[FAIL] T03"); }

    // T04: get_result after deflate non-empty
    string:gr4 = raw Compress.get_result();
    int64:gl4 = string_length(gr4);
    if (gl4 > 0i64) { println("[PASS] T04 get_result");  }
    if (gl4 <= 0i64) { println("[FAIL] T04"); }

    // T05: roundtrip returns length > 0
    int32:rt5 = raw Compress.roundtrip("test data", 9i32);
    if (rt5 > 0i32) { println("[PASS] T05 roundtrip>0");  }
    if (rt5 <= 0i32) { println("[FAIL] T05"); }

    // T06: roundtrip result matches original
    string:rr6 = raw Compress.get_result();
    if (rr6 == "test data") { println("[PASS] T06 roundtrip match");  }
    if (rr6 != "test data") { println("[FAIL] T06"); }

    // T07: gzip returns compressed length > 0
    int32:g7 = raw Compress.gzip("hello gzip", 10i32);
    if (g7 > 0i32) { println("[PASS] T07 gzip>0");  }
    if (g7 <= 0i32) { println("[FAIL] T07"); }

    // T08: get_error after success is 0
    int32:e8 = raw Compress.get_error();
    if (e8 == 0i32) { println("[PASS] T08 no error");  }
    if (e8 != 0i32) { println("[FAIL] T08"); }

    // T09: deflate compressed shorter than original for long string
    int32:d9 = raw Compress.deflate("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", 40i32);
    if (d9 > 0i32) { if (d9 < 40i32) { println("[PASS] T09 smaller");  } }

    // T10: roundtrip longer string
    int32:rt10 = raw Compress.roundtrip("the quick brown fox jumps over the lazy dog", 44i32);
    string:rr10 = raw Compress.get_result();
    if (rr10 == "the quick brown fox jumps over the lazy dog") { println("[PASS] T10 long roundtrip");  }
    if (rr10 != "the quick brown fox jumps over the lazy dog") { println("[FAIL] T10"); }

    // T11: inflate after deflate
    int32:d11 = raw Compress.deflate("inflate me", 10i32);
    string:comp11 = raw Compress.get_result();
    int32:i11 = raw Compress.inflate(comp11, d11);
    string:dec11 = raw Compress.get_result();
    if (dec11 == "inflate me") { println("[PASS] T11 inflate");  }
    if (dec11 != "inflate me") { println("[FAIL] T11"); }

    // T12: gzip get_length matches return value
    int32:g12 = raw Compress.gzip("length check", 12i32);
    int32:gl12 = raw Compress.get_length();
    if (gl12 == g12) { println("[PASS] T12 gzip length");  }
    if (gl12 != g12) { println("[FAIL] T12"); }

    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
