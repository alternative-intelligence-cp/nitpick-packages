// test_nitpick_display.npk — 12-test suite for nitpick-display (v0.12.2)
extern "libc" { func:aria_libc_exit = NIL(int32:code); }
use "../src/nitpick_display.npk".*;

func:failsafe = int32(tbb32:_err) { exit 1; };

func:test_create_cursor = int32() {
    int32:pc = 0i32;

    int64:d = raw disp_create(80i64, 24i64);
    if (d > 0i64) { println("[PASS] T01 disp_create"); pc += 1i32; }
    if (d <= 0i64) { println("[FAIL] T01"); }

    int32:_m = raw disp_move(d, 3i64, 5i64);
    string:row2 = raw disp_cursor_row(d);
    int32:t2 = 0i32;
    if (string_contains(row2, "3")) { t2 = 1i32; }
    if (t2 == 1i32) { println("[PASS] T02 cursor_row=3"); pc += 1i32; }
    if (t2 == 0i32) { println("[FAIL] T02"); }

    string:col3 = raw disp_cursor_col(d);
    int32:t3 = 0i32;
    if (string_contains(col3, "5")) { t3 = 1i32; }
    if (t3 == 1i32) { println("[PASS] T03 cursor_col=5"); pc += 1i32; }
    if (t3 == 0i32) { println("[FAIL] T03"); }

    pass pc;
};

func:test_colors = int32() {
    int32:pc = 0i32;

    int64:d = raw disp_create(80i64, 24i64);

    int32:_f = raw disp_set_fg(d, 1i64);
    string:fg4 = raw disp_fg(d);
    int32:t4 = 0i32;
    if (string_contains(fg4, "1")) { t4 = 1i32; }
    if (t4 == 1i32) { println("[PASS] T04 fg=1 (red)"); pc += 1i32; }
    if (t4 == 0i32) { println("[FAIL] T04"); }

    int32:_b = raw disp_set_bg(d, 4i64);
    string:bg5 = raw disp_bg(d);
    int32:t5 = 0i32;
    if (string_contains(bg5, "4")) { t5 = 1i32; }
    if (t5 == 1i32) { println("[PASS] T05 bg=4 (blue)"); pc += 1i32; }
    if (t5 == 0i32) { println("[FAIL] T05"); }

    string:cn6 = raw disp_color_name(1i64);
    int32:t6 = 0i32;
    if (string_contains(cn6, "red")) { t6 = 1i32; }
    if (t6 == 1i32) { println("[PASS] T06 color_name(1)=red"); pc += 1i32; }
    if (t6 == 0i32) { println("[FAIL] T06"); }

    pass pc;
};

func:test_attributes = int32() {
    int32:pc = 0i32;

    int64:d = raw disp_create(80i64, 24i64);

    int32:_b = raw disp_set_bold(d, 1i64);
    string:bold7 = raw disp_is_bold(d);
    int32:t7 = 0i32;
    if (string_contains(bold7, "1")) { t7 = 1i32; }
    if (t7 == 1i32) { println("[PASS] T07 bold=1"); pc += 1i32; }
    if (t7 == 0i32) { println("[FAIL] T07"); }

    int32:_h = raw disp_hide_cursor(d);
    string:vis8 = raw disp_cursor_visible(d);
    int32:t8 = 0i32;
    if (string_contains(vis8, "0")) { t8 = 1i32; }
    if (t8 == 1i32) { println("[PASS] T08 cursor hidden"); pc += 1i32; }
    if (t8 == 0i32) { println("[FAIL] T08"); }

    int32:_s = raw disp_show_cursor(d);
    string:vis9 = raw disp_cursor_visible(d);
    int32:t9 = 0i32;
    if (string_contains(vis9, "1")) { t9 = 1i32; }
    if (t9 == 1i32) { println("[PASS] T09 cursor shown"); pc += 1i32; }
    if (t9 == 0i32) { println("[FAIL] T09"); }

    pass pc;
};

func:test_dimensions_reset = int32() {
    int32:pc = 0i32;

    int64:d = raw disp_create(80i64, 24i64);

    string:cols10 = raw disp_cols(d);
    int32:t10 = 0i32;
    if (string_contains(cols10, "80")) { t10 = 1i32; }
    if (t10 == 1i32) { println("[PASS] T10 cols=80"); pc += 1i32; }
    if (t10 == 0i32) { println("[FAIL] T10"); }

    int32:_r = raw disp_resize(d, 120i64, 40i64);
    string:rows11 = raw disp_rows(d);
    int32:t11 = 0i32;
    if (string_contains(rows11, "40")) { t11 = 1i32; }
    if (t11 == 1i32) { println("[PASS] T11 rows=40 after resize"); pc += 1i32; }
    if (t11 == 0i32) { println("[FAIL] T11"); }

    int32:_m2 = raw disp_move(d, 9i64, 7i64);
    int32:_f2 = raw disp_set_fg(d, 2i64);
    int32:_b2 = raw disp_set_bold(d, 1i64);
    int32:_rst = raw disp_reset(d);
    string:fg12 = raw disp_fg(d);
    int32:t12 = 0i32;
    if (string_contains(fg12, "7")) { t12 = 1i32; }
    if (t12 == 1i32) { println("[PASS] T12 reset fg=7 (white)"); pc += 1i32; }
    if (t12 == 0i32) { println("[FAIL] T12"); }

    pass pc;
};

func:main = int32() {
    int32:_pass_count = 0i32;
    int32:p1 = raw test_create_cursor();
    int32:p2 = raw test_colors();
    int32:p3 = raw test_attributes();
    int32:p4 = raw test_dimensions_reset();
    println("DONE");
    
    drop(println("---"));
    
        drop(println("PASS: all tests passed"));
    exit 0;
};
