[project]
name = "nitpick-cron"
version = "0.1.0"

[target.nitpick-cron]
type = "library"
sources = ["src/nitpick_cron.npk"]
deps = []
flags = ["-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_string"]

[target.test-nitpick-cron]
type = "binary"
sources = ["tests/test_nitpick_cron.npk"]
deps = ["nitpick-cron"]
flags = ["-I", "src", "-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_string"]
