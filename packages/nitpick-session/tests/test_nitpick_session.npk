// test_nitpick_session.npk — 12-test suite for nitpick-session (v0.12.1)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_session.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq_i64 = int64(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:assert_eq_str = int64(string:actual, string:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:test_lifecycle = int32() {
    int64:s1 = raw Session.create("abc123");
    string:sid1 = raw Session.sid(s1);
    drop assert_eq_str(sid1, "abc123", "T01 create + id\0");

    int64:act1 = raw Session.active(s1);
    drop assert_eq_i64(act1, 1i64, "T02 is_active=true\0");

    drop raw Session.kill(s1);
    int64:act2 = raw Session.active(s1);
    drop assert_eq_i64(act2, 0i64, "T03 destroy to inactive\0");

    pass 0i32;
};

func:test_vars = int32() {
    int64:s2 = raw Session.create("def456");
    drop raw Session.set_var(s2, "user", "alice");
    string:g4 = raw Session.get_var(s2, "user");
    drop assert_eq_str(g4, "alice", "T04 set+get user=alice\0");

    int64:h5 = raw Session.has_var(s2, "user");
    drop assert_eq_i64(h5, 1i64, "T05 has user=true\0");

    int64:h6 = raw Session.has_var(s2, "missing");
    drop assert_eq_i64(h6, 0i64, "T06 has missing=false\0");

    drop raw Session.set_var(s2, "role", "admin");
    int64:vc7 = raw Session.vars(s2);
    drop assert_eq_i64(vc7, 2i64, "T07 var_count=2\0");

    pass 0i32;
};

func:test_remove = int32() {
    int64:s3 = raw Session.create("ghi789");
    drop raw Session.set_var(s3, "color", "blue");
    drop raw Session.remove_var(s3, "color");
    int64:vc8 = raw Session.vars(s3);
    drop assert_eq_i64(vc8, 0i64, "T08 remove to count=0\0");

    pass 0i32;
};

func:test_cookie = int32() {
    int64:s4 = raw Session.create("tok001");

    string:cname9 = raw Session.get_cname(s4);
    drop assert_eq_str(cname9, "NITPICK_SID", "T09 default cookie name\0");

    drop raw Session.set_cname(s4, "MY_SES");
    string:ch10 = raw Session.cookie(s4);
    
    int64:t10 = 0i64;
    if (string_contains(ch10, "MY_SES=tok001")) { t10 = 1i64; }
    drop assert_eq_i64(t10, 1i64, "T10 cookie header name+sid\0");

    int64:t11 = 0i64;
    if (string_contains(ch10, "HttpOnly")) { t11 = 1i64; }
    drop assert_eq_i64(t11, 1i64, "T11 cookie HttpOnly\0");

    string:clr12 = raw Session.clear(s4);
    int64:t12 = 0i64;
    if (string_contains(clr12, "Max-Age=0")) { t12 = 1i64; }
    drop assert_eq_i64(t12, 1i64, "T12 clear cookie Max-Age=0\0");

    pass 0i32;
};

func:main = int32() {
    drop raw test_lifecycle();
    drop raw test_vars();
    drop raw test_remove();
    drop raw test_cookie();

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }

    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
