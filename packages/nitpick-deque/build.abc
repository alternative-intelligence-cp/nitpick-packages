[project]
name = "nitpick-deque"
version = "0.11.3"

[target.nitpick-deque]
type = "library"
sources = ["src/nitpick_deque.npk"]
deps = []
flags = ["-L../../../nitpick-libc/shim", "-lnitpick_libc_mem"]

[target.test-nitpick-deque]
type = "binary"
sources = ["tests/test_nitpick_deque.npk"]
deps = []
flags = ["-I", "src", "-L../../../nitpick-libc/shim", "-lnitpick_libc_mem", "-lnitpick_libc_io"]
