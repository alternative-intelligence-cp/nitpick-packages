// test_nitpick_deque.npk
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_deque.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:_err) {
    drop _err;
    exit 1i32;
};

func:assert_eq_i64 = int64(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i64);
};

func:main = int32() {
    int64:dq = raw Deque.create(8i64);

    int64:sz1 = raw Deque.size(dq);
    drop assert_eq_i64(sz1, 0i64, "T01 init size=0\0");

    int32:e2 = raw Deque.is_empty(dq);
    drop assert_eq_i64(e2 => int64, 1i64, "T02 is_empty\0");

    drop raw Deque.push_back(dq, 10i64);
    int64:pk3 = raw Deque.peek_back(dq);
    drop assert_eq_i64(pk3, 10i64, "T03 push/peek back\0");

    drop raw Deque.push_front(dq, 20i64);
    int64:pk4 = raw Deque.peek_front(dq);
    drop assert_eq_i64(pk4, 20i64, "T04 push/peek front\0");

    int64:sz5 = raw Deque.size(dq);
    drop assert_eq_i64(sz5, 2i64, "T05 size=2\0");

    int64:v6 = raw Deque.pop_front(dq);
    drop assert_eq_i64(v6, 20i64, "T06 pop_front=20\0");

    int64:v7 = raw Deque.pop_back(dq);
    drop assert_eq_i64(v7, 10i64, "T07 pop_back=10\0");

    int32:e8 = raw Deque.is_empty(dq);
    drop assert_eq_i64(e8 => int64, 1i64, "T08 empty again\0");

    int64:cap9 = raw Deque.capacity(dq);
    drop assert_eq_i64(cap9, 8i64, "T09 cap=8\0");

    drop raw Deque.push_back(dq, 1i64);
    drop raw Deque.push_back(dq, 2i64);
    drop raw Deque.push_back(dq, 3i64);
    int64:v10 = raw Deque.pop_front(dq);
    drop assert_eq_i64(v10, 1i64, "T10 FIFO order\0");

    int64:v11 = raw Deque.pop_back(dq);
    drop assert_eq_i64(v11, 3i64, "T11 LIFO order\0");

    drop raw Deque.push_back(dq, 99i64);
    drop raw Deque.clear(dq);
    int64:sz12 = raw Deque.size(dq);
    drop assert_eq_i64(sz12, 0i64, "T12 clear\0");

    drop raw Deque.destroy(dq);

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }
    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
