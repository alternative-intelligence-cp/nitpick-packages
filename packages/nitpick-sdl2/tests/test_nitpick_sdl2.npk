// test_nitpick_sdl2.npk — Automated tests for nitpick-sdl2 bindings
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_sdl2.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq_i32 = int32(int32:actual, int32:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i32);
};

func:main = int32() {
    // T01: SDL_Init
    int32:init_result = raw Sdl2.init(32i32);
    drop assert_eq_i32(init_result, 0i32, "T01 SDL_Init\0");

    // T02: create window
    int32:win_ok = raw Sdl2.create_window("Nitpick SDL2 Test", 536805376i32, 536805376i32, 800i32, 600i32, 4i32);
    drop assert_eq_i32(win_ok, 1i32, "T02 create_window\0");

    // T03: window width
    int32:ww = raw Sdl2.get_window_width();
    drop assert_eq_i32(ww, 800i32, "T03 get_window_width\0");

    // T04: window height
    int32:wh = raw Sdl2.get_window_height();
    drop assert_eq_i32(wh, 600i32, "T04 get_window_height\0");

    // T05: create renderer
    int32:ren_ok = raw Sdl2.create_renderer(1i32);
    drop assert_eq_i32(ren_ok, 1i32, "T05 create_renderer\0");

    // drawing commands - no asserts, just checking no crash
    drop raw Sdl2.set_draw_color(40i32, 40i32, 40i32, 255i32);
    drop raw Sdl2.clear();
    drop raw Sdl2.set_draw_color(255i32, 255i32, 255i32, 255i32);
    drop raw Sdl2.draw_point(100i32, 100i32);
    drop raw Sdl2.draw_line(50i32, 50i32, 750i32, 550i32);
    drop raw Sdl2.set_draw_color(0i32, 255i32, 0i32, 255i32);
    drop raw Sdl2.draw_rect(100i32, 100i32, 200i32, 150i32);
    drop raw Sdl2.set_draw_color(255i32, 0i32, 0i32, 255i32);
    drop raw Sdl2.fill_rect(350i32, 100i32, 200i32, 150i32);
    drop raw Sdl2.present();

    // T06: get_ticks
    int32:ticks = raw Sdl2.get_ticks();
    int32:ticks_ok = 0i32;
    if (ticks > 0i32) { ticks_ok = 1i32; }
    drop assert_eq_i32(ticks_ok, 1i32, "T06 get_ticks > 0\0");

    // Event checking
    int32:has_ev = raw Sdl2.poll_event();
    int32:et = raw Sdl2.event_type();

    // T07: mouse state (no crash, returning 0 expected)
    int32:mx = raw Sdl2.get_mouse_x();
    drop assert_eq_i32(mx, 0i32, "T07 get_mouse_x\0");

    drop raw Sdl2.set_window_title("Nitpick SDL2 - Updated Title");
    drop raw Sdl2.delay(10i32);

    string:err = raw Sdl2.get_error();

    drop raw Sdl2.quit();

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }

    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
