// ── public API: init / quit ─────────────────────────────────────────


pub Type:Sdl2 = {
func:init = int32(int32:flags) {
    int32:r = nitpick_sdl2_init(flags);
    pass(r);
};

func:quit = NIL() {
    nitpick_sdl2_quit();
    pass(NIL);
};

