// test_nitpick_result.npk — 12-test suite for nitpick-result (v0.11.3)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_result.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq_i32 = int32(int32:actual, int32:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i32);
};

func:assert_eq_i64 = int32(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i32);
};

func:test_result = int32() {
    int64:r1 = raw Res.success(42i64);
    int32:ok1 = raw Res.is_ok(r1);
    drop assert_eq_i32(ok1, 1i32, "T01 ok is_ok\0");

    int64:r2 = raw Res.err(99i64);
    int32:er2 = raw Res.is_err(r2);
    drop assert_eq_i32(er2, 1i32, "T02 err is_err\0");

    int64:v3 = raw Res.unwrap(r1);
    drop assert_eq_i64(v3, 42i64, "T03 unwrap ok=42\0");

    int64:v4 = raw Res.unwrap(r2);
    drop assert_eq_i64(v4, 0i64 - 1i64, "T04 unwrap err=-1\0");

    int64:v5 = raw Res.unwrap_or(r1, 0i64);
    drop assert_eq_i64(v5, 42i64, "T05 unwrap_or ok\0");

    int64:v6 = raw Res.unwrap_or(r2, 777i64);
    drop assert_eq_i64(v6, 777i64, "T06 unwrap_or err\0");

    int64:ec7 = raw Res.error_code(r2);
    drop assert_eq_i64(ec7, 99i64, "T07 error_code=99\0");

    int64:ra8 = raw Res.success(10i64);
    int64:rb8 = raw Res.success(20i64);
    int64:and8 = raw Res.and_both(ra8, rb8);
    int64:v8 = raw Res.unwrap(and8);
    drop assert_eq_i64(v8, 20i64, "T08 and ok,ok\0");

    int64:re9 = raw Res.err(5i64);
    int64:ro9 = raw Res.success(10i64);
    int64:and9 = raw Res.and_both(re9, ro9);
    int32:ie9 = raw Res.is_err(and9);
    drop assert_eq_i32(ie9, 1i32, "T09 and err,ok\0");

    int64:or10 = raw Res.or_either(re9, ro9);
    int32:io10 = raw Res.is_ok(or10);
    drop assert_eq_i32(io10, 1i32, "T10 or err,ok\0");

    int64:m11 = raw Res.map_or(r1, 100i64, 200i64);
    drop assert_eq_i64(m11, 100i64, "T11 map_or ok\0");

    int64:cl12 = raw Res.clone(r1);
    int64:v12 = raw Res.unwrap(cl12);
    drop assert_eq_i64(v12, 42i64, "T12 clone\0");

    drop raw Res.destroy(r1);
    drop raw Res.destroy(r2);
    drop raw Res.destroy(ra8);
    drop raw Res.destroy(rb8);
    drop raw Res.destroy(re9);
    drop raw Res.destroy(ro9);
    drop raw Res.destroy(cl12);

    pass 0i32;
};

func:main = int32() {
    drop test_result();

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }

    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
