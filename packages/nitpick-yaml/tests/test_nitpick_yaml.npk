// test_nitpick_yaml.npk — YAML parser tests (13 tests)
extern "libc" {
    func:printf  = int32(string:fmt);
    func:strstr  = int64(string:haystack, string:needle);
}
int32:fail_cnt = 0i32;
use "nitpick_yaml.npk".*;

func:failsafe = int32(tbb32:err) { drop(err); exit 1i32; };



func:main = int32() {
    int32:pass_count = 0i32;
    int32:n = raw YAML.parse("name: MyApp\nversion: 3\ndebug: true\npi: 3.14\n\nserver:\n  host: localhost\n  port: 8080\n\ndatabase:\n  name: mydb\n  enabled: false\n");

    // T01: parse
    if (n > 0i32) { drop(printf("[PASS] T01 parse\n\0")); }
    if (n <= 0i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T01 parse\n\0")); }

    // T02: top-level string
    int32:h1 = raw YAML.has_key("name");
    if (h1 == 1i32) { drop(printf("[PASS] T02 has_key name\n\0")); }
    if (h1 != 1i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T02 has_key name\n\0")); }

    // T03: top-level int
    int64:ver = raw YAML.get_int("version");
    if (ver == 3i64) { drop(printf("[PASS] T03 get_int version\n\0")); }
    if (ver != 3i64) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T03 get_int version\n\0")); }

    // T04: bool true
    int32:dbg = raw YAML.get_bool("debug");
    if (dbg == 1i32) { drop(printf("[PASS] T04 get_bool debug\n\0")); }
    if (dbg != 1i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T04 get_bool debug\n\0")); }

    // T05: nested int
    int64:port = raw YAML.get_int("server.port");
    if (port == 8080i64) { drop(printf("[PASS] T05 get_int server.port\n\0")); }
    if (port != 8080i64) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T05 get_int server.port\n\0")); }

    // T06: nested bool false
    int32:en = raw YAML.get_bool("database.enabled");
    if (en == 0i32) { drop(printf("[PASS] T06 get_bool database.enabled\n\0")); }
    if (en != 0i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T06 get_bool database.enabled\n\0")); }

    // T07: missing key
    int32:miss = raw YAML.has_key("nonexistent");
    if (miss == 0i32) { drop(printf("[PASS] T07 missing key\n\0")); }
    if (miss != 0i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T07 missing key\n\0")); }

    // T08: clear
    raw YAML.clear();
    int32:c2 = raw YAML.count();
    if (c2 == 0i32) { drop(printf("[PASS] T08 clear\n\0")); }
    if (c2 != 0i32) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T08 clear\n\0")); }

    // T09: serialize — build a small doc and check output
    drop YAML.set_string("app.name", "NitpickTest");
    drop YAML.set_int("app.port", 9090i64);
    drop YAML.set_bool("app.debug", 1i32);
    string:s = raw YAML.serialize();
    // must contain the section header and the keys
    int64:has_app  = strstr(s, "app:\0");
    int64:has_name = strstr(s, "name: NitpickTest\0");
    int64:has_port = strstr(s, "port: 9090\0");
    int64:has_dbg  = strstr(s, "debug: true\0");
    if (has_app != 0i64)  { drop(printf("[PASS] T09 serialize has section header\n\0")); }
    if (has_app == 0i64)  { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T09 serialize has section header\n\0")); }
    if (has_name != 0i64) { drop(printf("[PASS] T10 serialize has string value\n\0")); }
    if (has_name == 0i64) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T10 serialize has string value\n\0")); }
    if (has_port != 0i64) { drop(printf("[PASS] T11 serialize has int value\n\0")); }
    if (has_port == 0i64) { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T11 serialize has int value\n\0")); }
    if (has_dbg != 0i64)  { drop(printf("[PASS] T12 serialize has bool value\n\0")); }
    if (has_dbg == 0i64)  { fail_cnt = fail_cnt + 1i32; drop(printf("[FAIL] T12 serialize has bool value\n\0")); }

    // T13: write_file -> parse_file round-trip
    int32:wok = raw YAML.write_file("/tmp/npk_yaml_test.yaml\0");
    raw YAML.clear();
    int32:rok = raw YAML.parse_file("/tmp/npk_yaml_test.yaml\0");
    int64:rport = raw YAML.get_int("app.port");
    if ((wok == 0i32) && (rok > 0i32) && (rport == 9090i64)) {
        drop(printf("[PASS] T13 write_file/parse_file round-trip\n\0"));
    } else {
        fail_cnt = fail_cnt + 1i32;
        drop(printf("[FAIL] T13 write_file/parse_file round-trip\n\0"));
    }

    drop(printf("---\n\0"));

    if (fail_cnt == 0i32) { drop(printf("PASS: all tests passed\n\0")); }
    if (fail_cnt > 0i32) { drop(printf("FAIL\n\0")); }
    exit fail_cnt;
};
