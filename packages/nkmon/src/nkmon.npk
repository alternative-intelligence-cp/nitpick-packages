// nkmon.npk
use "nitpick_display.npk".*;
use "nitpick_input.npk".*;
use "nitpick_tui.npk".*;
use "sysfs.npk".*;
use "../../../nitpick-thread/src/nitpick_thread.npk".*;

extern func:read = int64(int32:fd, any*:buf, int64:count);
extern func:usleep = int32(int32:usec);
extern func:fcntl = int32(int32:fd, int32:cmd, int32:arg);
extern func:malloc = any*(int64:size);
extern func:free = void(any*:ptr);

int32:g_running = 1i32;

func:main = int32() {
    drop(Tui.init());
    
    (int64)(int64):input_worker = int64(int64:arg) {
        int8->:c = malloc(1i64) => int8->;
        while (g_running == 1i32) {
            int64:r = read(0i32, c => any->, 1i64);
            if (r > 0i64) {
                if (c[0i64] == 113i8) { // 'q'
                    g_running = 0i32;
                }
            }
        }
        free(c => any->);
        pass 0i64;
    };
    int64:input_th = npk_shim_thread_spawn(input_worker, 0i64);
    
    while (g_running == 1i32) {
        print("\x1b[2J\x1b[H\0");
        
        string:kernel = raw get_os_kernel();
        string:uptime = raw get_uptime();
        string:load = raw get_loadavg();
        
        int64:mtot = raw get_mem_total();
        int64:mfree = raw get_mem_free();
        int64:mused = mtot - mfree;
        int32:mperc = 0i32;
        if (mtot > 0i64) {
            mperc = @cast_unchecked<int32>((mused * 100i64) / mtot);
        }
        
        string:cmodel = raw get_cpu_model();
        int64:ccores = raw get_cpu_cores();
        if (ccores == 0i64) {
            ccores = 1i64; // fallback just in case
        }
        
        // System Info Panel
        Widget:p1 = raw Tui.panel(2i32, 2i32, 76i32, 6i32, 7i32, 0i32);
        drop(Tui.draw_widget(p1));
        Widget:l1 = raw Tui.label(4i32, 3i32, string_concat("OS/Kernel: ", kernel), 6i32, 0i32);
        drop(Tui.draw_widget(l1));
        Widget:l2 = raw Tui.label(4i32, 4i32, string_concat("Uptime: ", uptime), 6i32, 0i32);
        drop(Tui.draw_widget(l2));
        Widget:l3 = raw Tui.label(4i32, 5i32, string_concat("Load Average: ", load), 6i32, 0i32);
        drop(Tui.draw_widget(l3));
        
        // Memory Panel
        Widget:p2 = raw Tui.panel(2i32, 9i32, 76i32, 6i32, 7i32, 0i32);
        drop(Tui.draw_widget(p2));
        Widget:lm1 = raw Tui.label(4i32, 10i32, "Memory Usage:", 7i32, 0i32);
        drop(Tui.draw_widget(lm1));
        
        Widget:bar = raw Tui.progress(18i32, 10i32, 50i32, mperc);
        drop(Tui.draw_widget(bar));
        
        string:mstr = string_concat(string_concat(raw format_mem(mused), " / "), raw format_mem(mtot));
        Widget:lm2 = raw Tui.label(4i32, 12i32, string_concat("Used: ", mstr), 6i32, 0i32);
        drop(Tui.draw_widget(lm2));
        
        // CPU Panel
        Widget:p3 = raw Tui.panel(2i32, 16i32, 76i32, 5i32, 7i32, 0i32);
        drop(Tui.draw_widget(p3));
        Widget:lc1 = raw Tui.label(4i32, 17i32, string_concat("CPU Model: ", cmodel), 2i32, 0i32);
        drop(Tui.draw_widget(lc1));
        Widget:lc2 = raw Tui.label(4i32, 18i32, string_concat("CPU Cores: ", string_from_int(ccores)), 2i32, 0i32);
        drop(Tui.draw_widget(lc2));
        
        // Footer
        Widget:foot = raw Tui.label(2i32, 22i32, "[q] Quit    [nkmon - Nitpick Kernel Monitor]", 3i32, 0i32);
        drop(Tui.draw_widget(foot));
        
        // Sleep for 1 second total (checking running flag every 100ms for fast exit)
        int32:wait = 0i32;
        while ((wait < 10i32) && (g_running == 1i32)) {
            drop(usleep(100000i32));
            wait = wait + 1i32;
        }
    }
    
    drop(Tui.shutdown());
    
    // We don't join the input thread since it's blocking on read.
    // It will die when the process exits.
    exit(0i32);
};
