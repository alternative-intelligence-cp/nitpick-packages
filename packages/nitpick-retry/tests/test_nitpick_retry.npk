// test_nitpick_retry.npk — 12-test suite for nitpick-retry (v0.12.3)
extern "libc" { func:printf = int32(string:fmt); }
use "../src/nitpick_retry.npk".*;

int64:fail_cnt = 0i64;

func:failsafe = int32(tbb32:err) {
    drop err;
    exit 1i32;
};

func:assert_eq_i32 = int32(int32:actual, int32:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i32);
};

func:assert_eq_i64 = int64(int64:actual, int64:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass 0i64;
};

func:assert_eq_string = int32(string:actual, string:expected, string:test_name) {
    if (actual != expected) {
        fail_cnt += 1i64;
        drop(printf("[FAIL] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    } else {
        drop(printf("[PASS] \0"));
        drop(printf(test_name));
        drop(printf("\n\0"));
    }
    pass(0i32);
};

func:test_basic = int32() {
    int64:r = raw Retry.init(3i64, 100i64, 5000i64);
    int32:ok1 = 0i32;
    if (r > 0i64) { ok1 = 1i32; }
    drop assert_eq_i32(ok1, 1i32, "T01 retry_create\0");

    string:a2 = raw Retry.attempt(r);
    drop assert_eq_string(a2, "0", "T02 attempt=0\0");

    int64:sr3 = raw Retry.can_retry(r);
    drop assert_eq_i64(sr3, 1i64, "T03 should_retry=1\0");

    pass 0i32;
};

func:test_delay = int32() {
    int64:r = raw Retry.init(5i64, 100i64, 5000i64);

    string:d4 = raw Retry.delay(r);
    drop assert_eq_string(d4, "100", "T04 delay=100\0");

    int32:_f1 = raw Retry.rec_fail(r);
    string:d5 = raw Retry.delay(r);
    drop assert_eq_string(d5, "200", "T05 delay=200\0");

    int64:r2 = raw Retry.init(5i64, 1000i64, 3000i64);
    int32:_f2a = raw Retry.rec_fail(r2);
    int32:_f2b = raw Retry.rec_fail(r2);
    int32:_f2c = raw Retry.rec_fail(r2);
    string:d6 = raw Retry.delay(r2);
    drop assert_eq_string(d6, "3000", "T06 delay capped=3000\0");

    pass 0i32;
};

func:test_fail = int32() {
    int64:r = raw Retry.init(2i64, 100i64, 5000i64);

    int32:_f1 = raw Retry.rec_fail(r);
    string:a7 = raw Retry.attempt(r);
    drop assert_eq_string(a7, "1", "T07 attempt=1\0");

    int32:_f2 = raw Retry.rec_fail(r);
    int64:ex8 = raw Retry.is_done(r);
    drop assert_eq_i64(ex8, 1i64, "T08 exhausted\0");

    int64:sr9 = raw Retry.can_retry(r);
    drop assert_eq_i64(sr9, 0i64, "T09 no retry\0");

    pass 0i32;
};

func:test_success = int32() {
    int64:r = raw Retry.init(3i64, 100i64, 5000i64);

    int64:ok10 = raw Retry.is_ok(r);
    drop assert_eq_i64(ok10, 0i64, "T10 not ok yet\0");

    int32:_f1 = raw Retry.rec_fail(r);
    int32:_ok = raw Retry.rec_ok(r);
    int64:ok11 = raw Retry.is_ok(r);
    drop assert_eq_i64(ok11, 1i64, "T11 succeeded\0");

    int64:sr12 = raw Retry.can_retry(r);
    drop assert_eq_i64(sr12, 0i64, "T12 no retry after ok\0");

    pass 0i32;
};

func:main = int32() {
    drop test_basic();
    drop test_delay();
    drop test_fail();
    drop test_success();

    if (fail_cnt > 0i64) {
        drop(printf("SOME TESTS FAILED\n\0"));
        exit 1i32;
    }

    drop(printf("SUCCESS: All tests passed.\n\0"));
    exit 0i32;
};
