use std.core.memory;

pub func:failsafe = int32(tbb32:err) { exit 1; };

struct:FloatNode = { float64:v; };

pub func:main = int32() {
    alloc_result<FloatNode>:res = raw alloc_array<FloatNode>(15i32);
    if (!is_ok(res)) { exit 1; }
    wild FloatNode->:nodes = unwrap(res);
    nodes[0i32].v = 42.0;
    if (nodes[0i32].v == 42.0) { exit 0; }
    exit 1;
};
