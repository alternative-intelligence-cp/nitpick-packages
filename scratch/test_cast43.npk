extern func:println_f64 = void(float64:v);
pub func:failsafe = int32(tbb32:err) { exit 1; };

func:takes_ptr = int64(wild float64->:ptr) {
    ptr[14i64] = 42.0;
    pass 1i64;
};

func:do_test = int64() {
    float64[15]:nodes;
    nodes[0i64] = 0.0;
    int64:ret = raw takes_ptr(nodes);
    println_f64(nodes[14i64]);
    pass ret;
};

pub func:main = int32() {
    drop(do_test());
    exit 0;
};
